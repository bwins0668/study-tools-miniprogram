.fc-container{min-height:100vh;padding:24rpx 32rpx 160rpx;background:#f7f7f7}
.fc-loading{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:200rpx 32rpx}
.fc-loading-spinner{width:56rpx;height:56rpx;border:4rpx solid #e5e5e5;border-top-color:#333;border-radius:50%;animation:fc-spin .8s linear infinite}
@keyframes fc-spin{to{transform:rotate(360deg)}}
.fc-loading-text{margin-top:20rpx;font-size:28rpx;color:#999}
.fc-error{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:200rpx 32rpx}
.fc-error-icon{font-size:56rpx;font-weight:700;color:#e53935;width:80rpx;height:80rpx;line-height:80rpx;text-align:center;border-radius:50%;background:#fce4ec;margin-bottom:24rpx}
.fc-error-title{font-size:30rpx;font-weight:600;color:#333;margin-bottom:8rpx}
.fc-error-course{font-size:24rpx;color:#999;margin-bottom:12rpx}
.fc-error-detail{font-size:24rpx;color:#999;margin-bottom:32rpx;text-align:center}
.fc-error-actions{display:flex;gap:16rpx}
.fc-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12rpx}
.fc-header-left{display:flex;align-items:center}
.fc-badge{display:inline-flex;align-items:center;justify-content:center;width:48rpx;height:48rpx;border-radius:12rpx;font-size:22rpx;font-weight:700;color:#fff;margin-right:12rpx;flex-shrink:0}
.fc-badge-it{background:#333}
.fc-badge-sg{background:#666}
.fc-header-info{display:flex;flex-direction:column}
.fc-title{font-size:28rpx;font-weight:600;color:#1a1a1a;line-height:1.3}
.fc-header-meta{font-size:22rpx;color:#999;margin-top:2rpx}
.fc-deck-timer{font-size:24rpx;color:#999;font-variant-numeric:tabular-nums}
.fc-progress{height:4rpx;background:#e5e5e5;border-radius:2rpx;margin-bottom:12rpx;overflow:hidden}
.fc-progress-bar{height:100%;background:#333;border-radius:2rpx;transition:width .3s ease}
.fc-stats{display:flex;gap:20rpx;margin-bottom:16rpx}
.fc-stat{font-size:24rpx;font-weight:500}
.fc-stat-correct{color:#4caf50}
.fc-stat-wrong{color:#e53935}
.fc-card{background:#fff;border-radius:16rpx;padding:28rpx;margin-bottom:16rpx;box-shadow:0 1rpx 4rpx rgba(0,0,0,.04)}
.fc-front{border-left:6rpx solid #333}
.fc-question-text{font-size:32rpx;line-height:1.65;color:#1a1a1a;white-space:pre-wrap;word-break:break-all}
.fc-question-zh{font-size:24rpx;line-height:1.6;color:#999;margin-top:12rpx;white-space:pre-wrap}
.fc-options{margin-bottom:16rpx}
.fc-option{display:flex;align-items:flex-start;padding:20rpx;margin-bottom:10rpx;border-radius:12rpx;background:#fff;border:2rpx solid #e8e8e8;transition:all .15s ease}
.fc-option:active{background:#fafafa;transform:scale(.985)}
.fc-option-key{display:inline-flex;align-items:center;justify-content:center;width:44rpx;height:44rpx;border-radius:50%;background:#f0f0f0;font-size:24rpx;font-weight:600;color:#333;margin-right:14rpx;flex-shrink:0}
.fc-option-body{flex:1;min-width:0}
.fc-option-text{display:block;font-size:28rpx;line-height:1.5;color:#1a1a1a;word-break:break-all}
.fc-option-text-zh{display:block;font-size:24rpx;line-height:1.5;color:#999;margin-top:6rpx;word-break:break-all}
.fc-option-correct{border-color:#4caf50;background:#f1f8f1}
.fc-option-wrong{border-color:#e53935;background:#fef2f2}
.fc-option-selected{border-color:#333;background:#f5f5f5}
.fc-feedback{margin-top:12rpx;padding:16rpx 20rpx;border-radius:12rpx;font-size:28rpx;font-weight:600}
.fc-feedback-correct{background:#f1f8f1;border:2rpx solid #4caf50;color:#4caf50}
.fc-feedback-wrong{background:#fef2f2;border:2rpx solid #e53935;color:#e53935}
.fc-feedback-text{font-size:28rpx;font-weight:600;display:block;margin-bottom:12rpx}
.fc-feedback-detail{font-size:24rpx;font-weight:400;margin-bottom:12rpx}
.fc-feedback-item{display:flex;justify-content:space-between;padding:4rpx 0}
.fc-feedback-label{color:#444;font-weight:500}
.fc-feedback-value{font-weight:600;color:#333}
.fc-action-row{display:flex;gap:12rpx;margin-top:12rpx}
.fc-btn{flex:1;display:flex;align-items:center;justify-content:center;padding:22rpx 16rpx;border-radius:12rpx;background:#f0f0f0;font-size:28rpx;color:#333;font-weight:500}
.fc-btn:active{opacity:.75}
.fc-btn-primary{background:#333;color:#fff;font-weight:600}
.fc-btn-secondary{background:#f0f0f0;color:#666;border:2rpx solid #ddd}
.fc-btn-ghost{background:transparent;border:2rpx solid #ddd;color:#666}
.fc-btn-retry{background:#fff8e1;color:#795548;border:2rpx solid #ffe082}
.fc-btn-full{flex:none;width:100%}
.fc-back-block{background:#fff;border-radius:14rpx;padding:24rpx;margin-bottom:12rpx;box-shadow:0 1rpx 4rpx rgba(0,0,0,.04)}
.fc-back-label{display:block;font-size:20rpx;font-weight:600;color:#999;text-transform:uppercase;letter-spacing:1rpx;margin-bottom:10rpx}
.fc-back-ja{font-size:28rpx;line-height:1.65;color:#1a1a1a;white-space:pre-wrap;word-break:break-all;display:block}
.fc-back-zh{font-size:24rpx;line-height:1.6;color:#aaa;white-space:pre-wrap;word-break:break-all;margin-top:10rpx;display:block}
.fc-back-verdict{display:flex;flex-direction:column;gap:16rpx;padding:20rpx 24rpx}
.fc-verdict-item{width:100%}
.fc-verdict-value{display:block;font-size:36rpx;font-weight:700;margin-top:6rpx}
.fc-verdict-correct{color:#4caf50}
.fc-verdict-wrong{color:#e53935}
.fc-back-options{margin-top:4rpx}
.fc-back-option{padding:16rpx 20rpx;margin-bottom:8rpx;border-radius:10rpx;background:#fafafa;border:2rpx solid #eee}
.fc-back-option-correct{border-color:#4caf50;background:#f1f8f1}
.fc-back-option-wrong{border-color:#e53935;background:#fef2f2}
.fc-back-option-selected-correct{border-color:#4caf50;background:#e8f5e9}
.fc-back-option-head{display:flex;align-items:center;gap:10rpx;margin-bottom:8rpx}
.fc-back-option-key{display:inline-flex;align-items:center;justify-content:center;width:40rpx;height:40rpx;border-radius:50%;background:#e8e8e8;font-size:22rpx;font-weight:600;color:#333}
.fc-back-option-key-correct{background:#4caf50;color:#fff}
.fc-back-option-mark{font-size:20rpx;padding:2rpx 10rpx;border-radius:6rpx;font-weight:600;background:#e3f2fd;color:#1565c0}
.fc-back-option-mark-correct{background:#e8f5e9;color:#2e7d32}
.fc-back-option-ja{display:block;font-size:26rpx;line-height:1.55;color:#1a1a1a;word-break:break-all}
.fc-back-option-zh{display:block;font-size:24rpx;line-height:1.5;color:#999;margin-top:6rpx;word-break:break-all}
.fc-back-option-explain{margin-top:10rpx;padding-top:10rpx;border-top:1rpx solid #eee}
.fc-back-explain-ja{display:block;font-size:24rpx;line-height:1.6;color:#555;word-break:break-all}
.fc-back-explain-zh{display:block;font-size:22rpx;line-height:1.55;color:#aaa;margin-top:6rpx;word-break:break-all}
.fc-back-detail-ja{display:block;font-size:26rpx;line-height:1.7;color:#1a1a1a;white-space:pre-wrap;word-break:break-all}
.fc-back-detail-zh{display:block;font-size:24rpx;line-height:1.6;color:#555;margin-top:12rpx;white-space:pre-wrap;word-break:auto-phrase}
.fc-back-mnemonic{background:#fff;border-left:4rpx solid #999}
.fc-back-mnemonic-ja{display:block;font-size:26rpx;line-height:1.6;color:#1a1a1a;word-break:break-all}
.fc-back-mnemonic-zh{display:block;font-size:24rpx;line-height:1.55;color:#aaa;margin-top:8rpx;word-break:break-all}
.fc-result{background:#fff;border-radius:16rpx;padding:40rpx 32rpx;text-align:center;box-shadow:0 1rpx 4rpx rgba(0,0,0,.04)}
.fc-result-title{font-size:34rpx;font-weight:700;color:#1a1a1a;display:block;margin-bottom:8rpx}
.fc-result-accuracy{margin-bottom:28rpx}
.fc-result-pct{font-size:72rpx;font-weight:700;color:#333;display:block;line-height:1.1}
.fc-result-label{font-size:24rpx;color:#999}
.fc-result-stats{display:flex;justify-content:center;gap:48rpx;margin-bottom:28rpx}
.fc-result-stat{text-align:center}
.fc-result-stat-value{font-size:38rpx;font-weight:700;display:block}
.fc-result-stat-correct .fc-result-stat-value{color:#4caf50}
.fc-result-stat-wrong .fc-result-stat-value{color:#e53935}
.fc-result-stat-label{font-size:22rpx;color:#999}
.fc-result-actions{display:flex;flex-direction:column;gap:12rpx}
.fc-result-actions .fc-btn{flex:none}
.fc-empty{display:flex;flex-direction:column;align-items:center;padding:120rpx 32rpx}
.fc-empty-title{font-size:32rpx;font-weight:600;color:#1a1a1a;margin-bottom:12rpx}
.fc-empty-detail{font-size:26rpx;color:#999;margin-bottom:40rpx;text-align:center}
.fc-status-tag{display:inline-block;padding:4rpx 16rpx;border-radius:8rpx;font-size:22rpx;font-weight:500;margin-bottom:16rpx}
.fc-status-ja{background:#f0f0f0;color:#888}
.fc-status-partial{background:#fff8e1;color:#f59e0b}
.fc-status-full{background:#e8f5e9;color:#2e7d32}
