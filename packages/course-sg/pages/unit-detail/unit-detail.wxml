<view class="td-page {{__themeDark ? 'dark-theme' : ''}}">
  <view class="td-top">
    <view class="td-back" bindtap="goBack">返回</view>
  </view>

  <block wx:if="{{notFound}}">
    <view class="td-empty">
      <text class="td-empty__title">章节暂不可用</text>
      <text class="td-empty__sub">该教材单元不存在或尚未开放</text>
    </view>
  </block>

  <block wx:else>
    <view class="td-head">
      <text class="td-head__ja">{{unit.titleJa}}</text>
      <text class="td-head__zh">{{unit.titleZh}}</text>
      <text class="td-source">{{sourceText}}</text>
    </view>

    <block wx:if="{{hasLearningExperience}}">
      <view class="td-source-card">
        <text class="td-kicker">原书路径</text>
        <text class="td-source-card__main">{{sourceInfo.sourceText}}</text>
        <text class="td-source-card__line">章节路径：{{sourceInfo.headingJa}}</text>
        <text class="td-source-card__line">定位关键词：{{sourceInfo.anchorTermsText}}</text>
        <text class="td-source-card__status">{{unit.sourceAccess.displayLabel}}</text>
      </view>

      <view class="td-section">
        <text class="td-kicker">这节要解决什么</text>
        <text class="td-copy td-copy--ja">{{unit.learningExperience.goalJa}}</text>
        <view class="td-zh-block">
          <text class="td-lang-label">中文理解</text>
          <text class="td-copy">{{unit.learningExperience.goalZh}}</text>
        </view>
      </view>

      <view class="td-section">
        <text class="td-kicker">核心概念</text>
        <text class="td-section__title">{{unit.learningExperience.coreConcept.headingJa}}</text>
        <text class="td-section__sub">{{unit.learningExperience.coreConcept.headingZh}}</text>
        <text class="td-copy td-copy--ja">{{unit.learningExperience.coreConcept.bodyJa}}</text>
        <view class="td-zh-block">
          <text class="td-lang-label">中文理解</text>
          <text class="td-copy">{{unit.learningExperience.coreConcept.bodyZh}}</text>
        </view>
      </view>

      <view class="td-section" wx:if="{{unit.learningExperience.prerequisiteConcepts && unit.learningExperience.prerequisiteConcepts.length}}">
        <text class="td-kicker">前置概念</text>
        <view class="td-mini-row" wx:for="{{unit.learningExperience.prerequisiteConcepts}}" wx:key="labelJa">
          <text class="td-mini-row__title">{{item.labelJa}} ｜ {{item.labelZh}}</text>
          <text class="td-copy td-copy--ja">{{item.bodyJa}}</text>
          <text class="td-copy">{{item.bodyZh}}</text>
        </view>
      </view>

      <view class="td-section" wx:if="{{unit.learningExperience.caseBreakdown && unit.learningExperience.caseBreakdown.length}}">
        <text class="td-kicker">案例 / 情境拆解</text>
        <view class="td-case-row" wx:for="{{unit.learningExperience.caseBreakdown}}" wx:key="labelJa">
          <text class="td-case-row__label">{{item.labelJa}}</text>
          <text class="td-case-row__zh">{{item.labelZh}}</text>
          <text class="td-copy td-copy--ja">{{item.bodyJa}}</text>
          <text class="td-copy">{{item.bodyZh}}</text>
        </view>
      </view>

      <view class="td-section">
        <text class="td-kicker">考试判断线索</text>
        <view class="td-focus" wx:for="{{unit.learningExperience.examCues}}" wx:key="cueJa">
          <text class="td-focus__ja">{{item.cueJa}}</text>
          <text class="td-focus__zh">{{item.cueZh}}</text>
        </view>
      </view>

      <view class="td-section">
        <text class="td-kicker">关键术语</text>
        <view class="td-term td-term--tap" wx:for="{{unit.keyTerms}}" wx:key="id" data-term-id="{{item.id}}" bindtap="openTermDetail">
          <text class="td-term__en">{{item.en}}</text>
          <text class="td-term__sep">｜</text>
          <text class="td-term__ja">{{item.ja}}</text>
          <text class="td-term__sep">｜</text>
          <text class="td-term__zh">{{item.zh}}</text>
        </view>
      </view>

      <view class="td-section">
        <text class="td-kicker">易错对比</text>
        <view class="td-compare" wx:for="{{unit.learningExperience.mistakeComparisons}}" wx:key="aJa">
          <text class="td-compare__pair">{{item.aJa}} / {{item.bJa}}</text>
          <text class="td-copy td-copy--ja">{{item.bodyJa}}</text>
          <text class="td-copy">{{item.bodyZh}}</text>
        </view>
      </view>

      <view class="td-section">
        <text class="td-kicker">关联练习</text>
        <text class="td-copy" wx:if="{{unit.relatedQuestionIds.length > 0}}">已关联既有课程题 {{unit.relatedQuestionIds.length}} 题。</text>
        <text class="td-copy" wx:else>当前没有可直接关联的既有课程题。</text>
        <view class="td-btn {{practiceAvailable ? 'td-btn--primary' : 'td-btn--disabled'}}" bindtap="startPractice">{{practiceAvailable ? '开始本主题练习' : '暂无对应既有题目'}}</view>
      </view>
    </block>

    <block wx:else>
      <view class="td-band">
        <text class="td-band__label">学習目標</text>
        <text class="td-band__ja">{{unit.learningGoalJa}}</text>
        <text class="td-band__zh">{{unit.learningGoalZh}}</text>
      </view>

      <view class="td-section">
        <text class="td-section__title">概要</text>
        <text class="td-copy td-copy--ja">{{unit.overviewJa}}</text>
        <text class="td-copy">{{unit.overviewZh}}</text>
      </view>

      <view class="td-section" wx:for="{{unit.sections}}" wx:key="headingJa">
        <text class="td-section__title">{{item.headingJa}}</text>
        <text class="td-section__sub">{{item.headingZh}}</text>
        <text class="td-copy td-copy--ja">{{item.explanationJa}}</text>
        <text class="td-copy">{{item.explanationZh}}</text>
        <view class="td-focus">
          <text class="td-focus__ja">{{item.examFocusJa}}</text>
          <text class="td-focus__zh">{{item.examFocusZh}}</text>
        </view>
        <view class="td-trap">
          <text class="td-trap__ja">{{item.commonMistakeJa}}</text>
          <text class="td-trap__zh">{{item.commonMistakeZh}}</text>
        </view>
        <view class="td-tags">
          <text class="td-tag" wx:for="{{item.englishTerms}}" wx:for-item="term" wx:key="*this">{{term}}</text>
        </view>
        <view class="td-locator" wx:for="{{item.sourceRefs}}" wx:for-item="ref" wx:key="headingJa">
          <text>原书定位：PDF 第 {{ref.pdfPageStart}} 页{{ref.pdfPageEnd > ref.pdfPageStart ? ' - ' + ref.pdfPageEnd + ' 页' : ''}} / 纸质页未验证</text>
        </view>
      </view>

      <view class="td-section">
        <text class="td-section__title">关键术语</text>
        <view class="td-term" wx:for="{{unit.keyTerms}}" wx:key="termJa">
          <text class="td-term__ja">{{item.termJa}}</text>
          <text class="td-term__zh">{{item.termZh}}</text>
          <text class="td-term__en">{{item.english || ''}}</text>
        </view>
      </view>

      <view class="td-section">
        <text class="td-section__title">易错点</text>
        <view class="td-trap-row" wx:for="{{unit.commonTraps}}" wx:key="trapJa">
          <text class="td-trap-row__ja">{{item.trapJa}}</text>
          <text class="td-trap-row__zh">{{item.trapZh}}</text>
        </view>
      </view>

      <view class="td-section">
        <text class="td-section__title">关联练习</text>
        <text class="td-copy" wx:if="{{unit.relatedQuestionIds.length > 0}}">已关联既有课程题 {{unit.relatedQuestionIds.length}} 题。</text>
        <text class="td-copy" wx:else>当前没有可直接关联的既有课程题。</text>
        <view class="td-btn {{practiceAvailable ? 'td-btn--primary' : 'td-btn--disabled'}}" bindtap="startPractice">{{practiceAvailable ? '开始本主题练习' : '暂无对应既有题目'}}</view>
      </view>
    </block>

    <view class="td-sheet-mask" wx:if="{{termSheetVisible}}" bindtap="closeTermDetail" catchtouchmove="noop">
      <view class="td-term-sheet" catchtap="noop">
        <view class="td-term-sheet__top">
          <view>
            <text class="td-term-sheet__en">{{selectedTerm.en}}</text>
            <text class="td-term-sheet__triad">{{selectedTerm.ja}} ｜ {{selectedTerm.zh}}</text>
            <text class="td-term-sheet__exp" wx:if="{{selectedTerm.expansionEn}}">{{selectedTerm.expansionEn}}</text>
          </view>
          <text class="td-term-sheet__close" catchtap="closeTermDetail">关闭</text>
        </view>
        <view class="td-term-detail">
          <text class="td-lang-label">日语定义</text>
          <text class="td-copy td-copy--ja">{{selectedTerm.definitionJa}}</text>
          <text class="td-lang-label">中文理解</text>
          <text class="td-copy">{{selectedTerm.definitionZh}}</text>
          <text class="td-lang-label">这一节里为什么会出现它</text>
          <text class="td-copy td-copy--ja">{{selectedTerm.contextJa}}</text>
          <text class="td-copy">{{selectedTerm.contextZh}}</text>
          <text class="td-lang-label">容易混淆</text>
          <view class="td-tags">
            <text class="td-tag" wx:for="{{selectedTerm.compareWith}}" wx:key="*this">{{item}}</text>
          </view>
          <text class="td-lang-label">考试如何区分</text>
          <text class="td-copy td-copy--ja">{{selectedTerm.examCueJa}}</text>
          <text class="td-copy">{{selectedTerm.examCueZh}}</text>
          <text class="td-lang-label">原书定位</text>
          <view class="td-locator" wx:for="{{selectedTerm.sourceRefs}}" wx:for-item="ref" wx:key="headingJa">
            <text>PDF 第 {{ref.pdfPageStart}} 页{{ref.pdfPageEnd > ref.pdfPageStart ? ' - ' + ref.pdfPageEnd + ' 页' : ''}} / {{ref.headingJa}}</text>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
