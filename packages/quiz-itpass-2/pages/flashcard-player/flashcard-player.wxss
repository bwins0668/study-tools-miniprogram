.fc-container{min-height:100vh;padding:24rpx 32rpx 160rpx;background:var(--bg-primary,#f5f5f5)}
.fc-loading{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:200rpx 32rpx}
.fc-loading-spinner{width:60rpx;height:60rpx;border:4rpx solid #e5e7eb;border-top-color:#3b82f6;border-radius:50%;animation:fc-spin .8s linear infinite}
@keyframes fc-spin{to{transform:rotate(360deg)}}
.fc-loading-text{margin-top:24rpx;font-size:28rpx;color:#6b7280}
.fc-error{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:200rpx 32rpx}
.fc-error-title{font-size:32rpx;font-weight:600;color:#ef4444;margin-bottom:12rpx}
.fc-error-detail{font-size:28rpx;color:#6b7280;margin-bottom:8rpx;text-align:center}
.fc-error-meta{font-size:24rpx;color:#9ca3af;margin-bottom:32rpx;text-align:center}
.fc-empty{display:flex;flex-direction:column;align-items:center;padding:200rpx 32rpx}
.fc-empty-title{font-size:32rpx;color:#6b7280;margin-bottom:32rpx}
.fc-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:16rpx}
.fc-deck-label{font-size:28rpx;color:#6b7280}
.fc-deck-meta{font-size:28rpx;font-weight:600;color:#111827}
.fc-progress{height:6rpx;background:#e5e7eb;border-radius:3rpx;margin-bottom:20rpx;overflow:hidden}
.fc-progress-bar{height:100%;background:#3b82f6;border-radius:3rpx;transition:width .3s ease}
.fc-card{background:var(--bg-card,#fff);border-radius:20rpx;padding:32rpx;margin-bottom:20rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.06);border-left:8rpx solid #3b82f6}
.fc-question-text{font-size:32rpx;line-height:1.7;color:var(--text-primary,#1a1a1a);white-space:pre-wrap}
.fc-options{margin-bottom:20rpx}
.fc-option{display:flex;align-items:flex-start;padding:24rpx;margin-bottom:12rpx;border-radius:16rpx;background:var(--bg-card,#fff);border:2rpx solid var(--border-color,#e5e5e5);transition:all .2s ease}
.fc-option:active{transform:scale(.98)}
.fc-option-key{display:inline-flex;align-items:center;justify-content:center;width:48rpx;height:48rpx;border-radius:50%;background:var(--bg-secondary,#e8e8e8);font-size:26rpx;font-weight:600;color:var(--text-primary,#1a1a1a);margin-right:16rpx;flex-shrink:0}
.fc-option-text{flex:1;font-size:28rpx;line-height:1.6;color:var(--text-primary,#1a1a1a)}
.fc-option-status{margin-left:12rpx;flex-shrink:0}
.fc-status-correct{font-size:26rpx;font-weight:600;color:#10b981}
.fc-status-wrong{font-size:26rpx;font-weight:600;color:#ef4444}
.fc-option-correct{border-color:#10b981;background:#ecfdf5}
.fc-option-correct .fc-option-key{background:#10b981;color:#fff}
.fc-option-wrong{border-color:#ef4444;background:#fef2f2}
.fc-option-wrong .fc-option-key{background:#ef4444;color:#fff}
.fc-option-dim{opacity:.5}
.fc-feedback{margin-top:16rpx}
.fc-feedback-bar{display:flex;align-items:center;padding:20rpx 24rpx;border-radius:12rpx;margin-bottom:16rpx}
.fc-feedback-correct{background:#ecfdf5;border:2rpx solid #10b981}
.fc-feedback-wrong{background:#fef2f2;border:2rpx solid #ef4444}
.fc-feedback-correct .fc-feedback-text{color:#10b981}
.fc-feedback-wrong .fc-feedback-text{color:#ef4444}
.fc-feedback-text{font-size:30rpx;font-weight:600}
.fc-action-row{display:flex;gap:16rpx;margin-top:16rpx}
.fc-btn{flex:1;display:flex;align-items:center;justify-content:center;padding:24rpx 16rpx;border-radius:14rpx;background:var(--bg-secondary,#e8e8e8);font-size:28rpx;color:var(--text-primary,#1a1a1a)}
.fc-btn:active{opacity:.8}
.fc-btn-primary{background:#3b82f6;color:#fff;font-weight:600}
.fc-btn-next{background:var(--bg-card,#fff);border:2rpx solid #3b82f6;color:#3b82f6;font-weight:600}
.fc-result{background:var(--bg-card,#fff);border-radius:20rpx;padding:40rpx 32rpx;text-align:center}
.fc-result-title{font-size:36rpx;font-weight:700;color:var(--text-primary,#1a1a1a);display:block;margin-bottom:32rpx}
.fc-error-actions{display:flex;gap:16rpx;margin-top:24rpx}
