/* pages/quiz/quiz.wxss */

.container {
  padding: 20rpx 0 60rpx;
  min-height: 100vh;
}

/* 头部 */
.quiz-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 30rpx 20rpx;
}

.quiz-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
}

.quiz-progress {
  font-size: 26rpx;
  color: #999999;
}

/* 题目卡片 */
.question-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin: 0 30rpx 20rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.question-zh {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.question-ja {
  display: block;
  font-size: 26rpx;
  color: #888888;
  line-height: 1.6;
}

.question-source {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.source-badge {
  font-size: 22rpx;
  color: #4a90d9;
  background-color: #e8f0fe;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.source-badge-exam {
  color: #e65100;
  background-color: #fff3e0;
}

.source-title {
  font-size: 24rpx;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.translation-warning {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  padding: 10rpx 16rpx;
  background-color: #fff8e1;
  border-radius: 8rpx;
}

.warning-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
  color: #f59e0b;
}

.warning-text {
  font-size: 24rpx;
  color: #b45309;
}

/* 选项列表 */
.options-list {
  padding: 0 30rpx;
}

.option-item {
  display: flex;
  align-items: flex-start;
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid transparent;
}

.option-item:active {
  background-color: #f5f5f5;
}

.option-correct {
  background-color: #e8f5e9;
  border-color: #4caf50;
}

.option-wrong {
  background-color: #fbe9e7;
  border-color: #f44336;
}

.option-answer {
  background-color: #e8f5e9;
  border-color: #4caf50;
}

.option-key {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #666666;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-content {
  flex: 1;
}

.option-zh {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 4rpx;
}

.option-ja {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

/* 答题反馈 */
.feedback-section {
  padding: 10rpx 0;
}

.feedback-result {
  display: flex;
  align-items: center;
  margin: 0 30rpx 16rpx;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
}

.feedback-correct {
  background-color: #e8f5e9;
}

.feedback-wrong {
  background-color: #fbe9e7;
}

.feedback-icon {
  font-size: 36rpx;
  font-weight: 700;
  margin-right: 16rpx;
}

.feedback-correct .feedback-icon {
  color: #4caf50;
}

.feedback-wrong .feedback-icon {
  color: #f44336;
}

.feedback-text {
  font-size: 28rpx;
  font-weight: 500;
}

.feedback-correct .feedback-text {
  color: #2e7d32;
}

.feedback-wrong .feedback-text {
  color: #c62828;
}

/* 解释卡片 */
.explanation-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin: 0 30rpx 20rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.explanation-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #4a90d9;
  margin-bottom: 8rpx;
  margin-top: 16rpx;
}

.explanation-title:first-child {
  margin-top: 0;
}

.explanation-body {
  display: block;
  font-size: 26rpx;
  color: #555555;
  line-height: 1.7;
}

.explanation-warning {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  padding: 10rpx 16rpx;
  background-color: #fff8e1;
  border-radius: 8rpx;
}

/* 下一题按钮 */
.next-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #4a90d9;
  border-radius: 40rpx;
  margin: 20rpx 60rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
}

.next-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 完成页面 */
.finish-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin: 60rpx 30rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.finish-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.finish-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 40rpx;
}

.finish-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  width: 100%;
  margin-bottom: 40rpx;
}

.finish-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.finish-stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 8rpx;
}

.finish-correct {
  color: #4caf50;
}

.finish-wrong {
  color: #f44336;
}

.finish-stat-label {
  font-size: 24rpx;
  color: #999999;
}

.finish-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #4a90d9;
  border-radius: 40rpx;
  padding: 24rpx 80rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
}

.finish-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 本次练习结果 */
.result-card {
  box-sizing: border-box;
  background-color: #ffffff;
  border-radius: 20rpx;
  margin: 32rpx 30rpx;
  padding: 44rpx 30rpx 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  text-align: center;
  overflow: hidden;
}

.result-kicker {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
}

.result-mode {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #777777;
  line-height: 1.5;
}

.accuracy-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 34rpx auto 28rpx;
}

.accuracy-value {
  font-size: 72rpx;
  line-height: 1.1;
  font-weight: 800;
  color: #4a90d9;
}

.accuracy-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #888888;
}

.result-stats {
  display: flex;
  width: 100%;
  padding: 24rpx 0;
  border-top: 1rpx solid #eeeeee;
  border-bottom: 1rpx solid #eeeeee;
}

.result-stat {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.result-stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
}

.result-correct {
  color: #2e7d32;
}

.result-wrong {
  color: #c62828;
}

.result-stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #888888;
  line-height: 1.4;
}

.encouragement-text {
  display: block;
  margin: 28rpx 0;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background-color: #eef5fd;
  font-size: 27rpx;
  color: #356a9f;
  line-height: 1.5;
}

.result-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
}

.result-btn {
  box-sizing: border-box;
  width: 100%;
  padding: 22rpx 24rpx;
  border: 2rpx solid #d9e3ee;
  border-radius: 40rpx;
  background-color: #ffffff;
}

.result-btn-primary {
  border-color: #4a90d9;
  background-color: #4a90d9;
  box-shadow: 0 4rpx 14rpx rgba(74, 144, 217, 0.25);
}

.result-btn-text {
  font-size: 29rpx;
  font-weight: 600;
  color: #4a6b8a;
}

.result-btn-text-primary {
  color: #ffffff;
}
