/* pages/quiz/quiz.wxss */
/* Round 3.146: Quiz 答题页面视觉升级 */

.container {
  padding: 0 0 60rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #1a2a4a 0%, #1e3560 30%, #f5f5f5 55%);
  position: relative;
}

/* ===== 头部沉浸区 ===== */
.quiz-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 30rpx 20rpx;
  position: relative;
  z-index: 2;
}

.quiz-header-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.quiz-exam-badge {
  font-size: 22rpx;
  font-weight: 700;
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  letter-spacing: 1rpx;
  backdrop-filter: blur(10px);
}

.badge-it {
  color: #7cb8f7;
  background-color: rgba(74, 144, 217, 0.2);
  border: 1rpx solid rgba(74, 144, 217, 0.3);
}

.badge-sg {
  color: #e099f0;
  background-color: rgba(156, 39, 176, 0.2);
  border: 1rpx solid rgba(156, 39, 176, 0.3);
}

.badge-wrong {
  color: #f8a0a0;
  background-color: rgba(239, 68, 68, 0.2);
  border: 1rpx solid rgba(239, 68, 68, 0.3);
}

.quiz-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

/* R3.62 答题计时器 */
.timer-section {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 8rpx 20rpx;
  background-color: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  backdrop-filter: blur(10px);
}

.timer-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.timer-text {
  font-size: 28rpx;
  color: #fbbf24;
  font-weight: 600;
  font-family: 'SF Mono', 'Menlo', monospace;
}

/* ===== 进度条 + 百分比 ===== */
.progress-row {
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  margin-bottom: 4rpx;
}

.progress-bar-wrap {
  height: 8rpx;
  background-color: rgba(255, 255, 255, 0.12);
  flex: 1;
  border-radius: 4rpx;
  overflow: hidden;
  margin-right: 16rpx;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #60a5fa, #a78bfa);
  border-radius: 4rpx;
  transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 0 12rpx rgba(96, 165, 250, 0.4);
}

.progress-percent {
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.7);
  flex-shrink: 0;
  min-width: 68rpx;
  text-align: right;
}

/* ===== 实时会话统计 ===== */
.session-stats {
  display: flex;
  align-items: center;
  padding: 10rpx 30rpx 16rpx;
  gap: 24rpx;
}

.session-stat-item {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.session-stat-correct {
  color: #4ade80;
  font-weight: 600;
}

.session-stat-wrong {
  color: #f87171;
  font-weight: 600;
}

/* ===== 题目内题号 ===== */
.question-progress-row {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--divider-color);
}

.question-number {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* ===== 题目卡片 ===== */
.question-card {
  background: linear-gradient(170deg, #ffffff 0%, #f6f8fc 50%, #eef2fa 100%);
  border-radius: 20rpx;
  margin: 0 30rpx 20rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08), 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
  position: relative;
  overflow: hidden;
}

.question-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, var(--color-itpass, #4a90d9), #a78bfa);
}

.question-zh {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.7;
  margin-bottom: 12rpx;
}

.question-ja {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.question-source {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--divider-color);
}

.source-badge {
  font-size: 22rpx;
  color: var(--color-itpass, #4a90d9);
  background-color: var(--color-itpass-light, rgba(74,144,217,0.1));
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.source-badge-exam {
  color: #e65100;
  background-color: rgba(230, 81, 0, 0.08);
}

.source-title {
  font-size: 24rpx;
  color: var(--text-hint);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.translation-warning {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background-color: rgba(245, 158, 11, 0.08);
  border-radius: 10rpx;
  border-left: 4rpx solid #f59e0b;
}

.warning-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
  color: #f59e0b;
}

.warning-text {
  font-size: 24rpx;
  color: #b45309;
}

/* ===== R3.60 提示按钮 ===== */
.hint-section {
  margin-top: 16rpx;
  padding: 0;
}

.hint-btn {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 22rpx;
  background-color: rgba(74, 144, 217, 0.08);
  border-radius: 10rpx;
  border: 1rpx solid rgba(74, 144, 217, 0.15);
  transition: all var(--transition-fast);
}

.hint-btn-active {
  background-color: rgba(74, 144, 217, 0.15);
  border-color: rgba(74, 144, 217, 0.25);
}

.hint-btn-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.hint-btn-text {
  font-size: 24rpx;
  color: var(--color-itpass, #4a90d9);
  font-weight: 500;
}

.hint-content {
  margin-top: 12rpx;
  padding: 16rpx 20rpx;
  background-color: rgba(74, 144, 217, 0.04);
  border-radius: 10rpx;
  border-left: 4rpx solid var(--color-itpass, #4a90d9);
}

.hint-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

/* ===== 选项列表 ===== */
.options-list {
  padding: 0 30rpx;
}

.option-item {
  display: flex;
  align-items: flex-start;
  background: linear-gradient(170deg, #ffffff 0%, #fcfcfd 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.option-item:active {
  transform: scale(0.98);
  background: linear-gradient(170deg, #f8f9fa 0%, #f0f2f5 100%);
}

.option-correct {
  background: linear-gradient(170deg, #f0fdf4 0%, #dcfce7 100%);
  border-color: #22c55e;
  box-shadow: 0 2rpx 16rpx rgba(34, 197, 94, 0.15);
}

.option-correct .option-key {
  background-color: #22c55e;
  color: #ffffff;
}

.option-wrong {
  background: linear-gradient(170deg, #fef2f2 0%, #fee2e2 100%);
  border-color: #ef4444;
  box-shadow: 0 2rpx 16rpx rgba(239, 68, 68, 0.15);
}

.option-wrong .option-key {
  background-color: #ef4444;
  color: #ffffff;
}

.option-answer {
  background: linear-gradient(170deg, #f0fdf4 0%, #dcfce7 100%);
  border-color: #22c55e;
  box-shadow: 0 2rpx 12rpx rgba(34, 197, 94, 0.1);
}

.option-answer .option-key {
  background-color: #22c55e;
  color: #ffffff;
}

.option-key {
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  background-color: rgba(0, 0, 0, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-secondary);
  margin-right: 20rpx;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.option-content {
  flex: 1;
}

.option-zh {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 4rpx;
  line-height: 1.5;
}

.option-ja {
  display: block;
  font-size: 24rpx;
  color: var(--text-hint);
  line-height: 1.5;
}

/* ===== 答题反馈 ===== */
.feedback-section {
  padding: 10rpx 0;
}

.feedback-result {
  display: flex;
  align-items: center;
  margin: 0 30rpx 16rpx;
  padding: 20rpx 24rpx;
  border-radius: 14rpx;
  position: relative;
  overflow: hidden;
}

.feedback-correct {
  background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
  border-left: 6rpx solid #22c55e;
}

.feedback-wrong {
  background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%);
  border-left: 6rpx solid #ef4444;
}

.feedback-icon {
  font-size: 36rpx;
  font-weight: 700;
  margin-right: 16rpx;
}

.feedback-correct .feedback-icon {
  color: #22c55e;
}

.feedback-wrong .feedback-icon {
  color: #ef4444;
}

.feedback-text {
  font-size: 28rpx;
  font-weight: 500;
}

.feedback-text-wrap {
  flex: 1;
  min-width: 0;
}

.feedback-tip {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--text-hint);
  line-height: 1.4;
}

.feedback-correct .feedback-text {
  color: #15803d;
}

.feedback-wrong .feedback-text {
  color: #b91c1c;
}

.feedback-correct .feedback-tip {
  color: #166534;
}

/* ===== 解释卡片 ===== */
.explanation-card {
  background: linear-gradient(170deg, #ffffff 0%, #f8fafc 100%);
  border-radius: 20rpx;
  margin: 0 30rpx 20rpx;
  padding: 28rpx 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  position: relative;
  overflow: hidden;
}

.explanation-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  bottom: 0;
  width: 6rpx;
  background: linear-gradient(180deg, #60a5fa, #a78bfa);
}

.explanation-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-itpass, #4a90d9);
  margin-bottom: 8rpx;
  margin-top: 16rpx;
}

.explanation-title:first-child {
  margin-top: 0;
}

.explanation-body + .explanation-title {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid rgba(74, 144, 217, 0.1);
}

.explanation-body {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-top: 4rpx;
}

.explanation-warning {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  padding: 12rpx 16rpx;
  background-color: rgba(245, 158, 11, 0.08);
  border-radius: 10rpx;
  border-left: 4rpx solid #f59e0b;
}

/* ===== 下一题按钮 ===== */
.next-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #4a90d9 0%, #6366f1 100%);
  border-radius: 44rpx;
  margin: 20rpx 60rpx;
  padding: 26rpx;
  box-shadow: 0 6rpx 24rpx rgba(74, 144, 217, 0.35);
  transition: all 0.2s ease;
}

.next-btn:active {
  transform: translateY(2rpx) scale(0.97);
  box-shadow: 0 3rpx 12rpx rgba(74, 144, 217, 0.25);
}

.next-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 2rpx;
}

/* ===== 完成页面 ===== */
.finish-card {
  background: linear-gradient(170deg, #ffffff 0%, #f6f8fc 50%, #eef2fa 100%);
  border-radius: 20rpx;
  margin: 60rpx 30rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  overflow: hidden;
}

.finish-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #4a90d9, #6366f1);
}

.finish-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.finish-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 40rpx;
}

.finish-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  width: 100%;
  margin-bottom: 40rpx;
}

.finish-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.finish-stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.finish-correct {
  color: #22c55e;
}

.finish-wrong {
  color: #ef4444;
}

.finish-stat-label {
  font-size: 24rpx;
  color: var(--text-hint);
}

.finish-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #4a90d9 0%, #6366f1 100%);
  border-radius: 44rpx;
  padding: 26rpx 80rpx;
  box-shadow: 0 6rpx 24rpx rgba(74, 144, 217, 0.35);
}

.finish-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 2rpx;
}

/* ===== 本次练习结果 ===== */
.result-card {
  box-sizing: border-box;
  background: linear-gradient(170deg, #1a2a4a 0%, #1e3560 100%);
  border-radius: 24rpx;
  margin: 32rpx 24rpx;
  padding: 48rpx 32rpx 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
  text-align: center;
  overflow: hidden;
  position: relative;
}

.result-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #60a5fa, #a78bfa, #f472b6);
}

.result-kicker {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
}

.result-mode {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.5;
}

.result-timer {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  margin-bottom: 12rpx;
  background-color: rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
}

.result-timer-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.result-timer-text {
  font-size: 30rpx;
  color: #fbbf24;
  font-weight: 600;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.accuracy-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 34rpx auto 28rpx;
}

.accuracy-value {
  font-size: 80rpx;
  line-height: 1.1;
  font-weight: 800;
  background: linear-gradient(135deg, #60a5fa 0%, #a78bfa 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.accuracy-good .accuracy-value {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
}

.accuracy-moderate .accuracy-value {
  background: linear-gradient(135deg, #60a5fa 0%, #6366f1 100%);
}

.accuracy-low .accuracy-value {
  background: linear-gradient(135deg, #f97316 0%, #ef4444 100%);
}

.accuracy-label {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.result-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  width: 100%;
  padding: 20rpx 0;
  margin-top: 8rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.result-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.result-stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
}

.result-correct {
  color: #4ade80;
}

.result-wrong {
  color: #f87171;
}

.result-stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
  line-height: 1.4;
}

/* ===== 学习洞察块 ===== */
.insight-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 20rpx 0 8rpx;
  padding: 20rpx 24rpx;
  border-radius: 14rpx;
}

.insight-good {
  background-color: rgba(34, 197, 94, 0.12);
  border: 1rpx solid rgba(34, 197, 94, 0.2);
}

.insight-moderate {
  background-color: rgba(96, 165, 250, 0.12);
  border: 1rpx solid rgba(96, 165, 250, 0.2);
}

.insight-low {
  background-color: rgba(245, 158, 11, 0.12);
  border: 1rpx solid rgba(245, 158, 11, 0.2);
}

.insight-none {
  background-color: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.insight-header {
  display: flex;
  align-items: center;
}

.insight-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.insight-label {
  font-size: 30rpx;
  font-weight: 700;
}

.insight-good .insight-label {
  color: #4ade80;
}

.insight-moderate .insight-label {
  color: #60a5fa;
}

.insight-low .insight-label {
  color: #fbbf24;
}

.insight-none .insight-label {
  color: rgba(255, 255, 255, 0.4);
}

.insight-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.45);
  line-height: 1.5;
  text-align: center;
}

/* ===== 结果操作按钮 ===== */
.result-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
}

.result-btn {
  box-sizing: border-box;
  width: 100%;
  padding: 22rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 44rpx;
  background-color: rgba(255, 255, 255, 0.06);
  transition: all 0.2s ease;
}

.result-btn:active {
  transform: scale(0.98);
  background-color: rgba(255, 255, 255, 0.1);
}

.result-btn-wrong {
  border-color: rgba(248, 113, 113, 0.3);
  background-color: rgba(248, 113, 113, 0.1);
}

.result-btn-primary {
  border-color: transparent;
  background: linear-gradient(135deg, #4a90d9 0%, #6366f1 100%);
  box-shadow: 0 4rpx 18rpx rgba(74, 144, 217, 0.3);
}

.result-btn-text {
  font-size: 29rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.7);
}

.result-btn-text-wrong {
  color: #f87171;
}

.result-btn-text-primary {
  color: #ffffff;
}

/* R3.50 重练错题按钮 */
.result-btn-retry {
  border-color: rgba(251, 191, 36, 0.3);
  background-color: rgba(251, 191, 36, 0.1);
}

.result-btn-text-retry {
  color: #fbbf24;
}

/* ===== 下一步建议卡片 ===== */
.next-action-card {
  display: flex;
  align-items: center;
  margin: 20rpx 0 8rpx;
  padding: 18rpx 22rpx;
  background-color: rgba(96, 165, 250, 0.1);
  border-radius: 12rpx;
  border-left: 6rpx solid #60a5fa;
}

.next-action-icon {
  font-size: 32rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.next-action-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
  line-height: 1.5;
  flex: 1;
}

/* ===== R3.43 答题回顾 ===== */
.review-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 24rpx 30rpx 0;
  padding: 20rpx;
  background-color: rgba(96, 165, 250, 0.1);
  border-radius: 14rpx;
  border: 1rpx solid rgba(96, 165, 250, 0.2);
  transition: all 0.2s ease;
}

.review-btn:active {
  background-color: rgba(96, 165, 250, 0.15);
}

.review-btn-text {
  font-size: 28rpx;
  color: #60a5fa;
  font-weight: 500;
}

.review-section {
  margin: 20rpx 30rpx;
  background-color: var(--card-bg);
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  position: relative;
  overflow: hidden;
}

.review-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #60a5fa, #a78bfa);
}

.review-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--divider-color);
}

.review-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.review-close {
  font-size: 36rpx;
  color: var(--text-hint);
  padding: 8rpx;
}

.review-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.review-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 16rpx;
  border-bottom: 1rpx solid var(--bg-color);
  border-radius: 10rpx;
  margin-bottom: 8rpx;
}

.review-item:last-child {
  border-bottom: none;
}

.review-item-correct {
  background-color: rgba(34, 197, 94, 0.06);
}

.review-item-wrong {
  background-color: rgba(239, 68, 68, 0.06);
}

.review-item-index {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-right: 16rpx;
  flex-shrink: 0;
  width: 40rpx;
}

.review-item-content {
  flex: 1;
  min-width: 0;
}

.review-item-question {
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.5;
  margin-bottom: 8rpx;
  display: block;
}

.review-item-answer {
  display: flex;
  align-items: center;
  margin-top: 6rpx;
}

.review-item-label {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-right: 8rpx;
  flex-shrink: 0;
}

.review-item-selected {
  font-size: 24rpx;
  font-weight: 500;
}

.review-item-correct-answer {
  font-size: 24rpx;
  font-weight: 500;
}

.text-correct {
  color: #22c55e;
}

.text-wrong {
  color: #ef4444;
}

.review-item-status {
  font-size: 32rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* R3.46 分享按钮 */
.share-btn {
  background: transparent !important;
  border: none !important;
  padding: 0 !important;
  margin: 0 !important;
  line-height: normal !important;
  font-size: inherit !important;
}

.share-btn::after {
  border: none !important;
}

.share-btn-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* R3.48 错题解析 */
.review-item-hint {
  font-size: 22rpx;
  color: #fbbf24;
  line-height: 1.5;
  margin-top: 6rpx;
}

/* ===== 暗色模式微调 ===== */
@media (prefers-color-scheme: dark) {
  .container {
    background: linear-gradient(180deg, #0f1a2e 0%, #131d33 30%, #0d1117 55%);
  }

  .question-card {
    background: linear-gradient(170deg, #1e1e2e 0%, #1a1a2a 50%, #161626 100%);
    box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
  }

  .option-item {
    background: linear-gradient(170deg, #1e1e2e 0%, #1a1a2a 100%);
    border-color: rgba(255, 255, 255, 0.06);
  }

  .option-item:active {
    background: linear-gradient(170deg, #252535 0%, #202030 100%);
  }

  .option-correct {
    background: linear-gradient(170deg, #0a1f0f 0%, #0d2814 100%);
    border-color: #4ade80;
  }

  .option-wrong {
    background: linear-gradient(170deg, #1f0a0a 0%, #280d0d 100%);
    border-color: #f87171;
  }

  .option-answer {
    background: linear-gradient(170deg, #0a1f0f 0%, #0d2814 100%);
    border-color: #4ade80;
  }

  .option-key {
    background-color: rgba(255, 255, 255, 0.06);
    color: var(--text-secondary);
  }

  .option-correct .option-key {
    background-color: #4ade80;
    color: #0a1f0f;
  }

  .option-wrong .option-key {
    background-color: #f87171;
    color: #1f0a0a;
  }

  .option-answer .option-key {
    background-color: #4ade80;
    color: #0a1f0f;
  }

  .feedback-correct {
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.1) 0%, rgba(34, 197, 94, 0.05) 100%);
    border-left-color: #4ade80;
  }

  .feedback-wrong {
    background: linear-gradient(135deg, rgba(239, 68, 68, 0.1) 0%, rgba(239, 68, 68, 0.05) 100%);
    border-left-color: #f87171;
  }

  .explanation-card {
    background: linear-gradient(170deg, #1e1e2e 0%, #1a1a2a 100%);
    box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
  }

  .finish-card {
    background: linear-gradient(170deg, #1e1e2e 0%, #1a1a2a 50%, #161626 100%);
    box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
  }

  .result-card {
    background: linear-gradient(170deg, #0f1a2e 0%, #131d33 100%);
    box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
  }
}

/* ===== 亮色模式适配 ===== */
@media (prefers-color-scheme: light) {
  .container {
    background: linear-gradient(180deg, #1a2a4a 0%, #1e3560 30%, #f5f5f5 55%);
  }
}
