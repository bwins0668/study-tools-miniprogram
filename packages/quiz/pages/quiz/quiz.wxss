/* pages/quiz/quiz.wxss */

.container {
  padding: 20rpx 0 60rpx;
  min-height: 100vh;
}

/* 头部 */
.quiz-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 30rpx 20rpx;
}

.quiz-header-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.quiz-exam-badge {
  font-size: 22rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  letter-spacing: 1rpx;
}

.badge-it {
  color: #4a90d9;
  background-color: #e8f0fe;
}

.badge-sg {
  color: #e65100;
  background-color: #fff3e0;
}

.badge-wrong {
  color: #c62828;
  background-color: #ffebee;
}

.quiz-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* R3.62 答题计时器 */
.timer-section {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 8rpx 20rpx;
}

.timer-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.timer-text {
  font-size: 28rpx;
  color: #e8913a;
  font-weight: 600;
  font-family: monospace;
}

.result-timer {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  margin-bottom: 12rpx;
}

.result-timer-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.result-timer-text {
  font-size: 30rpx;
  color: #e8913a;
  font-weight: 600;
  font-family: monospace;
}

/* 进度条 + 百分比 */
.progress-row {
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  margin-bottom: 4rpx;
}

.progress-bar-wrap {
  height: 6rpx;
  background-color: var(--border-color);
  flex: 1;
  border-radius: 3rpx;
  overflow: hidden;
  margin-right: 16rpx;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #4a90d9, #63b3ed);
  border-radius: 3rpx;
  transition: width 0.3s ease;
}

.progress-percent {
  font-size: 22rpx;
  font-weight: 600;
  color: #4a90d9;
  flex-shrink: 0;
  min-width: 68rpx;
  text-align: right;
}

/* 实时会话统计 */
.session-stats {
  display: flex;
  align-items: center;
  padding: 10rpx 30rpx 6rpx;
  gap: 24rpx;
}

.session-stat-item {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.session-stat-correct {
  color: #2e7d32;
  font-weight: 600;
}

.session-stat-wrong {
  color: #c62828;
  font-weight: 600;
}

/* 题目内题号 */
.question-progress-row {
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid var(--divider-color);
}

.question-number {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 题目卡片 */
.question-card {
  background-color: var(--card-bg);
  border-radius: 16rpx;
  margin: 0 30rpx 20rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.question-zh {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.question-ja {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.question-source {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--divider-color);
}

.source-badge {
  font-size: 22rpx;
  color: #4a90d9;
  background-color: #e8f0fe;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.source-badge-exam {
  color: #e65100;
  background-color: #fff3e0;
}

.source-title {
  font-size: 24rpx;
  color: var(--text-hint);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.translation-warning {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  padding: 10rpx 16rpx;
  background-color: #fff8e1;
  border-radius: 8rpx;
}

.warning-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
  color: #f59e0b;
}

.warning-text {
  font-size: 24rpx;
  color: #b45309;
}

/* R3.60 提示按钮 */
.hint-section {
  margin-top: 16rpx;
  padding: 0 32rpx;
}

.hint-btn {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background-color: #e8f0fe;
  border-radius: 8rpx;
}

.hint-btn-active {
  background-color: #dbeafe;
}

.hint-btn-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.hint-btn-text {
  font-size: 24rpx;
  color: #356a9f;
  font-weight: 500;
}

.hint-content {
  margin-top: 12rpx;
  padding: 16rpx;
  background-color: #f8f9fe;
  border-radius: 8rpx;
  border-left: 4rpx solid #4a90d9;
}

.hint-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 选项列表 */
.options-list {
  padding: 0 30rpx;
}

.option-item {
  display: flex;
  align-items: flex-start;
  background-color: var(--card-bg);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid transparent;
}

.option-item:active {
  background-color: var(--bg-color);
}

.option-correct {
  background-color: #e8f5e9;
  border-color: #4caf50;
}

.option-wrong {
  background-color: #fbe9e7;
  border-color: #f44336;
}

.option-answer {
  background-color: #e8f5e9;
  border-color: #4caf50;
}

.option-key {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: var(--divider-color);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-content {
  flex: 1;
}

.option-zh {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.option-ja {
  display: block;
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 答题反馈 */
.feedback-section {
  padding: 10rpx 0;
}

.feedback-result {
  display: flex;
  align-items: center;
  margin: 0 30rpx 16rpx;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
}

.feedback-correct {
  background-color: #e8f5e9;
}

.feedback-wrong {
  background-color: #fbe9e7;
}

.feedback-icon {
  font-size: 36rpx;
  font-weight: 700;
  margin-right: 16rpx;
}

.feedback-correct .feedback-icon {
  color: #4caf50;
}

.feedback-wrong .feedback-icon {
  color: #f44336;
}

.feedback-text {
  font-size: 28rpx;
  font-weight: 500;
}

.feedback-text-wrap {
  flex: 1;
  min-width: 0;
}

.feedback-tip {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--text-hint);
  line-height: 1.4;
}

.feedback-correct .feedback-text {
  color: #2e7d32;
}

.feedback-wrong .feedback-text {
  color: #c62828;
}

.feedback-correct .feedback-tip {
  color: #558b2f;
}

/* 解释卡片 */
.explanation-card {
  background-color: var(--card-bg);
  border-radius: 16rpx;
  margin: 0 30rpx 20rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.explanation-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #4a90d9;
  margin-bottom: 8rpx;
  margin-top: 16rpx;
}

.explanation-title:first-child {
  margin-top: 0;
}

.explanation-body {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

.explanation-warning {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  padding: 10rpx 16rpx;
  background-color: #fff8e1;
  border-radius: 8rpx;
}

/* 下一题按钮 */
.next-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #4a90d9;
  border-radius: 40rpx;
  margin: 20rpx 60rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
}

.next-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 完成页面 */
.finish-card {
  background-color: var(--card-bg);
  border-radius: 16rpx;
  margin: 60rpx 30rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.finish-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.finish-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 40rpx;
}

.finish-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  width: 100%;
  margin-bottom: 40rpx;
}

.finish-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.finish-stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.finish-correct {
  color: #4caf50;
}

.finish-wrong {
  color: #f44336;
}

.finish-stat-label {
  font-size: 24rpx;
  color: var(--text-hint);
}

.finish-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #4a90d9;
  border-radius: 40rpx;
  padding: 24rpx 80rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
}

.finish-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 本次练习结果 */
.result-card {
  box-sizing: border-box;
  background-color: var(--card-bg);
  border-radius: 20rpx;
  margin: 32rpx 30rpx;
  padding: 44rpx 30rpx 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  text-align: center;
  overflow: hidden;
}

.result-kicker {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.result-mode {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--text-hint);
  line-height: 1.5;
}

.accuracy-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 34rpx auto 28rpx;
}

.accuracy-value {
  font-size: 72rpx;
  line-height: 1.1;
  font-weight: 800;
  color: #4a90d9;
}

.accuracy-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.result-stats {
  display: flex;
  width: 100%;
  padding: 24rpx 0;
  border-top: 1rpx solid var(--border-color);
  border-bottom: 1rpx solid var(--border-color);
}

.result-stat {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.result-stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.result-correct {
  color: #2e7d32;
}

.result-wrong {
  color: #c62828;
}

.result-stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.4;
}

/* 学习洞察块 */
.insight-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 24rpx 0 8rpx;
  padding: 22rpx 24rpx;
  border-radius: 14rpx;
}

.insight-good {
  background-color: #e8f5e9;
}

.insight-moderate {
  background-color: #eef5fd;
}

.insight-low {
  background-color: #fff3e0;
}

.insight-none {
  background-color: var(--bg-color);
}

.insight-header {
  display: flex;
  align-items: center;
}

.insight-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.insight-label {
  font-size: 30rpx;
  font-weight: 700;
}

.insight-good .insight-label {
  color: #2e7d32;
}

.insight-moderate .insight-label {
  color: #356a9f;
}

.insight-low .insight-label {
  color: #e65100;
}

.insight-none .insight-label {
  color: var(--text-hint);
}

.insight-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  text-align: center;
}

.result-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
}

.result-btn {
  box-sizing: border-box;
  width: 100%;
  padding: 22rpx 24rpx;
  border: 2rpx solid #d9e3ee;
  border-radius: 40rpx;
  background-color: var(--card-bg);
}

.result-btn-wrong {
  border-color: #c62828;
  background-color: #fff5f5;
}

.result-btn-primary {
  border-color: #4a90d9;
  background-color: #4a90d9;
  box-shadow: 0 4rpx 14rpx rgba(74, 144, 217, 0.25);
}

.result-btn-text {
  font-size: 29rpx;
  font-weight: 600;
  color: #4a6b8a;
}

.result-btn-text-wrong {
  color: #c62828;
}

.result-btn-text-primary {
  color: #ffffff;
}

/* R3.50 重练错题按钮 */
.result-btn-retry {
  border-color: #ff9800;
  background-color: #fff3e0;
}

.result-btn-text-retry {
  color: #e65100;
}

/* 下一步建议卡片 */
.next-action-card {
  display: flex;
  align-items: center;
  margin: 20rpx 0 8rpx;
  padding: 18rpx 22rpx;
  background-color: #f0f7ff;
  border-radius: 12rpx;
  border-left: 6rpx solid #4a90d9;
}

.next-action-icon {
  font-size: 32rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.next-action-text {
  font-size: 26rpx;
  color: #356a9f;
  font-weight: 500;
  line-height: 1.5;
  flex: 1;
}

/* R3.43 答题回顾 */
.review-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 24rpx 30rpx 0;
  padding: 20rpx;
  background-color: #f0f7ff;
  border-radius: 12rpx;
  border: 1rpx solid #cce0ff;
}

.review-btn-text {
  font-size: 28rpx;
  color: #4a90d9;
  font-weight: 500;
}

.review-section {
  margin: 20rpx 30rpx;
  background-color: var(--card-bg);
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.review-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--divider-color);
}

.review-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.review-close {
  font-size: 36rpx;
  color: var(--text-hint);
  padding: 8rpx;
}

.review-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.review-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 16rpx;
  border-bottom: 1rpx solid var(--bg-color);
}

.review-item:last-child {
  border-bottom: none;
}

.review-item-correct {
  background-color: #f0fff0;
}

.review-item-wrong {
  background-color: #fff0f0;
}

.review-item-index {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-right: 16rpx;
  flex-shrink: 0;
  width: 40rpx;
}

.review-item-content {
  flex: 1;
  min-width: 0;
}

.review-item-question {
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.5;
  margin-bottom: 8rpx;
  display: block;
}

.review-item-answer {
  display: flex;
  align-items: center;
  margin-top: 6rpx;
}

.review-item-label {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-right: 8rpx;
  flex-shrink: 0;
}

.review-item-selected {
  font-size: 24rpx;
  font-weight: 500;
}

.review-item-correct-answer {
  font-size: 24rpx;
  font-weight: 500;
}

.text-correct {
  color: #4caf50;
}

.text-wrong {
  color: #f44336;
}

.review-item-status {
  font-size: 32rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* R3.46 分享按钮 */
.share-btn {
  background: transparent !important;
  border: none !important;
  padding: 0 !important;
  margin: 0 !important;
  line-height: normal !important;
  font-size: inherit !important;
}

.share-btn::after {
  border: none !important;
}

.share-btn-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* R3.48 错题解析 */
.review-item-hint {
  font-size: 22rpx;
  color: #ff9800;
  line-height: 1.5;
  margin-top: 6rpx;
}
