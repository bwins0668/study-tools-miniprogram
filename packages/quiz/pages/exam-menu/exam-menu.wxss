/* pages/exam-menu/exam-menu.wxss */

.container {
  padding: 0 0 60rpx;
  min-height: 100vh;
  background-color: var(--bg-color);
}

/* === Dashboard 头部 === */
.exam-dashboard {
  padding: 32rpx 30rpx 0;
  background: linear-gradient(135deg, rgba(74,144,217,0.08) 0%, rgba(54,209,220,0.06) 100%);
  border-bottom: 1rpx solid rgba(74,144,217,0.08);
}

.dashboard-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.dashboard-title-group {
  flex: 1;
}

.dashboard-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-primary);
  letter-spacing: 1rpx;
  margin-bottom: 6rpx;
}

.dashboard-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.dashboard-badge {
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  letter-spacing: 1rpx;
  flex-shrink: 0;
  margin-top: 8rpx;
}

.dashboard-badge-itpass {
  background-color: rgba(74,144,217,0.12);
  color: #4a90d9;
}

.dashboard-badge-sg {
  background-color: rgba(156,39,176,0.12);
  color: #9c27b0;
}

/* === 概览卡片 (Round 3.22) === */
.overview-card {
  margin: 0 0 16rpx;
  padding: 20rpx 28rpx 16rpx;
  background-color: var(--card-bg);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.overview-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 4rpx 0 16rpx;
}

.overview-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.overview-stat-value {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.overview-accuracy {
  color: #4a90d9;
}

.overview-time-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

.overview-stat-label {
  font-size: 20rpx;
  color: var(--text-hint);
  font-weight: 500;
}

.overview-divider {
  width: 1rpx;
  height: 40rpx;
  background-color: var(--divider-color);
}

/* === 学习建议 (Round 3.22) === */
.overview-suggestion {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  border-radius: 10rpx;
  margin-top: 4rpx;
}

.suggestion-good {
  background-color: #e8f5e9;
  border-left: 5rpx solid #4caf50;
}

.suggestion-moderate {
  background-color: #e3f2fd;
  border-left: 5rpx solid #4a90d9;
}

.suggestion-review {
  background-color: #fff3e0;
  border-left: 5rpx solid #ff9800;
}

.suggestion-start {
  background-color: #f3e5f5;
  border-left: 5rpx solid #9c27b0;
}

.suggestion-icon {
  font-size: 26rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.suggestion-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  flex: 1;
}

/* === 新用户卡片 (Round 3.22) === */
.new-user-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 32rpx;
  text-align: center;
  margin: 0 30rpx 16rpx;
}

.new-user-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.new-user-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.new-user-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* === 练习入口列表 === */
.menu-list {
  padding: 8rpx 0 0;
}

.menu-card {
  margin: 16rpx 30rpx;
  padding: 0;
  border-radius: 20rpx;
  background-color: var(--card-bg);
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  overflow: hidden;
  transition: transform 0.15s, box-shadow 0.15s;
}

.menu-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.menu-card-header {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx 16rpx;
}

.menu-card-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.menu-card-icon-lesson {
  background: linear-gradient(135deg, rgba(74,144,217,0.12), rgba(54,209,220,0.1));
}

.menu-card-icon-exam {
  background: linear-gradient(135deg, rgba(255,152,0,0.12), rgba(255,193,7,0.1));
}

.menu-card-icon {
  font-size: 36rpx;
}

.menu-card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.menu-card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.menu-card-desc {
  font-size: 22rpx;
  color: var(--text-hint);
  line-height: 1.4;
}

.menu-card-arrow {
  font-size: 36rpx;
  color: var(--text-hint);
  margin-left: 12rpx;
  flex-shrink: 0;
  font-weight: 300;
}

.menu-card-footer {
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding: 0 28rpx 20rpx 120rpx;
}

.menu-card-stat {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.menu-card-stat-value {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.menu-card-stat-accent {
  color: #4a90d9;
}

.menu-card-stat-label {
  font-size: 20rpx;
  color: var(--text-hint);
}
