/* pages/exam-menu/exam-menu.wxss */
/* Round 3.147: IT Passport / SG Dashboard 深化 */

.container {
  padding: 0 0 60rpx;
  min-height: 100vh;
  background-color: var(--bg-color);
}

/* === Dashboard 头部：沉浸式主题色 === */
.exam-dashboard {
  padding: 0 30rpx 28rpx;
  position: relative;
  overflow: hidden;
}

.exam-dashboard::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
}

.exam-itpass .exam-dashboard::before {
  background: linear-gradient(145deg, #0f2640 0%, #1a3f6e 30%, #1e5a8a 60%, #1a3f6e 85%, transparent 100%);
}

.exam-sg .exam-dashboard::before {
  background: linear-gradient(145deg, #2a0f3e 0%, #3d1a5e 30%, #522080 60%, #3d1a5e 85%, transparent 100%);
}

/* 微妙纹理叠加 */
.exam-dashboard::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  background-image: radial-gradient(rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 20rpx 20rpx;
  pointer-events: none;
}

.dashboard-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-top: 28rpx;
  position: relative;
  z-index: 1;
}

.dashboard-title-group {
  flex: 1;
}

.dashboard-title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.3);
}

.dashboard-subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  font-weight: 500;
}

.dashboard-badge {
  font-size: 18rpx;
  font-weight: 700;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  letter-spacing: 2rpx;
  flex-shrink: 0;
  margin-top: 8rpx;
  backdrop-filter: blur(10px);
}

.dashboard-badge-itpass {
  background-color: rgba(96, 165, 250, 0.2);
  color: rgba(147, 197, 253, 0.95);
  border: 1rpx solid rgba(96, 165, 250, 0.3);
}

.dashboard-badge-sg {
  background-color: rgba(206, 147, 216, 0.2);
  color: rgba(225, 190, 231, 0.95);
  border: 1rpx solid rgba(206, 147, 216, 0.3);
}

/* === 概览卡片：毛玻璃增强 === */
.overview-card {
  margin: 0 0 16rpx;
  padding: 24rpx 28rpx 20rpx;
  background-color: rgba(255,255,255,0.06);
  border-radius: 18rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
  position: relative;
  z-index: 1;
  backdrop-filter: blur(20px);
}

.overview-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 8rpx 0 16rpx;
}

.overview-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.overview-stat-value {
  font-size: 36rpx;
  font-weight: 800;
  color: #ffffff;
  margin-bottom: 4rpx;
}

.overview-accuracy {
  background: linear-gradient(135deg, #69db7c, #4ade80);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.overview-time-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  font-weight: 600;
}

.overview-stat-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.4);
  font-weight: 500;
}

.overview-divider {
  width: 1rpx;
  height: 44rpx;
  background-color: rgba(255,255,255,0.1);
}

/* === 学习建议 === */
.overview-suggestion {
  display: flex;
  align-items: center;
  padding: 14rpx 20rpx;
  border-radius: 12rpx;
  margin-top: 10rpx;
}

.suggestion-good {
  background-color: rgba(76,175,80,0.12);
  border-left: 5rpx solid #69db7c;
}

.suggestion-moderate {
  background-color: rgba(74,144,217,0.12);
  border-left: 5rpx solid #58a6ff;
}

.suggestion-review {
  background-color: rgba(255,152,0,0.12);
  border-left: 5rpx solid #ffb74d;
}

.suggestion-start {
  background-color: rgba(156,39,176,0.12);
  border-left: 5rpx solid #ce93d8;
}

.suggestion-icon {
  font-size: 26rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.suggestion-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.65);
  line-height: 1.5;
  flex: 1;
}

/* === 新用户卡片 === */
.new-user-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 32rpx;
  text-align: center;
  margin: 0 30rpx 16rpx;
  background-color: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 18rpx;
  backdrop-filter: blur(20px);
}

.new-user-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.new-user-title {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.8);
  margin-bottom: 6rpx;
}

.new-user-desc {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  line-height: 1.5;
}

/* === 练习入口列表：顶部色条 + 进度条 === */
.menu-list {
  padding: 8rpx 0 0;
}

.menu-card {
  margin: 16rpx 30rpx;
  padding: 0;
  border-radius: 20rpx;
  background: linear-gradient(170deg, var(--card-bg) 0%, rgba(255,255,255,0.98) 100%);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
  overflow: hidden;
  transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.2s ease;
  position: relative;
}

.menu-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

/* 菜单卡片顶部色条 */
.menu-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 5rpx;
  z-index: 2;
}

.exam-itpass .menu-card-lesson::before {
  background: linear-gradient(90deg, #4a90d9, #60a5fa);
}

.exam-itpass .menu-card-exam::before {
  background: linear-gradient(90deg, #f59e0b, #fbbf24);
}

.exam-sg .menu-card-lesson::before {
  background: linear-gradient(90deg, #9c27b0, #ce93d8);
}

.exam-sg .menu-card-exam::before {
  background: linear-gradient(90deg, #ef4444, #f87171);
}

.menu-card-header {
  display: flex;
  align-items: center;
  padding: 30rpx 28rpx 14rpx;
}

.menu-card-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.exam-itpass .menu-card-icon-lesson {
  background: linear-gradient(135deg, rgba(74,144,217,0.12), rgba(96,165,250,0.08));
  box-shadow: 0 2rpx 8rpx rgba(74,144,217,0.1);
}

.exam-itpass .menu-card-icon-exam {
  background: linear-gradient(135deg, rgba(245,158,11,0.12), rgba(251,191,36,0.08));
  box-shadow: 0 2rpx 8rpx rgba(245,158,11,0.1);
}

.exam-sg .menu-card-icon-lesson {
  background: linear-gradient(135deg, rgba(156,39,176,0.12), rgba(206,147,216,0.08));
  box-shadow: 0 2rpx 8rpx rgba(156,39,176,0.1);
}

.exam-sg .menu-card-icon-exam {
  background: linear-gradient(135deg, rgba(239,68,68,0.12), rgba(248,113,113,0.08));
  box-shadow: 0 2rpx 8rpx rgba(239,68,68,0.1);
}

.menu-card-icon {
  font-size: 36rpx;
}

.menu-card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.menu-card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.menu-card-desc {
  font-size: 22rpx;
  color: var(--text-hint);
  line-height: 1.4;
}

.menu-card-arrow {
  font-size: 40rpx;
  color: var(--text-hint);
  margin-left: 12rpx;
  flex-shrink: 0;
  font-weight: 300;
  opacity: 0.5;
}

/* 菜单卡片底部统计 + 进度条 */
.menu-card-footer {
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding: 0 28rpx 24rpx 120rpx;
}

.menu-card-stat {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.menu-card-stat-value {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.exam-itpass .menu-card-stat-accent {
  color: var(--color-itpass, #4a90d9);
}

.exam-sg .menu-card-stat-accent {
  color: var(--color-sg, #9c27b0);
}

.menu-card-stat-label {
  font-size: 20rpx;
  color: var(--text-hint);
}

/* 进度条 (在 footer 下方) */
.menu-card-progress {
  height: 4rpx;
  background-color: var(--divider-color);
  position: relative;
  overflow: hidden;
}

.menu-card-progress-bar {
  height: 100%;
  border-radius: 2rpx;
  transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.exam-itpass .menu-card-lesson .menu-card-progress-bar {
  background: linear-gradient(90deg, #4a90d9, #60a5fa);
}

.exam-itpass .menu-card-exam .menu-card-progress-bar {
  background: linear-gradient(90deg, #f59e0b, #fbbf24);
}

.exam-sg .menu-card-lesson .menu-card-progress-bar {
  background: linear-gradient(90deg, #9c27b0, #ce93d8);
}

.exam-sg .menu-card-exam .menu-card-progress-bar {
  background: linear-gradient(90deg, #ef4444, #f87171);
}

/* === 浅色模式适配 === */
@media (prefers-color-scheme: light) {
  .dashboard-title {
    color: var(--text-primary);
  }
  .dashboard-subtitle {
    color: var(--text-secondary);
  }
  .dashboard-badge-itpass,
  .dashboard-badge-sg {
    background-color: rgba(0,0,0,0.04);
    color: var(--text-secondary);
    border-color: rgba(0,0,0,0.06);
    backdrop-filter: none;
  }
  .overview-card {
    background-color: var(--card-bg);
    border-color: rgba(0,0,0,0.04);
    backdrop-filter: none;
  }
  .overview-stat-value {
    color: var(--text-primary);
  }
  .overview-accuracy {
    background: none;
    color: #22c55e;
    -webkit-background-clip: unset;
    background-clip: unset;
  }
  .overview-time-text {
    color: var(--text-secondary);
  }
  .overview-stat-label {
    color: var(--text-hint);
  }
  .overview-divider {
    background-color: var(--divider-color);
  }
  .suggestion-good {
    background-color: #e8f5e9;
    border-left-color: #4caf50;
  }
  .suggestion-moderate {
    background-color: #e3f2fd;
    border-left-color: #4a90d9;
  }
  .suggestion-review {
    background-color: #fff3e0;
    border-left-color: #ff9800;
  }
  .suggestion-start {
    background-color: #f3e5f5;
    border-left-color: #9c27b0;
  }
  .suggestion-text {
    color: var(--text-secondary);
  }
  .new-user-title {
    color: var(--text-primary);
  }
  .new-user-desc {
    color: var(--text-secondary);
  }
  .new-user-card {
    background-color: var(--card-bg);
    border-color: rgba(0,0,0,0.04);
    backdrop-filter: none;
  }
  .exam-itpass .exam-dashboard::before {
    background: linear-gradient(145deg, rgba(74,144,217,0.06) 0%, rgba(54,209,220,0.04) 100%);
  }
  .exam-sg .exam-dashboard::before {
    background: linear-gradient(145deg, rgba(156,39,176,0.06) 0%, rgba(233,30,99,0.04) 100%);
  }
}

/* === 暗色模式微调 === */
@media (prefers-color-scheme: dark) {
  .menu-card {
    background: linear-gradient(170deg, var(--card-bg) 0%, rgba(30,30,46,0.98) 100%);
    box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.2);
    border-radius: 20rpx;
  }
}

/* === 过去问年份入口 === */
.past-exam-year-section {
  border-top: 1rpx solid var(--divider-color);
  padding: 18rpx 28rpx 22rpx;
}
.past-exam-year-title {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-bottom: 14rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}
.past-exam-year-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.past-exam-year-chip {
  display: inline-flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  min-height: 62rpx;
  padding: 12rpx 16rpx 12rpx 20rpx;
  border-radius: 18rpx;
  box-sizing: border-box;
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.08), rgba(74, 144, 217, 0.035));
  color: var(--text-primary);
  border: 1rpx solid rgba(245, 158, 11, 0.14);
  box-shadow: 0 2rpx 10rpx rgba(15, 23, 42, 0.04);
  transition: transform 0.12s ease, box-shadow 0.12s ease;
}
.past-exam-year-chip:active {
  transform: scale(0.97);
  box-shadow: 0 1rpx 6rpx rgba(15, 23, 42, 0.08);
}
.past-exam-year-chip--active {
  background: linear-gradient(135deg, #4a90d9, #60a5fa);
  color: #ffffff;
  border-color: transparent;
  box-shadow: 0 4rpx 14rpx rgba(74, 144, 217, 0.22);
}
.past-exam-year-text {
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.25;
}
.past-exam-year-count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 56rpx;
  height: 34rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background-color: rgba(245, 158, 11, 0.12);
  font-size: 21rpx;
  color: #b45309;
  font-weight: 700;
  line-height: 34rpx;
}
.past-exam-year-chip--active .past-exam-year-count {
  color: #ffffff;
  background-color: rgba(255,255,255,0.18);
}

@media (prefers-color-scheme: dark) {
  .past-exam-year-chip {
    background: linear-gradient(135deg, rgba(251, 191, 36, 0.09), rgba(88, 166, 255, 0.045));
    border-color: rgba(251, 191, 36, 0.15);
    box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.2);
  }

  .past-exam-year-count {
    background-color: rgba(251, 191, 36, 0.14);
    color: #fbbf24;
  }
}
