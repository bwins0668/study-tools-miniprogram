<!--pages/exam-menu/exam-menu.wxml-->
<view class="container exam-{{exam}}">
  <!-- 考试 Dashboard 头部 -->
  <view class="exam-dashboard">
    <view class="dashboard-header">
      <view class="dashboard-title-group">
        <text class="dashboard-title">{{examTitle}}</text>
        <text class="dashboard-subtitle">{{examDesc}}</text>
      </view>
      <view class="dashboard-badge dashboard-badge-{{exam}}">ACTIVE</view>
    </view>
    <!-- 指标概览卡 -->
    <view class="overview-card card" wx:if="{{overallTotal > 0}}">
      <view class="overview-stats">
        <view class="overview-stat">
          <text class="overview-stat-value">{{overallTotal}}</text>
          <text class="overview-stat-label">累计答题</text>
        </view>
        <view class="overview-divider"></view>
        <view class="overview-stat">
          <text class="overview-stat-value overview-accuracy">{{overallAccuracy}}%</text>
          <text class="overview-stat-label">综合正确率</text>
        </view>
        <view class="overview-divider"></view>
        <view class="overview-stat">
          <text class="overview-stat-value overview-time-text">{{lastPracticeText || '暂无'}}</text>
          <text class="overview-stat-label">最近练习</text>
        </view>
      </view>
      <!-- 学习建议 -->
      <view class="overview-suggestion suggestion-{{suggestion.level}}" wx:if="{{suggestion.text}}">
        <text class="suggestion-icon">{{suggestion.level === 'good' ? '✅' : (suggestion.level === 'start' ? '📚' : (suggestion.level === 'moderate' ? '📖' : '🎯'))}}</text>
        <text class="suggestion-text">{{suggestion.text}}</text>
      </view>
    </view>
  </view>

  <!-- 新用户引导 (Round 3.22) -->
  <view class="overview-card card new-user-card" wx:if="{{overallTotal === 0}}">
    <text class="new-user-icon">📝</text>
    <text class="new-user-title">还没有练习记录</text>
    <text class="new-user-desc">选择下方练习方式开始学习，建议先从课程练习入手</text>
  </view>

  <!-- 练习入口 -->
  <view class="menu-list">
    <!-- 课程练习 -->
    <view class="menu-card menu-card-lesson" bindtap="goLessonQuiz">
      <view class="menu-card-header">
        <view class="menu-card-icon-wrap menu-card-icon-lesson">
          <text class="menu-card-icon">📚</text>
        </view>
        <view class="menu-card-body">
          <text class="menu-card-title">课程练习</text>
          <text class="menu-card-desc">双语课程练习题，含中文翻译</text>
        </view>
        <text class="menu-card-arrow">›</text>
      </view>
      <view class="menu-card-footer">
        <view class="menu-card-stat">
          <text class="menu-card-stat-value">{{lessonTotal}}</text>
          <text class="menu-card-stat-label">已做题</text>
        </view>
        <view class="menu-card-stat">
          <text class="menu-card-stat-value menu-card-stat-accent">{{lessonAccuracy}}%</text>
          <text class="menu-card-stat-label">正确率</text>
        </view>
      </view>
      <view class="menu-card-progress">
        <view class="menu-card-progress-bar" style="width: {{lessonAccuracy}}%"></view>
      </view>
    </view>

    <!-- 日文真题 -->
    <view class="menu-card menu-card-exam" bindtap="togglePastExamList">
      <view class="menu-card-header">
        <view class="menu-card-icon-wrap menu-card-icon-exam">
          <text class="menu-card-icon">📝</text>
        </view>
        <view class="menu-card-body">
          <text class="menu-card-title">日文真题</text>
          <text class="menu-card-desc">按考试年度 / 回数选择</text>
        </view>
        <text class="menu-card-arrow">{{pastExamExpanded ? '▲' : '▼'}}</text>
      </view>
      <view class="menu-card-footer">
        <view class="menu-card-stat">
          <text class="menu-card-stat-value">{{pastTotal}}</text>
          <text class="menu-card-stat-label">已做题</text>
        </view>
        <view class="menu-card-stat">
          <text class="menu-card-stat-value menu-card-stat-accent">{{pastAccuracy}}%</text>
          <text class="menu-card-stat-label">正确率</text>
        </view>
      </view>
      <view class="menu-card-progress">
        <view class="menu-card-progress-bar" style="width: {{pastAccuracy}}%"></view>
      </view>

      <!-- 年份展开区 -->
      <view class="past-exam-year-section" wx:if="{{pastExamExpanded && pastExamList.length > 0}}">
        <view class="past-exam-year-title">选择考试年度</view>
        <view class="past-exam-year-list">
          <view
            class="past-exam-year-chip {{activePastExamYearId === item.yearId ? 'past-exam-year-chip--active' : ''}}"
            wx:for="{{pastExamList}}"
            wx:key="yearId"
            data-yearId="{{item.yearId}}"
            bindtap="goPastExamYear"
          >
            <text class="past-exam-year-text">{{item.year}}</text>
            <text class="past-exam-year-count">{{item.count}}题</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
