/* pages/mistakes/mistakes.wxss */

.container {
  padding: 20rpx 0 60rpx;
  min-height: 100vh;
}

.page-header {
  text-align: center;
  padding: 50rpx 30rpx 30rpx;
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.page-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-hint);
}

/* 统计 */
.stats-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin: 20rpx 30rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #4a90d9;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 分组统计 */
.group-stats {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 12rpx 32rpx 0;
  flex-wrap: wrap;
}

.group-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.group-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.group-dot-it {
  background-color: #4a90d9;
}

.group-dot-sg {
  background-color: #e65100;
}

.group-dot-ja {
  background-color: #9c27b0;
}

.group-label {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.group-count {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* 搜索框 */
.search-section {
  padding: 8rpx 30rpx 0;
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: var(--bg-color);
  border-radius: 36rpx;
  padding: 16rpx 28rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  background: transparent;
  line-height: 1.4;
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.search-clear-text {
  font-size: 28rpx;
  color: var(--text-hint);
}

/* 筛选标签 */
.filter-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 30rpx;
  overflow-x: auto;
}

.filter-tag {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 28rpx;
  border-radius: 28rpx;
  background-color: var(--divider-color);
  flex-shrink: 0;
}

.filter-tag-active {
  background-color: #4a90d9;
}

.filter-tag-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.filter-tag-active .filter-tag-text {
  color: #ffffff;
  font-weight: 600;
}

/* 操作行：模式切换 + 重练入口 */
.section-action {
  padding: 8rpx 30rpx 16rpx;
}

.action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.mode-switch {
  display: flex;
  align-items: center;
  background-color: var(--divider-color);
  border-radius: 32rpx;
  padding: 6rpx;
  flex-shrink: 0;
}

.mode-tab {
  padding: 14rpx 28rpx;
  border-radius: 28rpx;
}

.mode-tab-active {
  background-color: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.mode-tab-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.mode-tab-active .mode-tab-text {
  color: #4a90d9;
  font-weight: 600;
}

/* 错题重练入口 */
.practice-wrong-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #e8913a;
  border-radius: 40rpx;
  padding: 24rpx 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(232, 145, 58, 0.3);
  flex: 1;
}

.practice-wrong-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 错题列表 */
.wrong-list {
  padding: 10rpx 0;
}

.wrong-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin: 16rpx 30rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.wrong-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.wrong-exam {
  font-size: 22rpx;
  color: #4a90d9;
  background-color: #eef4fc;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.wrong-tags {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.wrong-source {
  font-size: 20rpx;
  color: var(--text-secondary);
  background-color: var(--divider-color);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.wrong-source-exam {
  color: #e65100;
  background-color: #fff3e0;
}

.wrong-time {
  font-size: 22rpx;
  color: var(--text-hint);
}

.wrong-question-zh {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.wrong-question-ja {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.translation-warning {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  padding: 8rpx 16rpx;
  background-color: #fff8e1;
  border-radius: 8rpx;
}

.warning-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
  color: #f59e0b;
}

.warning-text {
  font-size: 22rpx;
  color: #b45309;
}

.wrong-detail-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.wrong-detail-label {
  font-size: 24rpx;
  color: var(--text-hint);
  flex-shrink: 0;
}

.wrong-detail-value {
  font-size: 26rpx;
  font-weight: 500;
}

.wrong-correct {
  color: #4caf50;
}

.wrong-incorrect {
  color: #f44336;
}

.wrong-explanation {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--divider-color);
}

.wrong-exp-text {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 8rpx;
}

.wrong-exp-ja {
  color: var(--text-secondary);
}

.explanation-warning {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  padding: 8rpx 16rpx;
  background-color: #fff8e1;
  border-radius: 8rpx;
}

/* 单条操作 */
.wrong-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--divider-color);
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 28rpx;
  border-radius: 24rpx;
  border: 1rpx solid var(--border-color);
}

.action-remove {
  border-color: #f44336;
}

.action-btn-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.action-remove .action-btn-text {
  color: #f44336;
}

/* 复习模式 */
.review-section {
  padding: 0 30rpx;
}

.review-progress {
  text-align: center;
  padding: 16rpx 0;
}

.review-index {
  font-size: 28rpx;
  color: var(--text-hint);
  font-weight: 500;
}

.review-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 20rpx;
}

.explanation-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  margin-top: 12rpx;
  border-top: 1rpx solid var(--divider-color);
}

.toggle-label {
  font-size: 26rpx;
  color: #4a90d9;
  margin-right: 8rpx;
}

.toggle-arrow {
  font-size: 20rpx;
  color: #4a90d9;
}

.review-nodata-hint {
  margin-top: 12rpx;
  padding: 20rpx 0;
  text-align: center;
  border-top: 1rpx solid var(--divider-color);
}

.nodata-text {
  font-size: 24rpx;
  color: var(--text-hint);
}

.review-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--divider-color);
}

.review-nav-left {
  display: flex;
  gap: 16rpx;
}

.action-nav {
  border-color: #4a90d9;
}

.action-nav .action-btn-text {
  color: #4a90d9;
}

.action-btn-disabled {
  border-color: var(--border-color);
  opacity: 0.4;
}

.action-btn-disabled .action-btn-text {
  color: var(--text-hint);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 60rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--text-hint);
  text-align: center;
  margin-bottom: 32rpx;
}

.empty-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.go-study-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #4a90d9;
  border-radius: 40rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
  width: calc(100% - 120rpx);
}

.go-study-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}
