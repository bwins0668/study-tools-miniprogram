<!--pages/mistakes/mistakes.wxml-->
<view class="container">
  <!-- 标题 -->
  <view class="page-header">
    <text class="page-title">错题本</text>
    <text class="page-desc">做题后，答错的题目会自动进入这里</text>
  </view>

  <!-- 统计 -->
  <view class="stats-card">
    <view class="stats-row">
      <view class="stats-item">
        <text class="stats-value">{{totalCount}}</text>
        <text class="stats-label">全部错题</text>
      </view>
      <view class="stats-item">
        <text class="stats-value">{{reviewCount}}</text>
        <text class="stats-label">待复习</text>
      </view>
      <view class="stats-item">
        <text class="stats-value">{{masteredCount}}</text>
        <text class="stats-label">已掌握</text>
      </view>
    </view>
  </view>

  <!-- 筛选标签 -->
  <view class="filter-bar" wx:if="{{totalCount > 0}}">
    <view
      wx:for="{{filterOptions}}"
      wx:key="key"
      class="filter-tag {{activeFilter === item.key ? 'filter-tag-active' : ''}}"
      bindtap="onFilterChange"
      data-key="{{item.key}}"
    >
      <text class="filter-tag-text">{{item.label}}</text>
    </view>
  </view>

  <!-- 错题重练入口 -->
  <view class="section-action" wx:if="{{filteredList.length > 0}}">
    <view class="practice-wrong-btn" bindtap="goPracticeWrong">
      <text class="practice-wrong-text">重新练习错题</text>
    </view>
  </view>

  <!-- 错题列表 -->
  <view class="wrong-list" wx:if="{{filteredList.length > 0}}">
    <view class="card wrong-card" wx:for="{{filteredList}}" wx:key="id">
      <view class="wrong-header">
        <view class="wrong-tags">
          <text class="wrong-exam">{{item.examLabel}}</text>
          <text class="wrong-source {{item.sourceType === 'past_exam_japanese' ? 'wrong-source-exam' : ''}}">{{item.sourceLabel}}</text>
        </view>
        <text class="wrong-time" wx:if="{{item.wrongAtLabel}}">{{item.wrongAtLabel}}</text>
      </view>

      <text class="wrong-question-zh">{{item.questionZh}}</text>
      <text class="wrong-question-ja">{{item.questionJa}}</text>
      <view class="translation-warning" wx:if="{{item.sourceType === 'past_exam_japanese'}}">
        <text class="warning-icon">⚠</text>
        <text class="warning-text">日文原题，中文翻译待补充。</text>
      </view>
      <view class="translation-warning" wx:if="{{item.sourceType !== 'past_exam_japanese' && item.translationStatus === 'zh_fallback_from_ja'}}">
        <text class="warning-icon">⚠</text>
        <text class="warning-text">中文翻译待补充</text>
      </view>

      <view class="wrong-detail-row">
        <text class="wrong-detail-label">正确答案：</text>
        <text class="wrong-detail-value wrong-correct">{{item.correctAnswer}}</text>
      </view>
      <view class="wrong-detail-row">
        <text class="wrong-detail-label">你的答案：</text>
        <text class="wrong-detail-value wrong-incorrect">{{item.lastAnswer}}</text>
      </view>

      <view class="wrong-explanation" wx:if="{{item.explanationZh || item.explanationJa}}">
        <view class="explanation-warning" wx:if="{{item.explanationStatus === 'shared_hint'}}">
          <text class="warning-icon">⚠</text>
          <text class="warning-text">解释为通用说明，中文解释待补充。</text>
        </view>
        <text class="wrong-exp-text">{{item.explanationZh}}</text>
        <text class="wrong-exp-text wrong-exp-ja">{{item.explanationJa}}</text>
      </view>

      <!-- 单条操作 -->
      <view class="wrong-actions">
        <view class="action-btn action-remove" bindtap="removeWrong" data-id="{{item.id}}">
          <text class="action-btn-text">移出错题本</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{filteredList.length === 0}}">
    <text class="empty-icon">📋</text>
    <text class="empty-text">{{activeFilter === 'all' ? '当前没有错题' : '该分类下没有错题'}}</text>
    <text class="empty-hint">继续练习后会自动记录需要复习的题目。</text>
    <view class="empty-action">
      <view class="go-study-btn" bindtap="goStudy">
        <text class="go-study-text">去练习</text>
      </view>
    </view>
  </view>
</view>
