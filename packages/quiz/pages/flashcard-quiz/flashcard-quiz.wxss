/* packages/quiz/pages/flashcard-quiz/flashcard-quiz.wxss — themed with app.wxss CSS variables */
.fc-container {
  min-height: 100vh;
  padding: 24rpx 32rpx 160rpx;
  background: var(--bg-color);
}

/* Loading State */
.fc-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 32rpx;
}
.fc-loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid var(--divider-color);
  border-top-color: var(--text-secondary);
  border-radius: 50%;
  animation: fc-spin .8s linear infinite;
}
@keyframes fc-spin { to { transform: rotate(360deg); } }
.fc-loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* Error State */
.fc-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 32rpx;
}
.fc-error-icon {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--color-error);
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 50%;
  background: var(--color-error-light);
  margin-bottom: 24rpx;
}
.fc-error-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}
.fc-error-course {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}
.fc-error-detail {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 32rpx;
  text-align: center;
}
.fc-error-actions {
  display: flex;
  gap: 16rpx;
}

/* ===== HEADER ===== */
.fc-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.fc-header-left {
  display: flex;
  align-items: center;
}
.fc-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-inverse);
  margin-right: 12rpx;
  flex-shrink: 0;
}
.fc-badge-it { background: var(--text-primary); }
.fc-badge-sg { background: var(--text-secondary); }
.fc-header-info {
  display: flex;
  flex-direction: column;
}
.fc-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.3;
}
.fc-header-meta {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 2rpx;
}
.fc-deck-timer {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-variant-numeric: tabular-nums;
}

/* ===== PROGRESS BAR ===== */
.fc-progress {
  height: 4rpx;
  background: var(--divider-color);
  border-radius: 2rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
}
.fc-progress-bar {
  height: 100%;
  background: var(--text-primary);
  border-radius: 2rpx;
  transition: width .3s ease;
}

/* ===== STATS (compact) ===== */
.fc-stats {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}
.fc-stat { font-size: 24rpx; font-weight: 500; }
.fc-stat-correct { color: var(--color-success); }
.fc-stat-wrong { color: var(--color-error); }

/* ===== FRONT SIDE ===== */
.fc-card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}
.fc-front {
  border-left: 6rpx solid var(--text-primary);
}
.fc-question-text {
  display: block;
  font-size: 32rpx;
  line-height: 1.65;
  color: var(--text-primary);
  white-space: pre-wrap;
  word-break: break-word;
}
.fc-question-zh {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-secondary);
  margin-top: 12rpx;
  white-space: pre-wrap;
}

/* ===== OPTIONS ===== */
.fc-options { margin-bottom: 16rpx; }
.fc-option {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  margin-bottom: 10rpx;
  border-radius: 12rpx;
  background: var(--card-bg);
  border: 2rpx solid var(--border-color);
  transition: all .15s ease;
}
.fc-option:active {
  background: var(--press-bg);
  transform: scale(.985);
}
.fc-option-key {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--bg-surface);
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-right: 14rpx;
  flex-shrink: 0;
}
.fc-option-key-correct {
  background: var(--color-success);
  color: var(--text-inverse);
}
.fc-option-key-wrong {
  background: var(--color-error);
  color: var(--text-inverse);
}
.fc-option-body {
  flex: 1;
  min-width: 0;
}
.fc-option-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--text-primary);
  word-break: break-word;
}
.fc-option-text-zh {
  display: block;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
  margin-top: 6rpx;
  word-break: break-word;
}
.fc-option-status {
  margin-left: 10rpx;
  flex-shrink: 0;
  padding-top: 4rpx;
}
.fc-status-correct { font-size: 24rpx; font-weight: 600; color: var(--color-success); }
.fc-status-wrong { font-size: 24rpx; font-weight: 600; color: var(--color-error); }

/* Option states after answer */
.fc-option-correct {
  border-color: var(--color-success);
  background: var(--color-success-light);
}
.fc-option-wrong {
  border-color: var(--color-error);
  background: var(--color-error-light);
}
.fc-option-dim {
  opacity: .45;
  pointer-events: none;
}

/* ===== FEEDBACK ===== */
.fc-feedback { margin-top: 12rpx; }
.fc-feedback-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  border-radius: 10rpx;
  margin-bottom: 12rpx;
}
.fc-feedback-correct {
  background: var(--color-success-light);
  border: 2rpx solid var(--color-success);
}
.fc-feedback-wrong {
  background: var(--color-error-light);
  border: 2rpx solid var(--color-error);
}
.fc-feedback-text { font-size: 28rpx; font-weight: 600; }
.fc-feedback-correct .fc-feedback-text { color: var(--color-success); }
.fc-feedback-wrong .fc-feedback-text { color: var(--color-error); }

/* ===== ACTION BUTTONS ===== */
.fc-action-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 12rpx;
}
.fc-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 22rpx 16rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: opacity 0.12s ease, transform 0.12s ease;
}
.fc-btn:active { opacity: .75; transform: scale(.97); }
.fc-btn-primary {
  width: 100%;
  background: var(--text-primary);
  color: var(--text-inverse);
  font-weight: 600;
}
.fc-btn-secondary {
  width: 100%;
  background: var(--bg-surface);
  color: var(--text-primary);
  border: 2rpx solid var(--border-color);
}
.fc-btn-ghost {
  background: transparent;
  border: 2rpx solid var(--border-color);
  color: var(--text-secondary);
}
.fc-btn-retry {
  background: var(--color-warning-light);
  color: var(--color-warning);
  border: 2rpx solid rgba(139, 123, 93, 0.24);
}
.fc-btn-full { width: 100%; }

/* ===== BACK SIDE ===== */
.fc-back-block {
  background: var(--card-bg);
  border-radius: 14rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
  box-shadow: var(--shadow-sm);
}
.fc-back-label {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 1rpx;
  margin-bottom: 10rpx;
}
.fc-back-ja {
  display: block;
  font-size: 28rpx;
  line-height: 1.65;
  color: var(--text-primary);
  white-space: pre-wrap;
  word-break: break-word;
}
.fc-back-zh {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-secondary);
  white-space: pre-wrap;
  word-break: break-word;
  margin-top: 10rpx;
}

/* Verdict (user choice vs correct) — vertical stacked */
.fc-back-verdict {
  display: block;
  padding: 20rpx 24rpx;
}
.fc-verdict-item {
  display: block;
  width: 100%;
  margin-bottom: 16rpx;
}
.fc-verdict-item:last-child { margin-bottom: 0; }
.fc-verdict-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  margin-top: 6rpx;
}
.fc-verdict-correct { color: var(--color-success); }
.fc-verdict-wrong { color: var(--color-error); }

/* Back Options */
.fc-back-options { margin-top: 4rpx; }
.fc-back-option {
  padding: 16rpx 20rpx;
  margin-bottom: 8rpx;
  border-radius: 10rpx;
  background: var(--bg-surface);
  border: 2rpx solid var(--border-color);
}
.fc-back-option-correct {
  border-color: var(--color-success);
  background: var(--color-success-light);
}
.fc-back-option-wrong {
  border-color: var(--color-error);
  background: var(--color-error-light);
}
.fc-back-option-selected-correct {
  border-color: var(--color-success);
  background: var(--color-success-light);
}
.fc-back-option-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}
.fc-back-option-key {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--bg-surface);
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.fc-back-option-key-correct {
  background: var(--color-success);
  color: var(--text-inverse);
}
.fc-back-option-mark {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-weight: 600;
  background: var(--primary-light);
  color: var(--primary-color);
}
.fc-back-option-mark-correct {
  background: var(--color-success-light);
  color: var(--color-success);
}
.fc-back-option-ja {
  display: block;
  font-size: 26rpx;
  line-height: 1.55;
  color: var(--text-primary);
  word-break: break-word;
}
.fc-back-option-zh {
  display: block;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
  margin-top: 6rpx;
  word-break: break-word;
}

/* Option-level explanation */
.fc-back-option-explain {
  margin-top: 10rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid var(--divider-color);
}
.fc-back-explain-ja {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-secondary);
  word-break: break-word;
}
.fc-back-explain-zh {
  display: block;
  font-size: 22rpx;
  line-height: 1.55;
  color: var(--text-hint);
  margin-top: 6rpx;
  word-break: break-word;
}

/* Detail explanation */
.fc-back-detail-ja {
  display: block;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--text-primary);
  white-space: pre-wrap;
  word-break: break-word;
}
.fc-back-detail-zh {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-secondary);
  margin-top: 12rpx;
  white-space: pre-wrap;
  word-break: break-word;
}

/* Mnemonic */
.fc-back-mnemonic {
  background: var(--card-bg);
  border-left: 4rpx solid var(--text-hint);
}
.fc-back-mnemonic-ja {
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--text-primary);
  word-break: break-word;
}
.fc-back-mnemonic-zh {
  display: block;
  font-size: 24rpx;
  line-height: 1.55;
  color: var(--text-secondary);
  margin-top: 8rpx;
  word-break: break-word;
}

/* ===== RESULT ===== */
.fc-result {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  text-align: center;
  box-shadow: var(--shadow-sm);
}
.fc-result-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}
.fc-result-accuracy { margin-bottom: 28rpx; }
.fc-result-pct {
  display: block;
  font-size: 72rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.1;
}
.fc-result-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
}
.fc-result-stats {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-bottom: 28rpx;
}
.fc-result-stat { text-align: center; }
.fc-result-stat-value {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
}
.fc-result-stat-correct .fc-result-stat-value { color: var(--color-success); }
.fc-result-stat-wrong .fc-result-stat-value { color: var(--color-error); }
.fc-result-stat-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
}
.fc-result-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.fc-result-actions .fc-btn { width: 100%; }

/* Empty */
.fc-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
}
.fc-empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}
.fc-empty-detail {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 40rpx;
  text-align: center;
}
