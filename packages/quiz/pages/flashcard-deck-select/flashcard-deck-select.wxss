/* packages/quiz/pages/flashcard-deck-select/flashcard-deck-select.wxss — themed with app.wxss CSS variables */
.fds-container {
  min-height: 100vh;
  padding: 24rpx 32rpx;
  box-sizing: border-box;
  background: var(--bg-color);
}

.fds-loading, .fds-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  padding: 48rpx;
}

.fds-loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--divider-color);
  border-top: 4rpx solid var(--text-primary);
  border-radius: 50%;
  animation: fds-spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes fds-spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.fds-loading-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.fds-error-title {
  font-size: 30rpx;
  color: var(--color-error);
  margin-bottom: 24rpx;
  text-align: center;
}

.fds-header {
  margin-bottom: 32rpx;
}

.fds-course-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.fds-course-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
  display: block;
}

.fds-section-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid var(--divider-color);
}

.fds-deck-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.fds-deck-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  background: var(--card-bg);
  border-radius: 16rpx;
  border: 1rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
  transition: opacity 0.2s;
  active-opacity: 0.7;
}

.fds-deck-card:active {
  opacity: 0.7;
}

.fds-deck-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.fds-deck-label {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.fds-deck-count {
  font-size: 24rpx;
  color: var(--color-success);
}

.fds-deck-arrow {
  font-size: 36rpx;
  color: var(--text-hint);
}

.fds-footer {
  margin-top: 40rpx;
  text-align: center;
}

.fds-btn {
  display: inline-block;
  padding: 16rpx 48rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--color-success);
  border: 2rpx solid var(--color-success);
  text-align: center;
  transition: opacity 0.2s;
}

.fds-btn-primary {
  background: var(--text-primary);
  color: var(--text-inverse);
  border: none;
}

.fds-btn:active {
  opacity: 0.7;
}
