/* packages/quiz/pages/flashcard-deck-select/flashcard-deck-select.wxss */
.fds-container {
  min-height: 100vh;
  padding: 24rpx 32rpx;
  box-sizing: border-box;
}

.fds-loading, .fds-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  padding: 48rpx;
}

.fds-loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top: 4rpx solid #07c160;
  border-radius: 50%;
  animation: fds-spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes fds-spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.fds-loading-text {
  font-size: 28rpx;
  color: #999;
}

.fds-error-title {
  font-size: 30rpx;
  color: #e74c3c;
  margin-bottom: 24rpx;
  text-align: center;
}

.fds-header {
  margin-bottom: 32rpx;
}

.fds-course-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

.fds-course-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.fds-section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #eee;
}

.fds-deck-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.fds-deck-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  transition: opacity 0.2s;
  active-opacity: 0.7;
}

.fds-deck-card:active {
  opacity: 0.7;
}

.fds-deck-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.fds-deck-label {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.fds-deck-count {
  font-size: 24rpx;
  color: #07c160;
}

.fds-deck-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.fds-footer {
  margin-top: 40rpx;
  text-align: center;
}

.fds-btn {
  display: inline-block;
  padding: 16rpx 48rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #07c160;
  border: 2rpx solid #07c160;
  text-align: center;
  transition: opacity 0.2s;
}

.fds-btn-primary {
  background: #07c160;
  color: #fff;
  border: none;
}

.fds-btn:active {
  opacity: 0.7;
}
