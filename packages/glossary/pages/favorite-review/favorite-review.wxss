/* packages/glossary/pages/favorite-review/favorite-review.wxss — monochrome knowledge deck */

.container {
  background: var(--bg-color);
  padding: 28rpx 28rpx 88rpx;
  min-height: 100vh;
}

/* ===== Stats header ===== */
.stats-header { padding: 4rpx 0 18rpx; }

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 8rpx;
}

.stats-count {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 720;
}

.stats-last-saved {
  font-size: 22rpx;
  color: var(--text-hint);
}

/* ===== Search bar ===== */
.search-bar { padding: 0 0 20rpx; }

.search-input-wrap {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
  border-radius: 999rpx;
  padding: 16rpx 24rpx;
  box-shadow: var(--shadow-sm);
}

.search-input-wrap:active {
  border-color: var(--border-strong);
  background: var(--press-bg);
}

.search-symbol {
  width: 30rpx;
  height: 30rpx;
  margin-right: 14rpx;
  border: 3rpx solid var(--text-secondary);
  border-radius: 50%;
  position: relative;
  flex-shrink: 0;
}

.search-symbol::after {
  content: '';
  position: absolute;
  right: -8rpx;
  bottom: -5rpx;
  width: 14rpx;
  height: 3rpx;
  background: var(--text-secondary);
  transform: rotate(45deg);
}

.search-icon { font-size: 32rpx; margin-right: 12rpx; flex-shrink: 0; }

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 48rpx;
  line-height: 48rpx;
  color: var(--text-primary);
}

.search-clear {
  font-size: 28rpx;
  color: var(--text-hint);
  padding: 8rpx;
  margin-left: 8rpx;
  flex-shrink: 0;
}

/* ===== Mode switch ===== */
.mode-switch {
  display: flex;
  background: var(--bg-surface);
  border: 1rpx solid var(--border-color);
  border-radius: 40rpx;
  margin-bottom: 24rpx;
  padding: 6rpx;
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 36rpx;
  transition: all 0.2s;
}

.mode-tab:active,
.flc-unfav-btn:active,
.reveal-btn:active,
.unfav-btn:active,
.nav-btn:active,
.completion-btn:active {
  transform: translateY(2rpx) scale(0.97);
  opacity: 0.9;
}

.mode-tab-active {
  background: var(--card-bg);
  border: 1rpx solid var(--border-strong);
  box-shadow: var(--shadow-sm);
}

.mode-tab-text {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

/* ===== List mode ===== */
.fav-list { padding: 0 0 40rpx; }

.fav-list-card {
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
  border-radius: 22rpx;
  margin-bottom: 16rpx;
  padding: 28rpx 28rpx;
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: flex-start;
  transition: transform 0.12s ease, box-shadow 0.12s ease;
}

.fav-list-card:active {
  transform: translateY(2rpx) scale(0.985);
  background: var(--press-bg);
}

.flc-left { flex: 1; min-width: 0; }

.flc-header,
.flc-translations,
.term-header {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.flc-header { margin-bottom: 12rpx; }

.flc-term {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-right: 12rpx;
  word-break: break-word;
}

.flc-category,
.flc-level,
.term-category,
.term-level {
  font-size: 20rpx;
  color: var(--text-secondary);
  background: var(--bg-surface);
  border: 1rpx solid var(--divider-color);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  margin-right: 8rpx;
}

.flc-level,
.term-level { margin-right: 0; }

.flc-translations { margin-bottom: 10rpx; }

.flc-zh { font-size: 28rpx; color: var(--text-secondary); word-break: break-word; }
.flc-sep { font-size: 22rpx; color: var(--text-hint); margin: 0 10rpx; }
.flc-ja { font-size: 26rpx; color: var(--text-secondary); word-break: break-word; }

.flc-saved-at {
  font-size: 22rpx;
  color: var(--text-hint);
  display: block;
}

.flc-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.flc-unfav-btn {
  background: var(--color-error-light);
  border: 1rpx solid rgba(138, 95, 100, 0.28);
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
  margin-bottom: 8rpx;
}

.flc-unfav-text { font-size: 22rpx; color: var(--color-error); }

.flc-detail-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-arrow { font-size: 32rpx; color: var(--text-hint); }
.detail-label { font-size: 20rpx; color: var(--text-hint); }

/* ===== Review mode ===== */
.progress-bar { padding: 16rpx 0 24rpx; text-align: center; }

.progress-text {
  display: inline-flex;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  background: var(--bg-surface);
  border: 1rpx solid var(--divider-color);
}

.term-card {
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
  border-radius: 22rpx;
  padding: 40rpx 36rpx;
  box-shadow: var(--shadow-sm);
  margin-bottom: 30rpx;
}

.term-english,
.term-zh,
.term-ja,
.explanation-text {
  word-break: break-word;
}

.term-english {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.term-zh {
  display: block;
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  line-height: 1.6;
}

.term-ja {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  line-height: 1.6;
}

.term-saved-at {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-left: auto;
}

.explanation-section { margin-top: 10rpx; }

.explanation-divider {
  height: 1rpx;
  background: var(--divider-color);
  margin-bottom: 24rpx;
}

.explanation-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-hint);
  margin-bottom: 8rpx;
  margin-top: 16rpx;
}

.expl-ja-label { margin-top: 20rpx; }

.explanation-text {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

.expl-ja-text { color: var(--text-secondary); }

.expl-example {
  background: var(--bg-surface);
  border: 1rpx solid var(--divider-color);
  color: var(--text-secondary);
  font-style: italic;
  padding: 16rpx;
  border-radius: 12rpx;
}

/* ===== Completion ===== */
.completion-hint {
  background: var(--bg-surface);
  border: 1rpx solid var(--divider-color);
  margin-top: 30rpx;
  padding: 28rpx;
  border-radius: 16rpx;
}

.completion-text {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 600;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.completion-actions { display: flex; gap: 16rpx; }

.completion-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 0;
  border-radius: 32rpx;
}

.completion-btn-list,
.reveal-btn,
.nav-btn-detail,
.go-search-btn {
  background: var(--text-primary);
  border: 1rpx solid var(--text-primary);
  box-shadow: 0 14rpx 32rpx rgba(17, 24, 39, 0.16);
}

.completion-btn-glossary,
.go-search-btn-secondary,
.nav-btn {
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
}

.completion-btn-text { font-size: 26rpx; font-weight: 600; }

.completion-btn-list .completion-btn-text { color: var(--text-inverse); }

.completion-btn-glossary .completion-btn-text,
.go-search-text-secondary,
.nav-btn-text {
  color: var(--text-primary);
}

/* ===== Reveal button ===== */
.reveal-btn-wrap {
  display: flex;
  justify-content: center;
  margin-top: 32rpx;
}

.reveal-btn {
  border-radius: 40rpx;
  padding: 22rpx 60rpx;
}

.reveal-btn-text { font-size: 30rpx; font-weight: 600; color: var(--text-inverse); }

/* ===== Unfavorite ===== */
.unfav-btn-wrap {
  display: flex;
  justify-content: center;
  margin-top: 24rpx;
}

.unfav-btn {
  background: var(--color-error-light);
  border: 1rpx solid rgba(138, 95, 100, 0.28);
  border-radius: 40rpx;
  padding: 16rpx 50rpx;
}

.unfav-btn-text { font-size: 26rpx; color: var(--color-error); }

/* ===== Nav buttons ===== */
.nav-buttons { display: flex; justify-content: space-between; gap: 20rpx; }

.nav-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  padding: 24rpx 0;
}

.nav-btn-text { font-size: 28rpx; font-weight: 600; }

.nav-btn-disabled {
  opacity: 0.45;
  background: var(--disabled-bg);
}

/* ===== Empty state ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 64rpx;
  padding: 72rpx 40rpx 60rpx;
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
  border-radius: 24rpx;
  box-shadow: var(--shadow-sm);
}

.empty-symbol {
  width: 80rpx;
  height: 80rpx;
  font-size: 120rpx; /* R3.19 smoke anchor */
  border: 3rpx solid var(--text-hint);
  border-radius: 24rpx;
  margin-bottom: 28rpx;
  position: relative;
}

.empty-symbol::before,
.empty-symbol::after {
  content: '';
  position: absolute;
  background: var(--text-hint);
}

.empty-symbol::before {
  left: 20rpx; right: 20rpx; top: 38rpx;
  height: 3rpx;
}

.empty-symbol::after {
  top: 20rpx; bottom: 20rpx; left: 38rpx;
  width: 3rpx;
}

.empty-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  border-radius: 30rpx;
  font-size: 64rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-hint);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 50rpx;
  padding: 0 20rpx;
}

.go-search-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 40rpx;
  padding: 0 60rpx;
  transition: transform 0.12s ease, opacity 0.12s ease;
}

.go-search-btn:active {
  transform: translateY(2rpx) scale(0.985);
  opacity: 0.9;
}

.go-search-text { font-size: 30rpx; font-weight: 600; color: var(--text-inverse); }
