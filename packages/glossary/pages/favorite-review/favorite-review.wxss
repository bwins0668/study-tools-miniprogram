/* packages/glossary/pages/favorite-review/favorite-review.wxss */

.container {
  padding: 30rpx 30rpx 80rpx;
  min-height: 100vh;
}

/* 顶部统计 */
.stats-header {
  padding: 10rpx 0 16rpx;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 8rpx;
}

.stats-count {
  font-size: 28rpx;
  color: #4a90d9;
  font-weight: 600;
}

.stats-last-saved {
  font-size: 22rpx;
  color: #999999;
}

/* 搜索框 */
.search-bar {
  padding: 0 0 20rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 48rpx;
  line-height: 48rpx;
}

.search-clear {
  font-size: 28rpx;
  color: #cccccc;
  padding: 8rpx;
  margin-left: 8rpx;
  flex-shrink: 0;
}

/* 模式切换 */
.mode-switch {
  display: flex;
  background-color: #f0f0f0;
  border-radius: 40rpx;
  margin-bottom: 24rpx;
  padding: 6rpx;
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 36rpx;
  transition: all 0.2s;
}

.mode-tab-active {
  background-color: #4a90d9;
  box-shadow: 0 2rpx 12rpx rgba(74, 144, 217, 0.3);
}

.mode-tab-text {
  font-size: 28rpx;
  color: #888888;
  font-weight: 500;
}

.mode-tab-active .mode-tab-text {
  color: #ffffff;
}

/* ====== 列表模式 ====== */
.fav-list {
  padding: 0 0 40rpx;
}

.fav-list-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  padding: 28rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: flex-start;
}

.flc-left {
  flex: 1;
  min-width: 0;
}

.flc-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.flc-term {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  margin-right: 12rpx;
}

.flc-category {
  font-size: 20rpx;
  color: #4a90d9;
  background-color: #eef4fc;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  margin-right: 8rpx;
}

.flc-level {
  font-size: 20rpx;
  color: #e8913a;
  background-color: #fdf4e8;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.flc-translations {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.flc-zh {
  font-size: 28rpx;
  color: #555555;
}

.flc-sep {
  font-size: 22rpx;
  color: #cccccc;
  margin: 0 10rpx;
}

.flc-ja {
  font-size: 26rpx;
  color: #888888;
}

.flc-saved-at {
  font-size: 22rpx;
  color: #aaaaaa;
  display: block;
}

.flc-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.flc-unfav-btn {
  background-color: #fff0f0;
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
  margin-bottom: 8rpx;
}

.flc-unfav-text {
  font-size: 22rpx;
  color: #e05a5a;
}

.flc-detail-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-arrow {
  font-size: 32rpx;
  color: #cccccc;
}

.detail-label {
  font-size: 20rpx;
  color: #cccccc;
}

/* ====== 复习模式 ====== */
/* 进度条 */
.progress-bar {
  text-align: center;
  padding: 20rpx 0 30rpx;
}

.progress-text {
  font-size: 28rpx;
  color: #888888;
}

/* 术语卡片 */
.term-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 30rpx;
}

.term-header {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
}

.term-category {
  font-size: 22rpx;
  color: #4a90d9;
  background-color: #eef4fc;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  margin-right: 12rpx;
}

.term-level {
  font-size: 22rpx;
  color: #e8913a;
  background-color: #fff8e1;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  margin-right: 12rpx;
}

.term-saved-at {
  font-size: 22rpx;
  color: #aaaaaa;
  margin-left: auto;
}

.term-english {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 20rpx;
  line-height: 1.4;
  word-break: break-word;
}

.term-zh {
  display: block;
  font-size: 32rpx;
  color: #555555;
  margin-bottom: 12rpx;
  line-height: 1.6;
  word-break: break-word;
}

.term-ja {
  display: block;
  font-size: 28rpx;
  color: #888888;
  margin-bottom: 12rpx;
  line-height: 1.6;
  word-break: break-word;
}

/* 解释区域 */
.explanation-section {
  margin-top: 10rpx;
}

.explanation-divider {
  height: 1rpx;
  background-color: #f0f0f0;
  margin-bottom: 24rpx;
}

.explanation-label {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
  margin-top: 16rpx;
}

.expl-ja-label {
  margin-top: 20rpx;
}

.explanation-text {
  display: block;
  font-size: 28rpx;
  color: #444444;
  line-height: 1.8;
  word-break: break-word;
}

.expl-ja-text {
  color: #666666;
}

.expl-example {
  color: #4a90d9;
  font-style: italic;
  padding: 16rpx;
  background-color: #f5f8fe;
  border-radius: 12rpx;
}

/* 复习完成提示 */
.completion-hint {
  margin-top: 30rpx;
  padding: 28rpx;
  background-color: #f0faf0;
  border-radius: 16rpx;
  border: 2rpx solid #c8e6c9;
}

.completion-text {
  display: block;
  font-size: 28rpx;
  color: #2e7d32;
  font-weight: 600;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.completion-actions {
  display: flex;
  gap: 16rpx;
}

.completion-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 0;
  border-radius: 32rpx;
}

.completion-btn-list {
  background-color: #4a90d9;
  box-shadow: 0 2rpx 12rpx rgba(74, 144, 217, 0.3);
}

.completion-btn-glossary {
  background-color: #ffffff;
  border: 2rpx solid #4a90d9;
}

.completion-btn-text {
  font-size: 26rpx;
  font-weight: 600;
}

.completion-btn-list .completion-btn-text {
  color: #ffffff;
}

.completion-btn-glossary .completion-btn-text {
  color: #4a90d9;
}

/* 显示解释按钮 */
.reveal-btn-wrap {
  display: flex;
  justify-content: center;
  margin-top: 32rpx;
}

.reveal-btn {
  background-color: #4a90d9;
  border-radius: 40rpx;
  padding: 22rpx 60rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
}

.reveal-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 取消收藏按钮 */
.unfav-btn-wrap {
  display: flex;
  justify-content: center;
  margin-top: 24rpx;
}

.unfav-btn {
  background-color: #fff0f0;
  border-radius: 40rpx;
  padding: 16rpx 50rpx;
  border: 2rpx solid #fddddd;
}

.unfav-btn-text {
  font-size: 26rpx;
  color: #e05a5a;
}

/* 底部操作按钮 */
.nav-buttons {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.nav-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ffffff;
  border-radius: 40rpx;
  padding: 24rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.nav-btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.nav-btn-detail {
  background-color: #4a90d9;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
}

.nav-btn-detail .nav-btn-text {
  color: #ffffff;
}

.nav-btn-disabled {
  opacity: 0.4;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 140rpx 40rpx 60rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 36rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999999;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 50rpx;
  padding: 0 20rpx;
}

.go-search-btn {
  background-color: #4a90d9;
  border-radius: 40rpx;
  padding: 24rpx 60rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
}

.go-search-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

.go-search-btn-secondary {
  background-color: #ffffff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  border: 2rpx solid #4a90d9;
}

.go-search-text-secondary {
  color: #4a90d9;
}
