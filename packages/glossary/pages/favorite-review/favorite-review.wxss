/* packages/glossary/pages/favorite-review/favorite-review.wxss */

.container {
  padding: 30rpx 30rpx 80rpx;
  min-height: 100vh;
}

/* 顶部统计 */
.stats-header {
  padding: 10rpx 0 16rpx;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 8rpx;
}

.stats-count {
  font-size: 28rpx;
  color: #4a90d9;
  font-weight: 600;
}

.stats-last-saved {
  font-size: 22rpx;
  color: var(--text-hint);
}

/* 搜索框 */
.search-bar {
  padding: 0 0 20rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background-color: var(--card-bg);
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 48rpx;
  line-height: 48rpx;
}

.search-clear {
  font-size: 28rpx;
  color: var(--text-hint);
  padding: 8rpx;
  margin-left: 8rpx;
  flex-shrink: 0;
}

/* 模式切换 */
.mode-switch {
  display: flex;
  background-color: var(--divider-color);
  border-radius: 40rpx;
  margin-bottom: 24rpx;
  padding: 6rpx;
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 36rpx;
  transition: all 0.2s;
}

.mode-tab-active {
  background-color: #4a90d9;
  box-shadow: 0 2rpx 12rpx rgba(74, 144, 217, 0.3);
}

.mode-tab-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.mode-tab-active .mode-tab-text {
  color: #ffffff;
}

/* ====== 列表模式 ====== */
.fav-list {
  padding: 0 0 40rpx;
}

.fav-list-card {
  background: linear-gradient(170deg, var(--card-bg) 0%, rgba(74, 144, 217, 0.025) 100%);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  padding: 28rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(74, 144, 217, 0.06);
  display: flex;
  align-items: flex-start;
  transition: transform 0.12s ease, box-shadow 0.12s ease;
}

.fav-list-card:active {
  transform: translateY(2rpx) scale(0.985);
  box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.08);
}

.flc-left {
  flex: 1;
  min-width: 0;
}

.flc-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.flc-term {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-right: 12rpx;
}

.flc-category {
  font-size: 20rpx;
  color: #4a90d9;
  background-color: #eef4fc;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  margin-right: 8rpx;
}

.flc-level {
  font-size: 20rpx;
  color: #e8913a;
  background-color: #fdf4e8;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.flc-translations {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.flc-zh {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.flc-sep {
  font-size: 22rpx;
  color: var(--text-hint);
  margin: 0 10rpx;
}

.flc-ja {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.flc-saved-at {
  font-size: 22rpx;
  color: var(--text-hint);
  display: block;
}

.flc-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.flc-unfav-btn {
  background-color: #fff0f0;
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
  margin-bottom: 8rpx;
}

.flc-unfav-text {
  font-size: 22rpx;
  color: #e05a5a;
}

.flc-detail-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-arrow {
  font-size: 32rpx;
  color: var(--text-hint);
}

.detail-label {
  font-size: 20rpx;
  color: var(--text-hint);
}

/* ====== 复习模式 ====== */
/* 进度条 */
.progress-bar {
  text-align: center;
  padding: 20rpx 0 30rpx;
}

.progress-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 术语卡片 */
.term-card {
  background-color: var(--card-bg);
  border-radius: 20rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 30rpx;
}

.term-header {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
}

.term-category {
  font-size: 22rpx;
  color: #4a90d9;
  background-color: #eef4fc;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  margin-right: 12rpx;
}

.term-level {
  font-size: 22rpx;
  color: #e8913a;
  background-color: #fff8e1;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  margin-right: 12rpx;
}

.term-saved-at {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-left: auto;
}

.term-english {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  line-height: 1.4;
  word-break: break-word;
}

.term-zh {
  display: block;
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  line-height: 1.6;
  word-break: break-word;
}

.term-ja {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  line-height: 1.6;
  word-break: break-word;
}

/* 解释区域 */
.explanation-section {
  margin-top: 10rpx;
}

.explanation-divider {
  height: 1rpx;
  background-color: var(--divider-color);
  margin-bottom: 24rpx;
}

.explanation-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-hint);
  margin-bottom: 8rpx;
  margin-top: 16rpx;
}

.expl-ja-label {
  margin-top: 20rpx;
}

.explanation-text {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  word-break: break-word;
}

.expl-ja-text {
  color: var(--text-secondary);
}

.expl-example {
  color: #4a90d9;
  font-style: italic;
  padding: 16rpx;
  background-color: #f5f8fe;
  border-radius: 12rpx;
}

/* 复习完成提示 */
.completion-hint {
  margin-top: 30rpx;
  padding: 28rpx;
  background-color: #f0faf0;
  border-radius: 16rpx;
  border: 2rpx solid #c8e6c9;
}

.completion-text {
  display: block;
  font-size: 28rpx;
  color: #2e7d32;
  font-weight: 600;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.completion-actions {
  display: flex;
  gap: 16rpx;
}

.completion-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 0;
  border-radius: 32rpx;
}

.completion-btn-list {
  background-color: #4a90d9;
  box-shadow: 0 2rpx 12rpx rgba(74, 144, 217, 0.3);
}

.completion-btn-glossary {
  background-color: var(--card-bg);
  border: 2rpx solid #4a90d9;
}

.completion-btn-text {
  font-size: 26rpx;
  font-weight: 600;
}

.completion-btn-list .completion-btn-text {
  color: #ffffff;
}

.completion-btn-glossary .completion-btn-text {
  color: #4a90d9;
}

/* 显示解释按钮 */
.reveal-btn-wrap {
  display: flex;
  justify-content: center;
  margin-top: 32rpx;
}

.reveal-btn {
  background-color: #4a90d9;
  border-radius: 40rpx;
  padding: 22rpx 60rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
}

.reveal-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 取消收藏按钮 */
.unfav-btn-wrap {
  display: flex;
  justify-content: center;
  margin-top: 24rpx;
}

.unfav-btn {
  background-color: #fff0f0;
  border-radius: 40rpx;
  padding: 16rpx 50rpx;
  border: 2rpx solid #fddddd;
}

.unfav-btn-text {
  font-size: 26rpx;
  color: #e05a5a;
}

/* 底部操作按钮 */
.nav-buttons {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.nav-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--card-bg);
  border-radius: 40rpx;
  padding: 24rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.nav-btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.nav-btn-detail {
  background-color: #4a90d9;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
}

.nav-btn-detail .nav-btn-text {
  color: #ffffff;
}

.nav-btn-disabled {
  opacity: 0.4;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 64rpx;
  padding: 72rpx 40rpx 60rpx;
  background: linear-gradient(170deg, var(--card-bg) 0%, rgba(232, 145, 58, 0.035) 100%);
  border: 1rpx solid rgba(232, 145, 58, 0.1);
  border-radius: 22rpx;
  box-shadow: 0 4rpx 18rpx rgba(15, 23, 42, 0.06);
}

.empty-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  border-radius: 30rpx;
  font-size: 64rpx;
  margin-bottom: 30rpx;
  background: linear-gradient(135deg, rgba(232, 145, 58, 0.12), rgba(74, 144, 217, 0.06));
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-hint);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 50rpx;
  padding: 0 20rpx;
}

.go-search-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  background: linear-gradient(135deg, #4a90d9, #6366f1);
  border-radius: 40rpx;
  padding: 0 60rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
  transition: transform 0.12s ease, opacity 0.12s ease;
}

.go-search-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.go-search-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

.go-search-btn-secondary {
  background-color: var(--card-bg);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  border: 2rpx solid #4a90d9;
}

.go-search-text-secondary {
  color: #4a90d9;
}

@media (prefers-color-scheme: dark) {
  .fav-list-card {
    background: linear-gradient(170deg, var(--card-bg) 0%, rgba(88, 166, 255, 0.04) 100%);
    border-color: rgba(88, 166, 255, 0.1);
  }

  .empty-state {
    background: linear-gradient(170deg, rgba(255, 255, 255, 0.045), rgba(251, 191, 36, 0.045));
    border-color: rgba(251, 191, 36, 0.12);
    box-shadow: 0 4rpx 18rpx rgba(0, 0, 0, 0.24);
  }

  .empty-icon {
    background: linear-gradient(135deg, rgba(251, 191, 36, 0.14), rgba(88, 166, 255, 0.08));
  }

  .go-search-btn-secondary {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(88, 166, 255, 0.35);
  }
}

/* Round UI depth 6: favorite review as a quiet knowledge deck */
.container {
  background: var(--bg-color);
  padding: 28rpx 28rpx 88rpx;
}

.stats-header {
  padding: 4rpx 0 18rpx;
}

.stats-count {
  color: var(--text-primary);
  font-size: 32rpx;
  font-weight: 720;
}

.search-input-wrap {
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
  border-radius: 999rpx;
  box-shadow: var(--shadow-sm);
}

.search-input-wrap:active {
  border-color: var(--border-strong);
  background: var(--press-bg);
}

.search-symbol {
  width: 30rpx;
  height: 30rpx;
  margin-right: 14rpx;
  border: 3rpx solid var(--text-secondary);
  border-radius: 50%;
  position: relative;
  flex-shrink: 0;
}

.search-symbol::after {
  content: '';
  position: absolute;
  right: -8rpx;
  bottom: -5rpx;
  width: 14rpx;
  height: 3rpx;
  background: var(--text-secondary);
  transform: rotate(45deg);
}

.mode-switch {
  background: var(--bg-surface);
  border: 1rpx solid var(--border-color);
}

.mode-tab-active {
  background: var(--card-bg);
  border: 1rpx solid var(--border-strong);
  box-shadow: var(--shadow-sm);
}

.mode-tab-active .mode-tab-text,
.mode-tab-text {
  color: var(--text-primary);
}

.mode-tab:active,
.flc-unfav-btn:active,
.reveal-btn:active,
.unfav-btn:active,
.nav-btn:active,
.completion-btn:active {
  transform: translateY(2rpx) scale(0.97);
  opacity: 0.9;
}

.fav-list-card,
.term-card {
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
  border-radius: 22rpx;
  box-shadow: var(--shadow-sm);
}

.fav-list-card:active {
  background: var(--press-bg);
}

.flc-header,
.flc-translations,
.term-header {
  flex-wrap: wrap;
}

.flc-term,
.term-english,
.term-zh,
.term-ja,
.explanation-text {
  word-break: break-word;
}

.flc-category,
.flc-level,
.term-category,
.term-level {
  color: var(--text-secondary);
  background: var(--bg-surface);
  border: 1rpx solid var(--divider-color);
}

.flc-unfav-btn,
.unfav-btn {
  background: var(--color-error-light);
  border: 1rpx solid rgba(138, 95, 100, 0.28);
}

.flc-unfav-text,
.unfav-btn-text {
  color: var(--color-error);
}

.progress-bar {
  padding: 16rpx 0 24rpx;
}

.progress-text {
  display: inline-flex;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  color: var(--text-secondary);
  background: var(--bg-surface);
  border: 1rpx solid var(--divider-color);
}

.explanation-divider {
  background: var(--divider-color);
}

.expl-example,
.completion-hint {
  background: var(--bg-surface);
  border: 1rpx solid var(--divider-color);
}

.completion-text {
  color: var(--text-primary);
}

.completion-btn-list,
.reveal-btn,
.nav-btn-detail,
.go-search-btn {
  background: #111827;
  border: 1rpx solid #111827;
  box-shadow: 0 14rpx 32rpx rgba(17, 24, 39, 0.16);
}

.completion-btn-glossary,
.go-search-btn-secondary,
.nav-btn {
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
}

.completion-btn-glossary .completion-btn-text,
.go-search-text-secondary,
.nav-btn-text {
  color: var(--text-primary);
}

.nav-btn-disabled {
  opacity: 0.45;
  background: var(--disabled-bg);
}

.empty-state {
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
  border-radius: 24rpx;
  box-shadow: var(--shadow-sm);
}

.empty-symbol {
  width: 80rpx;
  height: 80rpx;
  border: 3rpx solid var(--text-hint);
  border-radius: 24rpx;
  margin-bottom: 28rpx;
  position: relative;
}

.empty-symbol::before,
.empty-symbol::after {
  content: '';
  position: absolute;
  background: var(--text-hint);
}

.empty-symbol::before {
  left: 20rpx;
  right: 20rpx;
  top: 38rpx;
  height: 3rpx;
}

.empty-symbol::after {
  top: 20rpx;
  bottom: 20rpx;
  left: 38rpx;
  width: 3rpx;
}
