@import "../../../../styles/tokens.wxss";

/* packages/glossary/pages/term-detail/term-detail.wxss — monochrome term detail */

.page {
  padding: 20rpx 0 60rpx;
  min-height: 100vh;
  background: var(--bg-color);
}

/* ===== Back nav ===== */
.back-nav {
  display: flex;
  align-items: center;
  margin: 12rpx 28rpx 8rpx;
  padding: 18rpx 0;
}

.back-arrow {
  font-size: 48rpx;
  color: var(--text-secondary);
  margin-right: 8rpx;
  line-height: 1;
}

.back-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* ===== Card ===== */
.card {
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
  border-radius: 22rpx;
  margin: 16rpx 30rpx;
  padding: 28rpx 32rpx;
  box-shadow: var(--shadow-sm);
}

.card:active,
.copy-term-btn:active,
.copy-example-btn:active,
.note-save-btn:active,
.related-item:active {
  transform: translateY(2rpx) scale(0.985);
  background: var(--press-bg);
}

/* ===== Term header ===== */
.term-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.term-title-row {
  display: flex;
  align-items: flex-start;
  flex: 1;
  min-width: 0;
}

.term-main {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  word-break: break-word;
}

.copy-term-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 12rpx;
  margin-left: 12rpx;
  background: var(--bg-surface);
  border: 1rpx solid var(--border-color);
  border-radius: 14rpx;
  flex-shrink: 0;
}

.copy-term-icon { font-size: 28rpx; }

.copy-term-symbol,
.copy-example-symbol {
  width: 28rpx;
  height: 28rpx;
  border: 2rpx solid var(--text-secondary);
  border-radius: 8rpx;
  position: relative;
}

.copy-example-symbol { margin-right: 10rpx; }

.copy-term-symbol::before,
.copy-example-symbol::before {
  content: '';
  position: absolute;
  left: 7rpx;
  right: 7rpx;
  top: 8rpx;
  height: 2rpx;
  background: var(--text-secondary);
  box-shadow: 0 7rpx 0 var(--text-secondary);
}

/* ===== Term lines ===== */
.term-line {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
  line-height: 1.6;
  word-break: break-word;
}

.category-row {
  display: flex;
  margin-top: 4rpx;
  margin-bottom: 8rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.level,
.category-badge,
.tag {
  font-size: 22rpx;
  color: var(--text-secondary);
  background: var(--bg-surface);
  border: 1rpx solid var(--divider-color);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
}

.category-badge {
  font-size: 24rpx;
  font-weight: 500;
}

.tag {
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

/* ===== Sections ===== */
.section-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary) !important;
  margin-bottom: 16rpx;
}

.paragraph {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  word-break: break-word;
}

/* ===== Copy example ===== */
.copy-example-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 20rpx;
  margin-top: 16rpx;
  background: var(--bg-surface);
  border: 1rpx solid var(--border-color);
  border-radius: 14rpx;
  align-self: flex-start;
}

.copy-example-icon { font-size: 28rpx; margin-right: 8rpx; }
.copy-example-text { font-size: 26rpx; color: var(--text-secondary); }

/* ===== Favorite button ===== */
.favorite-btn {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
  border-radius: 22rpx;
  margin: 40rpx 30rpx;
  padding: 28rpx 32rpx;
  box-shadow: var(--shadow-sm);
}

.favorite-btn-active {
  background: var(--active-bg);
  border-color: var(--border-strong);
}

.favorite-star {
  font-size: 40rpx;
  color: var(--text-primary);
  margin-right: 16rpx;
  flex-shrink: 0;
  width: 48rpx;
  text-align: center;
}

.favorite-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.favorite-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary) !important;
  margin-bottom: 4rpx;
}

.favorite-hint {
  font-size: 22rpx;
  color: var(--text-hint);
  line-height: 1.4;
}

/* ===== Learning tip ===== */
.learning-tip-card {
  border-left: 5rpx solid var(--border-strong);
}

.learning-tip-title {
  color: var(--text-primary) !important;
}

.learning-tip-text {
  color: var(--text-secondary) !important;
  font-size: 26rpx !important;
}

/* ===== Related terms ===== */
.related-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--divider-color);
}

.related-item:last-child { border-bottom: none; }

.related-main { flex: 1; min-width: 0; }

.related-term {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.related-trans {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  word-break: break-word;
}

.related-arrow {
  font-size: 28rpx;
  color: var(--text-hint);
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* ===== Notes ===== */
.note-input {
  width: 100%;
  min-height: 160rpx;
  padding: 16rpx;
  margin-top: 16rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  background: var(--bg-surface);
  box-sizing: border-box;
}

.note-save-btn {
  margin-top: 16rpx;
  padding: 12rpx 32rpx;
  background: var(--text-primary);
  border: 1rpx solid var(--text-primary);
  border-radius: 999rpx;
  text-align: center;
}

.note-save-text {
  font-size: 26rpx;
  color: var(--text-inverse);
}

/* ===== R6 Quiet Paper shell ===== */
.term-detail {
  background: var(--qp-color-canvas);
  color: var(--qp-color-ink);
  letter-spacing: 0;
}

.term-detail .back-nav {
  margin-top: var(--qp-space-3);
}

.term-detail .card,
.term-detail .favorite-btn {
  background: var(--qp-color-surface);
  border: var(--qp-border-width) solid var(--qp-color-line);
  border-radius: var(--qp-radius-lg);
  box-shadow: none;
}

.term-detail .card:first-of-type {
  border-top: 4rpx solid var(--qp-color-editorial);
}

.term-detail .term-main {
  font-size: var(--qp-font-size-page-title);
  font-weight: var(--qp-font-weight-semibold);
  color: var(--qp-color-ink);
}

.term-detail .section-title,
.term-detail .favorite-text,
.term-detail .related-term {
  color: var(--qp-color-ink) !important;
}

.term-detail .back-arrow,
.term-detail .back-text,
.term-detail .term-line,
.term-detail .paragraph,
.term-detail .favorite-hint,
.term-detail .related-trans {
  color: var(--qp-color-text-secondary);
}

.term-detail .level,
.term-detail .category-badge,
.term-detail .tag,
.term-detail .copy-term-btn,
.term-detail .copy-example-btn,
.term-detail .note-input {
  background: var(--qp-color-surface-muted);
  border-color: var(--qp-color-line);
  border-radius: var(--qp-radius-tag);
}

.term-detail .favorite-btn-active {
  background: var(--qp-color-primary-soft);
  border-color: var(--qp-color-line-strong);
}

.term-detail .note-save-btn {
  background: var(--qp-color-primary);
  border-color: var(--qp-color-primary);
}
