.page {
  padding: 20rpx 0 60rpx;
  min-height: 100vh;
}

/* 返回导航 (Round 3.23) */
.back-nav {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  margin-bottom: 8rpx;
}

.back-arrow {
  font-size: 48rpx;
  color: #4a90d9;
  margin-right: 8rpx;
  line-height: 1;
}

.back-text {
  font-size: 28rpx;
  color: #4a90d9;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin: 16rpx 30rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.term-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

/* R3.56 复制术语按钮 */
.term-title-row {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.copy-term-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 12rpx;
  margin-left: 12rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.copy-term-icon {
  font-size: 28rpx;
}

.term-main {
  font-size: 44rpx;
  font-weight: 700;
  color: #333333;
}

.level {
  font-size: 22rpx;
  color: #e8913a;
  background-color: #fdf4e8;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
}

.term-line {
  display: block;
  font-size: 28rpx;
  color: #555555;
  margin-bottom: 10rpx;
  line-height: 1.6;
}

.category-row {
  display: flex;
  margin-top: 4rpx;
  margin-bottom: 8rpx;
}

.category-badge {
  font-size: 24rpx;
  color: #4a90d9;
  background-color: #eef5fd;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.tag {
  font-size: 22rpx;
  color: #666666;
  background-color: #f0f0f0;
  padding: 6rpx 18rpx;
  border-radius: 16rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.section-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #4a90d9;
  margin-bottom: 16rpx;
}

.paragraph {
  font-size: 28rpx;
  color: #444444;
  line-height: 1.8;
}

/* 收藏按钮 */
.favorite-btn {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 16rpx;
  margin: 40rpx 30rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.favorite-btn-active {
  background-color: #fff8e1;
  border: 1rpx solid #ffe082;
}

.favorite-star {
  font-size: 40rpx;
  color: #e8913a;
  margin-right: 16rpx;
  flex-shrink: 0;
  width: 48rpx;
  text-align: center;
}

.favorite-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.favorite-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #4a90d9;
  margin-bottom: 4rpx;
}

.favorite-hint {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.4;
}

/* 学习建议卡片 */
.learning-tip-card {
  border-left: 6rpx solid #4a90d9;
}

.learning-tip-title {
  color: #4a90d9 !important;
}

.learning-tip-text {
  color: #555555 !important;
  font-size: 26rpx !important;
}

/* R3.39 相关术语推荐 */
.related-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.related-item:last-child {
  border-bottom: none;
}

.related-main {
  flex: 1;
  min-width: 0;
}

.related-term {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 6rpx;
}

.related-trans {
  display: block;
  font-size: 24rpx;
  color: #888888;
}

.related-arrow {
  font-size: 28rpx;
  color: #cccccc;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* R3.49 学习笔记 */
.note-input {
  width: 100%;
  min-height: 160rpx;
  padding: 16rpx;
  margin-top: 16rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333333;
  box-sizing: border-box;
}

.note-save-btn {
  margin-top: 16rpx;
  padding: 12rpx 32rpx;
  background: #4caf50;
  border-radius: 8rpx;
  text-align: center;
}

.note-save-text {
  font-size: 26rpx;
  color: #ffffff;
}
