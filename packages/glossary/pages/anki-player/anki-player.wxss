/* anki-player.wxss */
/* Round 3.134: Anki 首屏重排 + 闪卡视觉升级 */

page{overflow:hidden}
.container{display:flex;flex-direction:column;height:100vh;background:linear-gradient(180deg,#1a2332 0%,#1e2d44 40%,var(--bg-color) 100%)}
.anki-header{padding:12rpx 24rpx 6rpx;flex-shrink:0;background:transparent}
.anki-category-label{font-size:26rpx;color:#8bb4d8;text-align:center;margin-bottom:8rpx;font-weight:600}
.anki-header-row{display:flex;align-items:flex-end;justify-content:flex-start;gap:20rpx;margin-bottom:8rpx}
.anki-info-block{display:flex;flex-direction:column;align-items:flex-start}
.anki-info-label{font-size:18rpx;color:rgba(255,255,255,0.5);font-weight:500;margin-bottom:2rpx}
.anki-info-value{font-size:28rpx;font-weight:800;color:#ffffff}
.anki-info-sep{font-weight:400;color:rgba(255,255,255,0.4);margin:0 2rpx}
.anki-info-mastered{color:#69db7c}
.anki-info-category{color:#8bb4d8;font-size:24rpx}
.anki-stats{display:flex;align-items:center;justify-content:center;margin-bottom:8rpx}
.anki-stat{font-size:26rpx;color:var(--text-secondary);font-weight:500}
.anki-stat-sep{font-size:24rpx;color:var(--border-color);margin:0 16rpx}
.anki-stat-value{font-weight:800;color:var(--text-primary);font-size:30rpx}
.anki-stat-mastered{color:#4caf50}
.anki-progress-bar{height:6rpx;background:rgba(255,255,255,0.08);border-radius:3rpx;overflow:hidden;margin-top:4rpx;position:relative}
.anki-progress-fill{height:100%;background:linear-gradient(90deg,#4a90d9,#36d1dc,#4ac4e0);border-radius:3rpx;transition:width 0.4s cubic-bezier(0.4,0,0.2,1);box-shadow:0 0 8rpx rgba(74,144,217,0.35);position:relative}
.anki-progress-fill::after{content:'';position:absolute;right:0;top:0;bottom:0;width:16rpx;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.3));border-radius:0 3rpx 3rpx 0}
.card-area{flex:1;display:flex;align-items:center;justify-content:center;padding:4rpx 24rpx 0;perspective:1200px;overflow:hidden}
.card-swipe{width:100%;height:560rpx;transition:transform 0.3s,opacity 0.3s}
.card-inner{width:100%;height:100%;position:relative;transition:transform 0.6s cubic-bezier(0.4,0,0.2,1);transform-style:preserve-3d;border-radius:24rpx}
.card-inner.flipped{transform:rotateY(180deg)}
.card-face{position:absolute;width:100%;height:100%;backface-visibility:hidden;-webkit-backface-visibility:hidden;border-radius:24rpx;background-color:var(--card-bg);box-shadow:0 12rpx 40rpx rgba(0,0,0,0.2),0 4rpx 12rpx rgba(74,144,217,0.08);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40rpx;box-sizing:border-box;border:1rpx solid rgba(74,144,217,0.1)}
.card-front{background:linear-gradient(180deg,#ffffff 0%,#f8faff 92%,rgba(74,144,217,0.06) 100%);border-top:4rpx solid #4a90d9}
.card-back{transform:rotateY(180deg);justify-content:flex-start;padding-top:60rpx;overflow-y:auto;background:linear-gradient(180deg,#ffffff 0%,#f8fff8 92%,rgba(76,175,80,0.06) 100%);border-top:4rpx solid #4caf50}
.card-term{font-size:56rpx;font-weight:800;color:var(--text-primary);text-align:center;margin-bottom:16rpx;word-break:break-word;letter-spacing:2rpx}
.card-ja-reading{font-size:30rpx;color:var(--text-secondary);text-align:center;word-break:break-word;letter-spacing:1rpx}
.card-hint{position:absolute;bottom:28rpx;font-size:20rpx;color:var(--text-hint);background-color:rgba(74,144,217,0.06);padding:6rpx 20rpx;border-radius:20rpx;letter-spacing:1rpx}
.card-section-label{display:block;font-size:22rpx;font-weight:600;color:#4a90d9;margin-bottom:8rpx;margin-top:20rpx;width:100%;padding-bottom:6rpx;border-bottom:1rpx solid rgba(74,144,217,0.12)}
.card-section-label:first-child{margin-top:0}
.card-zh{display:block;font-size:38rpx;font-weight:700;color:var(--text-primary);line-height:1.5;width:100%;margin-bottom:12rpx;word-break:break-word;letter-spacing:1rpx}
.card-ja{display:block;font-size:26rpx;color:var(--text-secondary);line-height:1.7;width:100%;word-break:break-word;background-color:rgba(74,144,217,0.04);border-radius:12rpx;padding:16rpx;margin-top:8rpx;border:1rpx solid rgba(74,144,217,0.06)}
.action-bar{display:flex;align-items:center;justify-content:center;gap:20rpx;padding:12rpx 24rpx 32rpx;flex-shrink:0;background:linear-gradient(0deg,rgba(0,0,0,0.03) 0%,transparent 100%)}
.action-btn{flex:1;max-width:320rpx;height:84rpx;border-radius:42rpx;display:flex;flex-direction:row;align-items:center;justify-content:center;gap:8rpx;transition:transform 0.15s,box-shadow 0.15s}
.action-btn:active{transform:scale(0.96)}
.action-btn-forgot{background:linear-gradient(135deg,#f44336,#e53935);box-shadow:0 4rpx 16rpx rgba(244,67,54,0.3)}
.action-btn-mastered{background:linear-gradient(135deg,#4caf50,#43a047);box-shadow:0 4rpx 16rpx rgba(76,175,80,0.3)}
.action-btn-icon{font-size:32rpx;color:#fff;font-weight:700}
.action-btn-label{font-size:26rpx;color:#fff;font-weight:600;letter-spacing:1rpx}
.complete-section{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40rpx}
.complete-icon{font-size:100rpx;margin-bottom:24rpx}
.complete-title{font-size:40rpx;font-weight:700;color:var(--text-primary);margin-bottom:12rpx}
.complete-desc{font-size:28rpx;color:var(--text-secondary);margin-bottom:40rpx}
.complete-btn{background-color:#4a90d9;border-radius:40rpx;padding:24rpx 80rpx;font-size:30rpx;color:#fff;font-weight:600;box-shadow:0 4rpx 16rpx rgba(74,144,217,0.3)}
.empty-section{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40rpx}
.empty-icon{font-size:100rpx;margin-bottom:24rpx}
.empty-text{font-size:32rpx;color:var(--text-primary);margin-bottom:12rpx}
.empty-hint{font-size:26rpx;color:var(--text-hint);text-align:center;margin-bottom:40rpx;line-height:1.6}
.empty-btn{background-color:#4a90d9;border-radius:40rpx;padding:24rpx 60rpx;font-size:28rpx;color:#fff;font-weight:600;box-shadow:0 4rpx 16rpx rgba(74,144,217,0.3)}

/* 筛选栏 */
.anki-filter-btn { margin-left:auto; width:52rpx; height:52rpx; display:flex; align-items:center; justify-content:center; flex-shrink:0; border-radius:12rpx; background-color:rgba(255,255,255,0.08); transition:background-color 0.15s; }
.anki-filter-btn:active { background-color:rgba(255,255,255,0.16); }
.anki-filter-icon { font-size:28rpx; color:#8bb4d8; }
.anki-filter-bar { margin-top:8rpx; padding:8rpx 0 4rpx; border-top:1rpx solid rgba(255,255,255,0.08); }
.anki-filter-scroll { white-space:nowrap; width:100%; }
.anki-filter-tag { display:inline-flex; align-items:center; justify-content:center; padding:8rpx 20rpx; border-radius:20rpx; background-color:rgba(255,255,255,0.06); margin-right:10rpx; font-size:22rpx; color:rgba(255,255,255,0.6); flex-shrink:0; transition:all 0.15s; }
.anki-filter-tag:active { transform:scale(0.95); }
.anki-filter-tag-active { background:linear-gradient(135deg,#4a90d9,#36d1dc); color:#fff; font-weight:600; box-shadow:0 2rpx 8rpx rgba(74,144,217,0.3); }

/* 循环计数 */
.card-loop-badge{position:absolute;top:20rpx;right:20rpx;font-size:22rpx;color:#e8913a;background-color:rgba(232,145,58,0.12);padding:4rpx 16rpx;border-radius:20rpx;font-weight:600;border:1rpx solid rgba(232,145,58,0.2)}

/* 结算看板 */
.summary-card{background-color:var(--card-bg);border-radius:24rpx;margin:30rpx;padding:36rpx;box-shadow:0 4rpx 24rpx rgba(0,0,0,0.12)}
.summary-title{display:block;font-size:36rpx;font-weight:700;color:var(--text-primary);text-align:center;margin-bottom:28rpx}
.summary-grid{display:flex;flex-wrap:wrap;gap:16rpx;margin-bottom:24rpx}
.summary-item{flex:1;min-width:40%;background-color:var(--bg-color);border-radius:16rpx;padding:20rpx 16rpx;display:flex;flex-direction:column;align-items:center}
.summary-value{font-size:44rpx;font-weight:800;color:var(--text-primary);margin-bottom:6rpx}
.summary-value-brand{color:#4a90d9}
.summary-value-green{color:#4caf50}
.summary-label{font-size:22rpx;color:var(--text-hint)}
.summary-timer{display:flex;align-items:center;justify-content:center;margin-bottom:28rpx;gap:8rpx}
.summary-timer-label{font-size:24rpx;color:var(--text-secondary)}
.summary-timer-value{font-size:36rpx;font-weight:700;color:var(--text-primary);font-family:monospace}
.summary-actions{display:flex;flex-direction:column;gap:16rpx}
.summary-btn{border-radius:40rpx;padding:24rpx;text-align:center;font-size:30rpx;font-weight:600}
.summary-btn-primary{background-color:#4a90d9;color:#fff;box-shadow:0 4rpx 16rpx rgba(74,144,217,0.3)}
.summary-btn-secondary{background-color:var(--divider-color);color:var(--text-secondary)}

/* 加载与错误状态 */
.loading-section{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40rpx}
.loading-icon{font-size:80rpx;margin-bottom:24rpx}
.loading-text{font-size:28rpx;color:var(--text-secondary)}
.error-section{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40rpx}
.error-icon{font-size:80rpx;margin-bottom:24rpx}
.error-text{font-size:28rpx;color:var(--text-secondary);margin-bottom:40rpx;text-align:center}
.error-btn{background-color:#4a90d9;border-radius:40rpx;padding:24rpx 60rpx;font-size:28rpx;color:#fff;font-weight:600}

/* 深色模式适配 */
@media (prefers-color-scheme: dark) {
  .container {
    background: linear-gradient(180deg, #0d1b2a 0%, #1a2a3e 40%, var(--bg-color) 100%);
  }
  .anki-filter-btn {
    background-color: rgba(255, 255, 255, 0.06);
  }
  .anki-filter-icon {
    color: #58a6ff;
  }
  .anki-filter-bar {
    border-top-color: rgba(255, 255, 255, 0.06);
  }
  .anki-filter-tag {
    background-color: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.5);
  }
  .card-front {
    background: linear-gradient(180deg, var(--card-bg) 0%, #1e2840 92%, rgba(74, 144, 217, 0.08) 100%);
  }
  .card-back {
    background: linear-gradient(180deg, var(--card-bg) 0%, #1e2840 92%, rgba(76, 175, 80, 0.08) 100%);
  }
}
