/* anki-player.wxss — monochrome flashcard review */

page { overflow: hidden; }

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-color);
}

/* ===== Header ===== */
.anki-header { padding: 18rpx 24rpx 8rpx; flex-shrink: 0; background: transparent; }

.anki-category-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: 8rpx;
  font-weight: 600;
}

.anki-header-row {
  display: flex;
  align-items: flex-end;
  justify-content: flex-start;
  gap: 20rpx;
  margin-bottom: 8rpx;
}

.anki-info-block { display: flex; flex-direction: column; align-items: flex-start; }

.anki-info-label { font-size: 18rpx; color: var(--text-hint); font-weight: 500; margin-bottom: 2rpx; }

.anki-info-value,
.anki-info-mastered,
.anki-info-category {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.anki-info-sep { font-weight: 400; color: var(--border-color); margin: 0 2rpx; }
.anki-info-category { font-size: 24rpx; }

.anki-stats { display: flex; align-items: center; justify-content: center; margin-bottom: 8rpx; }
.anki-stat { font-size: 26rpx; color: var(--text-secondary); font-weight: 500; }
.anki-stat-sep { font-size: 24rpx; color: var(--border-color); margin: 0 16rpx; }
.anki-stat-value { font-weight: 800; color: var(--text-primary); font-size: 30rpx; }
.anki-stat-mastered { color: var(--color-success); }

.anki-progress-bar { height: 6rpx; background: var(--divider-color); border-radius: 3rpx; overflow: hidden; margin-top: 4rpx; position: relative; }

.anki-progress-fill {
  height: 100%;
  background: var(--text-primary);
  border-radius: 3rpx;
  transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
}

/* ===== Card area ===== */
.card-area { flex: 1; display: flex; align-items: center; justify-content: center; padding: 4rpx 24rpx 0; perspective: 1200px; overflow: hidden; }
.card-swipe { width: 100%; height: 560rpx; transition: transform 0.3s, opacity 0.3s; }

.card-inner {
  width: 100%;
  height: 100%;
  position: relative;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  transform-style: preserve-3d;
  border-radius: 24rpx;
}

.card-inner.flipped { transform: rotateY(180deg); }

/* ===== Card faces ===== */
.card-face {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  border-radius: 24rpx;
  box-shadow: var(--shadow-md);
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  overflow: hidden;
}

.card-front,
.card-back {
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
}

.card-back { transform: rotateY(180deg); }

.card-front::before,
.card-back::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3rpx;
  background: var(--border-strong);
  border-radius: 24rpx 24rpx 0 0;
}

/* ===== Card front ===== */
.card-front-top { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 28rpx 0; flex-shrink: 0; }

.card-category-tag,
.card-index-badge,
.card-loop-badge,
.card-hint {
  color: var(--text-secondary);
  background: var(--bg-surface);
  border: 1rpx solid var(--divider-color);
}

.card-category-tag { font-size: 20rpx; padding: 7rpx 18rpx; border-radius: 13rpx; font-weight: 650; letter-spacing: 1rpx; }
.card-index-badge { font-size: 20rpx; font-weight: 600; font-family: monospace; padding: 4rpx 14rpx; border-radius: 10rpx; }
.card-index-badge-back { color: var(--text-secondary); background: var(--bg-surface); }

.card-front-center { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 0 40rpx; }

.card-term { font-size: 56rpx; font-weight: 800; color: var(--text-primary); text-align: center; margin-bottom: 16rpx; word-break: break-word; }
.card-ja-reading { font-size: 30rpx; color: var(--text-secondary); text-align: center; word-break: break-word; letter-spacing: 1rpx; margin-top: 4rpx; }

.card-loop-badge { position: absolute; top: 24rpx; right: 28rpx; font-size: 20rpx; padding: 4rpx 14rpx; border-radius: 16rpx; font-weight: 600; }

.card-front-bottom { flex-shrink: 0; padding: 0 28rpx 28rpx; display: flex; justify-content: center; }

.card-hint { font-size: 21rpx; padding: 9rpx 30rpx; border-radius: 24rpx; letter-spacing: 2rpx; font-weight: 600; }

/* ===== Card back ===== */
.card-back-header { display: flex; align-items: center; gap: 10rpx; padding: 20rpx 28rpx 0; flex-shrink: 0; }
.card-back-icon { font-size: 28rpx; }

.card-back-symbol {
  width: 28rpx;
  height: 28rpx;
  border: 2rpx solid var(--text-secondary);
  border-radius: 8rpx;
  position: relative;
}

.card-back-symbol::before {
  content: '';
  position: absolute;
  left: 7rpx; right: 7rpx; top: 12rpx;
  height: 2rpx;
  background: var(--text-secondary);
}

.card-back-label { font-size: 22rpx; font-weight: 700; color: var(--text-primary); letter-spacing: 2rpx; }

.card-back-body { flex: 1; overflow-y: auto; padding: 16rpx 28rpx 28rpx; -webkit-overflow-scrolling: touch; }
.card-back-section { margin-bottom: 20rpx; }
.card-back-section:last-child { margin-bottom: 0; }

.card-section-label {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
  padding-bottom: 6rpx;
  border-bottom: 1rpx solid var(--divider-color);
  letter-spacing: 1rpx;
}

.card-section-label-green { color: var(--text-secondary); border-bottom-color: var(--divider-color); }

.card-zh { display: block; font-size: 36rpx; font-weight: 700; color: var(--text-primary); line-height: 1.5; word-break: break-word; letter-spacing: 1rpx; }

.card-ja {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  word-break: break-word;
  background: var(--bg-surface);
  border: 1rpx solid var(--divider-color);
  border-radius: 14rpx;
  padding: 16rpx;
  margin-top: 8rpx;
}

/* ===== Action bar ===== */
.action-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 16rpx 30rpx 40rpx;
  flex-shrink: 0;
  background: var(--card-bg);
  border-top: 1rpx solid var(--border-color);
}

.action-btn {
  flex: 1;
  max-width: 320rpx;
  height: 92rpx;
  border-radius: 22rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  transition: transform 0.12s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.12s;
  position: relative;
  overflow: hidden;
}

.action-btn:active { transform: translateY(2rpx) scale(0.955); }

.action-btn-forgot,
.action-btn-mastered {
  background: var(--card-bg);
  border: 1rpx solid var(--border-strong);
  box-shadow: var(--shadow-sm);
}

.action-btn-forgot .action-btn-icon,
.action-btn-forgot .action-btn-label { color: var(--color-error); }

.action-btn-mastered .action-btn-icon,
.action-btn-mastered .action-btn-label { color: var(--color-success); }

.action-btn-icon { font-size: 34rpx; font-weight: 700; }
.action-btn-label { font-size: 28rpx; font-weight: 700; letter-spacing: 2rpx; }

/* ===== Filter bar ===== */
.anki-filter-btn {
  margin-left: auto;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 12rpx;
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
  color: var(--text-secondary);
  transition: background-color 0.15s;
}

.anki-filter-btn:active,
.anki-filter-tag:active,
.summary-btn:active {
  transform: translateY(2rpx) scale(0.97);
  opacity: 0.9;
}

.anki-filter-icon { font-size: 28rpx; color: var(--text-secondary); }

.anki-filter-bar { margin-top: 8rpx; padding: 8rpx 0 4rpx; border-top: 1rpx solid var(--divider-color); }
.anki-filter-scroll { white-space: nowrap; width: 100%; }

.anki-filter-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height:44rpx;
  padding: 8rpx 22rpx;
  white-space:nowrap;
  border-radius: 22rpx;
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
  margin-right: 10rpx;
  font-size: 23rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
  box-sizing: border-box;
  white-space: nowrap;
}

.anki-filter-tag-active {
  background: var(--active-bg);
  color: var(--text-primary);
  border-color: var(--border-strong);
  box-shadow: none;
}

/* ===== Completion ===== */
.complete-section { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40rpx; background: var(--bg-color); }
.complete-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.complete-title { font-size: 40rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 12rpx; }
.complete-desc { font-size: 28rpx; color: var(--text-secondary); margin-bottom: 40rpx; }

.complete-btn { background: var(--text-primary); border: 1rpx solid var(--text-primary); border-radius: 44rpx; padding: 24rpx 80rpx; font-size: 30rpx; color: var(--text-inverse); font-weight: 600; box-shadow: var(--shadow-md); }

/* ===== Summary card ===== */
.summary-card,
.empty-section,
.loading-section,
.error-section {
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
  border-radius: 26rpx;
  backdrop-filter:blur(10px);
  box-shadow: var(--shadow-sm);
}

.summary-card { margin: 30rpx; padding: 36rpx; }

.summary-title { display: block; font-size: 36rpx; font-weight: 700; color: var(--text-primary); text-align: center; margin-bottom: 28rpx; }
.summary-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; margin-bottom: 24rpx; }

.summary-item { background: var(--bg-surface); border: 1rpx solid var(--divider-color); border-radius: 16rpx; padding: 20rpx 16rpx; display: flex; flex-direction: column; align-items: center; }

.summary-value { font-size: 44rpx; font-weight: 800; color: var(--text-primary); margin-bottom: 6rpx; }
.summary-value-brand { color: var(--text-primary); }
.summary-value-green { color: var(--text-primary); }

.summary-label { font-size: 22rpx; color: var(--text-secondary); }

.summary-timer { display: flex; align-items: center; justify-content: center; margin-bottom: 28rpx; gap: 8rpx; }
.summary-timer-label { font-size: 24rpx; color: var(--text-secondary); }
.summary-timer-value { font-size: 36rpx; font-weight: 700; color: var(--text-primary); font-family: monospace; }

.summary-actions { display: flex; flex-direction: column; gap: 16rpx; }

.summary-btn { border-radius: 40rpx; padding: 24rpx; text-align: center; font-size: 30rpx; font-weight: 600; }

.summary-btn-primary,
.empty-btn,
.error-btn {
  background: var(--text-primary);
  border: 1rpx solid var(--text-primary);
  color: var(--text-inverse);
  box-shadow: var(--shadow-md);
}

.summary-btn-secondary { background: var(--card-bg); border: 1rpx solid var(--border-color); color: var(--text-primary); }

/* ===== Empty / Loading / Error ===== */
.empty-section { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; margin: 40rpx; padding: 44rpx; }
.empty-icon { display: flex; align-items: center; justify-content: center; width: 112rpx; height: 112rpx; border-radius: 30rpx; font-size: 64rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 32rpx; color: var(--text-primary); margin-bottom: 12rpx; font-weight: 700; }
.empty-hint { font-size: 26rpx; color: var(--text-secondary); text-align: center; margin-bottom: 40rpx; line-height: 1.6; }

.empty-btn { display: flex; align-items: center; justify-content: center; min-height: 88rpx; border-radius: 44rpx; padding: 0 60rpx; font-size: 28rpx; font-weight: 600; transition: transform 0.12s ease, opacity 0.12s ease; }
.empty-btn:active { transform: translateY(2rpx) scale(0.985); opacity: 0.9; }

.loading-section,
.error-section { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40rpx; }
.loading-icon,
.error-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.loading-text,
.error-text { font-size: 28rpx; color: var(--text-secondary); }
.error-text { margin-bottom: 40rpx; text-align: center; }
.error-btn { border-radius: 44rpx; padding: 24rpx 60rpx; font-size: 28rpx; font-weight: 600; }

/* ===== Geometric symbols ===== */
.loading-symbol,
.error-symbol,
.empty-symbol {
  width: 82rpx;
  height: 82rpx;
  border: 3rpx solid var(--text-hint);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  position: relative;
}

.loading-symbol::before,
.error-symbol::before,
.empty-symbol::before {
  content: '';
  position: absolute;
  left: 22rpx; right: 22rpx; top: 39rpx;
  height: 3rpx;
  background: var(--text-hint);
}

.loading-symbol::after,
.error-symbol::after,
.empty-symbol::after {
  content: '';
  position: absolute;
  top: 22rpx; bottom: 22rpx; left: 39rpx;
  width: 3rpx;
  background: var(--text-hint);
}
