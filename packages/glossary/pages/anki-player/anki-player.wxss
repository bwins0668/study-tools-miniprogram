/* anki-player.wxss */
page{overflow:hidden}
.container{display:flex;flex-direction:column;height:100vh;background-color:var(--bg-color)}
.anki-header{padding:20rpx 30rpx 10rpx;flex-shrink:0}
.anki-stats{display:flex;align-items:center;justify-content:center;margin-bottom:12rpx}
.anki-stat{font-size:28rpx;color:var(--text-secondary)}
.anki-stat-sep{font-size:28rpx;color:var(--border-color);margin:0 20rpx}
.anki-stat-value{font-weight:700;color:var(--text-primary)}
.anki-stat-mastered{color:#4caf50}
.anki-progress-bar{height:6rpx;background-color:var(--border-color);border-radius:3rpx;overflow:hidden}
.anki-progress-fill{height:100%;background:linear-gradient(90deg,#4a90d9,#58a6ff);border-radius:3rpx;transition:width 0.3s}
.card-area{flex:1;display:flex;align-items:center;justify-content:center;padding:20rpx 30rpx;perspective:1200px;overflow:hidden}
.card-swipe{width:100%;height:540rpx;transition:transform 0.3s,opacity 0.3s}
.card-inner{width:100%;height:100%;position:relative;transition:transform 0.6s cubic-bezier(0.4,0,0.2,1);transform-style:preserve-3d;border-radius:24rpx}
.card-inner.flipped{transform:rotateY(180deg)}
.card-face{position:absolute;width:100%;height:100%;backface-visibility:hidden;-webkit-backface-visibility:hidden;border-radius:24rpx;background-color:var(--card-bg);box-shadow:0 4rpx 24rpx rgba(0,0,0,0.1);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40rpx;box-sizing:border-box}
.card-back{transform:rotateY(180deg);justify-content:flex-start;padding-top:60rpx;overflow-y:auto}
.card-term{font-size:48rpx;font-weight:700;color:var(--text-primary);text-align:center;margin-bottom:16rpx;word-break:break-word}
.card-ja-reading{font-size:32rpx;color:var(--text-secondary);text-align:center;word-break:break-word}
.card-hint{position:absolute;bottom:32rpx;font-size:22rpx;color:var(--text-hint)}
.card-section-label{display:block;font-size:22rpx;font-weight:600;color:#4a90d9;margin-bottom:8rpx;margin-top:20rpx;width:100%}
.card-section-label:first-child{margin-top:0}
.card-zh{display:block;font-size:36rpx;font-weight:600;color:var(--text-primary);line-height:1.5;width:100%;margin-bottom:8rpx;word-break:break-word}
.card-ja{display:block;font-size:28rpx;color:var(--text-secondary);line-height:1.6;width:100%;word-break:break-word}
.action-bar{display:flex;align-items:center;justify-content:center;gap:60rpx;padding:30rpx 30rpx 50rpx;flex-shrink:0}
.action-btn{width:140rpx;height:140rpx;border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;box-shadow:0 4rpx 16rpx rgba(0,0,0,0.1)}
.action-btn-forgot{background-color:#f44336}
.action-btn-mastered{background-color:#4caf50}
.action-btn-icon{font-size:40rpx;color:#fff;font-weight:700;margin-bottom:4rpx}
.action-btn-label{font-size:22rpx;color:#fff;font-weight:500}
.complete-section{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40rpx}
.complete-icon{font-size:100rpx;margin-bottom:24rpx}
.complete-title{font-size:40rpx;font-weight:700;color:var(--text-primary);margin-bottom:12rpx}
.complete-desc{font-size:28rpx;color:var(--text-secondary);margin-bottom:40rpx}
.complete-btn{background-color:#4a90d9;border-radius:40rpx;padding:24rpx 80rpx;font-size:30rpx;color:#fff;font-weight:600;box-shadow:0 4rpx 16rpx rgba(74,144,217,0.3)}
.empty-section{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40rpx}
.empty-icon{font-size:100rpx;margin-bottom:24rpx}
.empty-text{font-size:32rpx;color:var(--text-primary);margin-bottom:12rpx}
.empty-hint{font-size:26rpx;color:var(--text-hint);text-align:center;margin-bottom:40rpx;line-height:1.6}
.empty-btn{background-color:#4a90d9;border-radius:40rpx;padding:24rpx 60rpx;font-size:28rpx;color:#fff;font-weight:600;box-shadow:0 4rpx 16rpx rgba(74,144,217,0.3)}

/* 筛选栏 */
.anki-filter-btn { margin-left:auto; width:56rpx; height:56rpx; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.anki-filter-icon { font-size:32rpx; }
.anki-filter-bar { margin-top:12rpx; padding:6rpx 0; border-top:1rpx solid var(--border-color); }
.anki-filter-scroll { white-space:nowrap; width:100%; }
.anki-filter-tag { display:inline-flex; align-items:center; justify-content:center; padding:10rpx 24rpx; border-radius:24rpx; background-color:var(--divider-color); margin-right:12rpx; font-size:24rpx; color:var(--text-secondary); flex-shrink:0; }
.anki-filter-tag-active { background-color:#4a90d9; color:#fff; font-weight:600; }

/* 循环计数 */
.card-loop-badge{position:absolute;top:20rpx;right:20rpx;font-size:22rpx;color:#e8913a;background-color:rgba(232,145,58,0.12);padding:4rpx 16rpx;border-radius:20rpx;font-weight:600}
