<view class="container">
  <view class="anki-header" wx:if="{{totalCount > 0 && !isComplete}}">
    <view class="anki-stats">
      <text class="anki-stat">{{currentIndex + 1}} / {{totalCount}}</text>
      <text class="anki-stat-sep">|</text>
      <text class="anki-stat">已掌握 <text class="anki-stat-value anki-stat-mastered">{{masteredCount}}</text></text>
      <view class="anki-filter-btn" bindtap="toggleFilter" wx:if="{{dataSource === 'glossary'}}">
        <text class="anki-filter-icon">{{showFilter ? '✕' : '☰'}}</text>
      </view>
    </view>
    <view class="anki-progress-bar">
      <view class="anki-progress-fill" style="width: {{progressPercent}}%"></view>
    </view>
    <view class="anki-filter-bar" wx:if="{{showFilter && dataSource === 'glossary'}}">
      <scroll-view class="anki-filter-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="anki-filter-tag {{selectedCategory === 'all' ? 'anki-filter-tag-active' : ''}}"
          data-category="all" bindtap="selectCategory"><text>全部</text></view>
        <view wx:for="{{categories}}" wx:key="*this" class="anki-filter-tag {{selectedCategory === item ? 'anki-filter-tag-active' : ''}}"
          data-category="{{item}}" bindtap="selectCategory"><text>{{item}}</text></view>
      </scroll-view>
    </view>
  </view>
  <view class="card-area" wx:if="{{!isComplete && totalCount > 0}}"
    bindtouchstart="onTouchStart" bindtouchmove="onTouchMove" bindtouchend="onTouchEnd">
    <view class="card-swipe" style="{{swipeStyle}}">
      <view class="card-inner {{isFlipped ? 'flipped' : ''}}" bindtap="toggleFlip">
        <view class="card-face card-front">
          <text class="card-term">{{currentTerm.term}}</text>
          <text class="card-ja-reading" wx:if="{{currentTerm.reading}}">{{currentTerm.reading}}</text>
          <text class="card-loop-badge" wx:if="{{currentTerm.loopCount > 0}}">↺ {{currentTerm.loopCount}}</text>
          <text class="card-hint" wx:if="{{!isFlipped}}">点击翻牌</text>
        </view>
        <view class="card-face card-back">
          <text class="card-section-label">中文释义</text>
          <text class="card-zh">{{currentTerm.zh}}</text>
          <text class="card-section-label" wx:if="{{currentTerm.ja}}">日本語 / 解析</text>
          <text class="card-ja" wx:if="{{currentTerm.ja}}">{{currentTerm.ja}}</text>
        </view>
      </view>
    </view>
  </view>
  <view class="action-bar" wx:if="{{!isComplete && totalCount > 0}}">
    <view class="action-btn action-btn-forgot" catchtap="markForgot">
      <text class="action-btn-icon">✕</text>
      <text class="action-btn-label">未记住</text>
    </view>
    <view class="action-btn action-btn-mastered" catchtap="markMastered">
      <text class="action-btn-icon">✓</text>
      <text class="action-btn-label">已记住</text>
    </view>
  </view>
  <view class="complete-section" wx:if="{{isComplete && totalCount === 0}}">
    <view class="summary-card" wx:if="{{summary}}">
      <text class="summary-title">🎉 会话结算</text>
      <view class="summary-grid">
        <view class="summary-item">
          <text class="summary-value summary-value-brand">{{summary.totalCards}}</text>
          <text class="summary-label">复习总数</text>
        </view>
        <view class="summary-item">
          <text class="summary-value summary-value-brand">{{summary.accuracy}}%</text>
          <text class="summary-label">一记即中率</text>
        </view>
        <view class="summary-item">
          <text class="summary-value">{{summary.totalLoops}}</text>
          <text class="summary-label">循环次数</text>
        </view>
        <view class="summary-item" wx:if="{{dataSource === 'mistakes'}}">
          <text class="summary-value summary-value-green">{{summary.eliminated}}</text>
          <text class="summary-label">斩获错题</text>
        </view>
      </view>
      <view class="summary-timer">
        <text class="summary-timer-label">⏱ 用时</text>
        <text class="summary-timer-value">{{summary.elapsedStr}}</text>
      </view>
      <view class="summary-actions">
        <view class="summary-btn summary-btn-primary" catchtap="restartSession">再来一轮</view>
        <view class="summary-btn summary-btn-secondary" catchtap="goBack">返回菜单</view>
      </view>
    </view>
  </view>
  <view class="empty-section" wx:elif="{{totalCount === 0 && !isComplete}}">
    <text class="empty-icon">📚</text>
    <text class="empty-text" wx:if="{{dataSource === 'mistakes'}}">错题本空空如也</text>
    <text class="empty-text" wx:else>暂无待复习术语</text>
    <text class="empty-hint" wx:if="{{dataSource === 'mistakes'}}">太棒了！所有错题已攻克！</text>
    <text class="empty-hint" wx:else>切换分类试试，或浏览术语表后重新开始。</text>
    <view class="empty-btn" wx:if="{{dataSource === 'glossary'}}" bindtap="loadAllTerms">加载全部术语</view>
    <view class="empty-btn" wx:elif="{{dataSource === 'mistakes'}}" bindtap="goBack">返回</view>
  </view>
</view>
