/* pages/glossary/glossary.wxss */

.search-bar {
  padding: 20rpx 30rpx;
  position: sticky;
  top: 0;
  background-color: #f5f5f5;
  z-index: 10;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 48rpx;
  line-height: 48rpx;
}

.search-clear {
  font-size: 28rpx;
  color: #cccccc;
  padding: 8rpx;
  margin-left: 8rpx;
  flex-shrink: 0;
}

.result-count {
  padding: 8rpx 30rpx 0;
  font-size: 24rpx;
  color: #999999;
}

.list-hint {
  padding: 8rpx 30rpx 16rpx;
  font-size: 24rpx;
  color: #bbbbbb;
}

.glossary-list {
  padding: 10rpx 0 40rpx;
}

/* 术语卡片 */
.glossary-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin: 16rpx 30rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-main {
  display: flex;
  align-items: flex-start;
}

.card-left {
  flex: 1;
  min-width: 0;
}

.item-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.item-term {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.item-badges {
  display: flex;
  align-items: center;
}

.badge {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  margin-left: 8rpx;
}

.badge-category {
  color: #4a90d9;
  background-color: #eef4fc;
}

.badge-level {
  color: #e8913a;
  background-color: #fdf4e8;
}

.badge-fav {
  color: #e8913a;
  background-color: #fdf4e8;
}

.item-translations {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.item-zh {
  font-size: 28rpx;
  color: #555555;
}

.item-sep {
  font-size: 24rpx;
  color: #cccccc;
  margin: 0 12rpx;
}

.item-ja {
  font-size: 26rpx;
  color: #888888;
}

.item-explanation {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.6;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 详情提示 */
.card-detail-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  flex-shrink: 0;
  padding-top: 8rpx;
}

.detail-arrow {
  font-size: 32rpx;
  color: #cccccc;
}

.detail-label {
  font-size: 20rpx;
  color: #cccccc;
  margin-top: 2rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 30rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999999;
}

/* 搜索空状态增强 (Round 3.21) */
.empty-suggestions {
  margin-top: 20rpx;
  padding: 24rpx 32rpx;
  background-color: #f8f9fe;
  border-radius: 16rpx;
  border: 1rpx solid #e8ebf5;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  width: 100%;
  max-width: 500rpx;
  box-sizing: border-box;
}

.empty-suggestion-title {
  font-size: 26rpx;
  color: #666666;
  font-weight: 500;
  margin-bottom: 10rpx;
}

.empty-suggestion-item {
  font-size: 24rpx;
  color: #888888;
  line-height: 2;
}
