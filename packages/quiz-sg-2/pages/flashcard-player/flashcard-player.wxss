/* ============================================================
   flashcard-player.wxss — themed with app.wxss CSS variables
   Supports automatic light/dark via var() tokens
   All hardcoded colors replaced (R20)
   ============================================================ */

/* ---- Container ---- */
.fc-container {
  min-height: 100vh;
  padding: 24rpx 32rpx 160rpx;
  background: var(--bg-color);
}

/* ---- Loading ---- */
.fc-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 32rpx;
}
.fc-loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid var(--divider-color);
  border-top-color: var(--text-secondary);
  border-radius: 50%;
  animation: fc-spin .8s linear infinite;
}
@keyframes fc-spin { to { transform: rotate(360deg); } }
.fc-loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* ---- Error ---- */
.fc-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 32rpx;
}
.fc-error-icon {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--color-error);
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 50%;
  background: var(--color-error-light);
  margin-bottom: 24rpx;
}
.fc-error-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}
.fc-error-course {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}
.fc-error-detail {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 32rpx;
  text-align: center;
}
.fc-error-actions {
  display: flex;
  gap: 16rpx;
}

/* ---- Header ---- */
.fc-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.fc-header-left {
  display: flex;
  align-items: center;
}
.fc-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  margin-right: 12rpx;
  flex-shrink: 0;
}
.fc-badge-it { background: var(--text-primary); }
.fc-badge-sg { background: var(--text-secondary); }
.fc-header-info {
  display: flex;
  flex-direction: column;
}
.fc-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.3;
}
.fc-header-meta {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 2rpx;
}
.fc-deck-timer {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-variant-numeric: tabular-nums;
}

/* ---- Progress ---- */
.fc-progress {
  height: 4rpx;
  background: var(--divider-color);
  border-radius: 2rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
}
.fc-progress-bar {
  height: 100%;
  background: var(--text-primary);
  border-radius: 2rpx;
  transition: width .3s ease;
}

/* ---- Stats ---- */
.fc-stats {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}
.fc-stat { font-size: 24rpx; font-weight: 500; }
.fc-stat-correct { color: var(--color-success); }
.fc-stat-wrong { color: var(--color-error); }

/* ---- Question Card ---- */
.fc-card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}
.fc-front {
  border-left: 6rpx solid var(--text-primary);
}
.fc-question-text {
  display: block;
  font-size: 32rpx;
  line-height: 1.65;
  color: var(--text-primary);
  white-space: pre-wrap;
  word-break: break-word;
}
.fc-question-zh {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-secondary);
  margin-top: 12rpx;
  white-space: pre-wrap;
}

/* ---- Options ---- */
.fc-options { margin-bottom: 16rpx; }
.fc-option {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  margin-bottom: 10rpx;
  border-radius: 12rpx;
  background: var(--card-bg);
  border: 2rpx solid var(--border-color);
  transition: all .15s ease;
}
.fc-option:active {
  background: var(--press-bg);
  transform: scale(.985);
}
.fc-option-key {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--bg-surface);
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-right: 14rpx;
  flex-shrink: 0;
}
.fc-option-body {
  flex: 1;
  min-width: 0;
}
.fc-option-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--text-primary);
  word-break: break-word;
}
.fc-option-text-zh {
  display: block;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
  margin-top: 6rpx;
  word-break: break-word;
}
.fc-option-correct {
  border-color: var(--color-success);
  background: var(--color-success-light);
}
.fc-option-wrong {
  border-color: var(--color-error);
  background: var(--color-error-light);
}
.fc-option-selected {
  border-color: var(--text-primary);
  background: var(--active-bg);
}

/* ---- Front-side Feedback (correct/wrong banner) ---- */
.fc-feedback {
  margin-top: 12rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}
.fc-feedback-correct {
  background: var(--color-success-light);
  border: 2rpx solid var(--color-success);
  color: var(--color-success);
}
.fc-feedback-wrong {
  background: var(--color-error-light);
  border: 2rpx solid var(--color-error);
  color: var(--color-error);
}
.fc-feedback-text {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

/* ---- Back-side Verdict (R20: vertical stacked layout) ---- */
.fc-back-block {
  background: var(--card-bg);
  border-radius: 14rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
  box-shadow: var(--shadow-sm);
}
.fc-back-label {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 1rpx;
  margin-bottom: 10rpx;
}
.fc-back-ja {
  display: block;
  font-size: 28rpx;
  line-height: 1.65;
  color: var(--text-primary);
  white-space: pre-wrap;
  word-break: break-word;
}
.fc-back-zh {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-secondary);
  white-space: pre-wrap;
  word-break: break-word;
  margin-top: 10rpx;
}

/* R20: verdict sections — vertical block flow, no flex-row */
.fc-back-verdict {
  display: block;
}
.fc-verdict-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid var(--divider-color);
}
.fc-verdict-section {
  display: block;
  width: 100%;
  margin-bottom: 16rpx;
  padding: 12rpx;
  border-radius: 10rpx;
  background: var(--bg-surface);
}
.fc-verdict-section:last-child {
  margin-bottom: 0;
}
.fc-verdict-section-label {
  display: block;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-hint);
  margin-bottom: 8rpx;
}
.fc-verdict-key {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--active-bg);
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}
.fc-verdict-text-ja {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.5;
  margin-top: 4rpx;
}
.fc-verdict-text-zh {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  margin-top: 4rpx;
}
.fc-verdict-correct {
  color: var(--color-success);
}
.fc-verdict-wrong {
  color: var(--color-error);
}

/* ---- Back-side options review ---- */
.fc-back-options { margin-top: 4rpx; }
.fc-back-option {
  padding: 16rpx 20rpx;
  margin-bottom: 8rpx;
  border-radius: 10rpx;
  background: var(--bg-surface);
  border: 2rpx solid var(--border-color);
}
.fc-back-option-correct {
  border-color: var(--color-success);
  background: var(--color-success-light);
}
.fc-back-option-wrong {
  border-color: var(--color-error);
  background: var(--color-error-light);
}
.fc-back-option-selected-correct {
  border-color: var(--color-success);
  background: var(--color-success-light);
}
.fc-back-option-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}
.fc-back-option-key {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--bg-surface);
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.fc-back-option-key-correct {
  background: var(--color-success);
  color: #fff;
}
.fc-back-option-mark {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-weight: 600;
  background: var(--primary-light);
  color: var(--primary-color);
}
.fc-back-option-mark-correct {
  background: var(--color-success-light);
  color: var(--color-success);
}
.fc-back-option-ja {
  display: block;
  font-size: 26rpx;
  line-height: 1.55;
  color: var(--text-primary);
  word-break: break-word;
}
.fc-back-option-zh {
  display: block;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
  margin-top: 6rpx;
  word-break: break-word;
}
.fc-back-option-explain {
  margin-top: 10rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid var(--divider-color);
}
.fc-back-explain-ja {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-secondary);
  word-break: break-word;
}
.fc-back-explain-zh {
  display: block;
  font-size: 22rpx;
  line-height: 1.55;
  color: var(--text-hint);
  margin-top: 6rpx;
  word-break: break-word;
}

/* ---- Explanation ---- */
.fc-back-detail-ja {
  display: block;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--text-primary);
  white-space: pre-wrap;
  word-break: break-word;
}
.fc-back-detail-zh {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-secondary);
  margin-top: 12rpx;
  white-space: pre-wrap;
  word-break: break-word;
}

/* ---- Mnemonic ---- */
.fc-back-mnemonic {
  background: var(--card-bg);
  border-left: 4rpx solid var(--text-hint);
}
.fc-back-mnemonic-ja {
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--text-primary);
  word-break: break-word;
}
.fc-back-mnemonic-zh {
  display: block;
  font-size: 24rpx;
  line-height: 1.55;
  color: var(--text-secondary);
  margin-top: 8rpx;
  word-break: break-word;
}

/* ---- Action Buttons ---- */
.fc-action-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 12rpx;
}
.fc-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 22rpx 16rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: opacity 0.12s ease, transform 0.12s ease;
}
.fc-btn:active {
  opacity: 0.75;
  transform: scale(0.97);
}
.fc-btn-primary {
  width: 100%;
  background: var(--text-primary);
  color: var(--text-inverse);
  font-weight: 600;
}
.fc-btn-secondary {
  width: 100%;
  background: var(--bg-surface);
  color: var(--text-primary);
  border: 2rpx solid var(--border-color);
}
.fc-btn-ghost {
  background: transparent;
  border: 2rpx solid var(--border-color);
  color: var(--text-secondary);
}
.fc-btn-retry {
  background: var(--color-warning-light);
  color: var(--color-warning);
  border: 2rpx solid rgba(139, 123, 93, 0.24);
}
.fc-btn-full {
  width: 100%;
}

/* ---- Result Screen ---- */
.fc-result {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  text-align: center;
  box-shadow: var(--shadow-sm);
}
.fc-result-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}
.fc-result-accuracy { margin-bottom: 28rpx; }
.fc-result-pct {
  display: block;
  font-size: 72rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.1;
}
.fc-result-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
}
.fc-result-stats {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-bottom: 28rpx;
}
.fc-result-stat { text-align: center; }
.fc-result-stat-value {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
}
.fc-result-stat-correct .fc-result-stat-value { color: var(--color-success); }
.fc-result-stat-wrong .fc-result-stat-value { color: var(--color-error); }
.fc-result-stat-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
}
.fc-result-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.fc-result-actions .fc-btn { width: 100%; }

/* ---- Empty ---- */
.fc-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
}
.fc-empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}
.fc-empty-detail {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 40rpx;
  text-align: center;
}

/* ---- Status Tags ---- */
.fc-status-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
}
.fc-status-ja {
  background: var(--bg-surface);
  color: var(--text-secondary);
}
.fc-status-partial {
  background: var(--color-warning-light);
  color: var(--color-warning);
}
.fc-status-full {
  background: var(--color-success-light);
  color: var(--color-success);
}
