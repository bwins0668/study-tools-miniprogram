/* packages/java-course/pages/course-menu/course-menu.wxss */

.qp-menu-page {
  min-height: 100vh;
  background-color: var(--bg-color);
  padding: var(--space-md) var(--space-lg);
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
}

/* Header */
.qp-menu-header {
  padding: var(--space-sm) 0 var(--space-md);
  border-bottom: 1rpx solid var(--border-color);
  margin-bottom: var(--space-lg);
}

.qp-menu-header__title {
  display: block;
  font-size: var(--font-2xl);
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.2;
}

.qp-menu-header__subtitle {
  display: block;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-top: var(--space-xs);
}

/* Progress Card */
.qp-progress-card {
  margin-top: var(--space-md);
  padding: var(--space-sm) var(--space-md);
  background-color: var(--card-bg);
  border: 1rpx solid var(--border-color);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}

.qp-progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-xs);
}

.qp-progress-info__label {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.qp-progress-info__val {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--text-primary);
}

.qp-progress-bar {
  height: 6rpx;
  background-color: var(--divider-color);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.qp-progress-bar__fill {
  height: 100%;
  background-color: var(--primary-color);
  border-radius: var(--radius-full);
  transition: width var(--transition-slow);
}

/* Chapter Section */
.qp-chapter-group {
  margin-bottom: var(--space-xl);
}

.qp-chapter-title {
  padding-bottom: var(--space-xs);
  border-bottom: 2rpx solid var(--text-primary);
  margin-bottom: var(--space-md);
}

/* Dark theme overrides native border-bottom */
.dark-theme .qp-chapter-title {
  border-bottom-color: var(--border-strong);
}

.qp-chapter-title__zh {
  display: block;
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.qp-chapter-title__ja {
  display: block;
  font-size: var(--font-sm);
  color: var(--text-hint);
  margin-top: 4rpx;
}

/* Lesson list */
.qp-lessons-container {
  display: flex;
  flex-direction: column;
}

.qp-lesson-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-md) var(--space-sm);
  background-color: var(--card-bg);
  border: 1rpx solid var(--border-color);
  border-radius: var(--radius-md);
  margin-bottom: var(--space-sm);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.qp-lesson-row--pressed {
  background-color: var(--press-bg);
  border-color: var(--border-strong);
}

.qp-lesson-row__body {
  flex: 1;
  padding-right: var(--space-md);
}

.qp-lesson-row__title-zh {
  display: block;
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
}

.qp-lesson-row__title-ja {
  display: block;
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.qp-lesson-row__status {
  display: flex;
  align-items: center;
}

.qp-status-badge {
  font-size: var(--font-xs);
  padding: 4rpx 10rpx;
  border-radius: var(--radius-sm);
}

.qp-status-badge--completed {
  color: var(--color-success);
  background-color: var(--color-success-light);
}

.qp-status-badge--pending {
  color: var(--text-hint);
  background-color: var(--disabled-bg);
}

.qp-lesson-row__chev {
  margin-left: var(--space-xs);
  font-size: var(--font-lg);
  color: var(--text-hint);
  line-height: 1;
}
