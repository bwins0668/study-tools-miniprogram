/* pages/practice/practice.wxss */
@import "../../styles/tokens.wxss";

.practice-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx var(--qp-space-5) calc(100rpx + env(safe-area-inset-bottom));
  background-color: var(--qp-color-canvas);
  color: var(--qp-color-ink);
}

.practice-head {
  margin-bottom: 20rpx;
}

.practice-head__kicker {
  display: block;
  margin-bottom: 8rpx;
  font-family: var(--qp-font-family-data);
  font-size: 20rpx;
  font-weight: 700;
  color: var(--qp-color-editorial);
  letter-spacing: 0;
}

.practice-head__title {
  display: block;
  font-size: var(--qp-font-size-masthead);
  font-weight: 800;
  color: var(--qp-color-ink);
  letter-spacing: 0;
  margin-bottom: 8rpx;
  line-height: 1;
}

.practice-head__sub {
  font-size: var(--qp-font-size-body);
  color: var(--qp-color-text-secondary);
}

.practice-rule {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.practice-rule view {
  width: 60rpx;
  height: 4rpx;
  background: var(--qp-color-primary);
}

.practice-rule text {
  flex: 1;
  height: 2rpx;
  background: var(--qp-color-ink);
  opacity: 0.72;
}

.practice-continue {
  margin-bottom: 32rpx;
}

.practice-section {
  margin-bottom: 24rpx;
}

.practice-section__title {
  display: block;
  font-size: var(--qp-font-size-label);
  font-weight: var(--qp-font-weight-regular);
  letter-spacing: 2rpx;
  color: var(--qp-color-text-tertiary);
  margin-bottom: 12rpx;
}

.practice-card {
  display: flex;
  flex-direction: column;
  min-height: 88rpx;
  padding: 24rpx;
  background-color: var(--qp-color-surface);
  border: var(--qp-border-width) solid var(--qp-color-line);
  border-radius: var(--qp-radius-lg);
  margin-bottom: 12rpx;
  position: relative;
}

.practice-card--continue {
  border-color: var(--qp-color-primary);
  border-top: 5rpx solid var(--qp-color-editorial);
  background-color: var(--qp-color-surface);
}

.practice-card--muted {
  opacity: 0.55;
}

.practice-card__kicker {
  font-size: 20rpx;
  font-weight: var(--qp-font-weight-semibold);
  letter-spacing: 2rpx;
  color: var(--qp-color-primary);
  text-transform: uppercase;
  margin-bottom: 4rpx;
}

.practice-card__title {
  font-size: 28rpx;
  font-weight: var(--qp-font-weight-semibold);
  color: var(--qp-color-ink);
}

.practice-card__sub {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--qp-color-text-secondary);
}

.practice-card__action {
  margin-top: 12rpx;
  font-size: var(--qp-font-size-body);
  color: var(--qp-color-primary);
  font-weight: var(--qp-font-weight-semibold);
}

.practice-card__chev {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  color: var(--qp-color-text-tertiary);
  opacity: 0.45;
}

/* ===== R6.2 practice icons ===== */
.practice-card__icon {
  width: 84rpx;
  height: 84rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--qp-font-family-data);
  font-size: 30rpx;
  font-weight: var(--qp-font-weight-semibold);
  flex-shrink: 0;
}
.practice-card__icon--itpass {
  background: var(--qp-color-primary-soft);
  color: var(--qp-color-primary);
}
.practice-card__icon--sg {
  background: var(--qp-color-primary-soft);
  color: var(--qp-color-primary);
}
.practice-card__icon--muted {
  background: var(--qp-color-disabled-bg);
  color: var(--qp-color-text-ghost);
}
.practice-card__body {
  flex: 1;
  min-width: 0;
}
.practice-card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.practice-card__meta {
  font-family: var(--qp-font-family-data);
  font-size: var(--qp-font-size-label);
  color: var(--qp-color-text-ghost);
}
.practice-card__kicker {
  font-family: var(--qp-font-family-data);
  font-size: var(--qp-font-size-label);
  color: var(--qp-color-primary);
  font-weight: var(--qp-font-weight-semibold);
  letter-spacing: .1em;
}
/* enforce flex row on exam cards */
.practice-card {
  display: flex;
  align-items: center;
  gap: 28rpx;
}
.practice-card--continue {
  flex-direction: column;
  align-items: stretch;
}
/* section numbering */
.practice-section .r6-section-label {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 12rpx;
}
.practice-section .r6-section-label__num {
  font-family: var(--qp-font-family-data);
  font-size: 48rpx;
  font-weight: var(--qp-font-weight-semibold);
  color: var(--qp-color-text-phantom);
  line-height: .8;
}
/* accent rule */
.practice-rule {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}
.practice-rule__accent { width: 60rpx; height: 4rpx; background: var(--qp-color-primary); }
.practice-rule__line { flex: 1; height: 2rpx; background: var(--qp-color-ink); opacity: 0.72; }
.practice-head__meta {
  display: block;
  font-size: var(--qp-font-size-caption);
  color: var(--qp-color-text-secondary);
  margin-top: 6rpx;
}

