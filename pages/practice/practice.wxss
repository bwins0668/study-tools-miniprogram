/* pages/practice/practice.wxss */
@import "../../styles/tokens.wxss";

.practice-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx var(--qp-space-5) calc(128rpx + env(safe-area-inset-bottom));
  background-color: var(--qp-color-canvas);
  color: var(--qp-color-ink);
}

.practice-head {
  margin-bottom: 32rpx;
}

.practice-head__title {
  display: block;
  font-size: 38rpx;
  font-weight: var(--qp-font-weight-semibold);
  color: var(--qp-color-ink);
  letter-spacing: -0.5rpx;
  margin-bottom: 8rpx;
}

.practice-head__sub {
  font-size: var(--qp-font-size-body);
  color: var(--qp-color-text-secondary);
}

.practice-continue {
  margin-bottom: 32rpx;
}

.practice-section {
  margin-bottom: 24rpx;
}

.practice-section__title {
  display: block;
  font-size: var(--qp-font-size-label);
  font-weight: var(--qp-font-weight-regular);
  letter-spacing: 2rpx;
  color: var(--qp-color-text-tertiary);
  margin-bottom: 12rpx;
}

.practice-card {
  display: flex;
  flex-direction: column;
  min-height: 88rpx;
  padding: 24rpx;
  background-color: var(--qp-color-surface);
  border: var(--qp-border-width) solid var(--qp-color-line);
  border-radius: var(--qp-radius-lg);
  margin-bottom: 12rpx;
  position: relative;
}

.practice-card--continue {
  border-color: var(--qp-color-primary);
  background-color: var(--qp-color-surface);
}

.practice-card--muted {
  opacity: 0.55;
}

.practice-card__kicker {
  font-size: 20rpx;
  font-weight: var(--qp-font-weight-semibold);
  letter-spacing: 2rpx;
  color: var(--qp-color-primary);
  text-transform: uppercase;
  margin-bottom: 4rpx;
}

.practice-card__title {
  font-size: 28rpx;
  font-weight: var(--qp-font-weight-semibold);
  color: var(--qp-color-ink);
}

.practice-card__sub {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--qp-color-text-secondary);
}

.practice-card__action {
  margin-top: 12rpx;
  font-size: var(--qp-font-size-body);
  color: var(--qp-color-primary);
  font-weight: var(--qp-font-weight-semibold);
}

.practice-card__chev {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  color: var(--qp-color-text-tertiary);
  opacity: 0.45;
}
