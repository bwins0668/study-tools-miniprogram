/* pages/glossary/glossary.wxss - 术语学习中心 */

.container {
  min-height: 100vh;
  background: var(--bg-color);
  padding-bottom: 40rpx;
}

/* === Hero 区域 === */
.glossary-hero {
  margin: 28rpx 28rpx 0;
  padding: 30rpx;
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
  border-radius: 26rpx;
  box-shadow: var(--shadow-sm);
  position: relative;
  overflow: hidden;
}

.glossary-hero::before,
.glossary-hero::after {
  display: none;
}

.glossary-hero-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.glossary-hero-text {
  flex: 1;
}

.glossary-hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.glossary-hero-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.glossary-hero-badge {
  background: var(--bg-surface);
  border: 1rpx solid var(--border-color);
  border-radius: 999rpx;
  padding: 8rpx 20rpx;
  flex-shrink: 0;
  margin-top: 6rpx;
}

.glossary-hero-badge-text {
  font-size: 20rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

/* === 搜索入口卡片 === */
.search-entry-card {
  display: flex;
  align-items: center;
  background: var(--bg-surface);
  border: 1rpx solid var(--border-color);
  border-radius: 999rpx;
  padding: 24rpx 28rpx;
  position: relative;
  z-index: 2;
  transition: transform var(--transition-fast), background-color var(--transition-fast), border-color var(--transition-fast);
}

.search-entry-card:active {
  transform: translateY(2rpx) scale(0.985);
  background: var(--press-bg);
  border-color: var(--border-strong);
}

.search-entry-symbol {
  width: 34rpx;
  height: 34rpx;
  margin-right: 16rpx;
  border: 3rpx solid var(--text-secondary);
  border-radius: 50%;
  position: relative;
  flex-shrink: 0;
}

.search-entry-symbol::after {
  content: '';
  position: absolute;
  right: -8rpx;
  bottom: -5rpx;
  width: 14rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: var(--text-secondary);
  transform: rotate(45deg);
}

.search-entry-placeholder,
.search-entry-arrow {
  color: var(--text-hint);
}

.search-entry-placeholder {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
}

.search-entry-arrow {
  font-size: 36rpx;
  flex-shrink: 0;
  font-weight: 300;
}

/* === 功能卡片矩阵 === */
.glossary-actions {
  padding: 18rpx 28rpx 0;
  position: relative;
  z-index: 2;
}

.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.action-tile {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 206rpx;
  padding: 32rpx 16rpx 28rpx;
  border-radius: 22rpx;
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
  position: relative;
  overflow: hidden;
  transition: transform 0.15s, box-shadow 0.15s;
}

.action-tile:active {
  transform: translateY(2rpx) scale(0.985);
  background: var(--press-bg);
  box-shadow: var(--shadow-sm);
}

.action-tile::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: var(--border-strong);
}

.action-tile-icon {
  font-size: 44rpx;
  margin-bottom: 12rpx;
}

.action-tile-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.action-tile-stat {
  font-size: 22rpx;
  color: var(--text-hint);
  font-weight: 500;
}

/* === 底部提示 === */
.glossary-footer-hint {
  padding: 24rpx 30rpx 0;
  text-align: center;
}

.glossary-footer-hint-text {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* === 几何 Symbol 系统 === */
.action-symbol {
  width: 54rpx;
  height: 54rpx;
  border: 2rpx solid var(--text-primary);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  position: relative;
}

.action-symbol::before,
.action-symbol::after {
  content: '';
  position: absolute;
  background: var(--text-primary);
}

.symbol-favorite::before {
  left: 13rpx;
  right: 13rpx;
  top: 25rpx;
  height: 2rpx;
}

.symbol-favorite::after {
  left: 25rpx;
  top: 13rpx;
  width: 2rpx;
  height: 28rpx;
}

.symbol-anki::before {
  left: 12rpx;
  top: 12rpx;
  width: 10rpx;
  height: 10rpx;
  box-shadow: 18rpx 0 0 var(--text-primary), 0 18rpx 0 var(--text-primary), 18rpx 18rpx 0 var(--text-primary);
}

.symbol-random::before {
  left: 15rpx;
  top: 15rpx;
  width: 20rpx;
  height: 20rpx;
  border: 2rpx solid var(--text-primary);
  border-radius: 50%;
  background: transparent;
}

.symbol-list::before {
  left: 13rpx;
  right: 13rpx;
  top: 15rpx;
  height: 2rpx;
  box-shadow: 0 10rpx 0 var(--text-primary), 0 20rpx 0 var(--text-primary);
}

/* R3.54 smoke anchor: random term launcher compat */
.launcher-btn-random {
  display: none;
}
