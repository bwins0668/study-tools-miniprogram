/* pages/glossary/glossary.wxss - 术语 tab 轻入口 */

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
  padding: 60rpx 40rpx;
}

.launcher-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.launcher-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.launcher-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.launcher-desc {
  font-size: 26rpx;
  color: var(--text-hint);
  text-align: center;
  margin-bottom: 50rpx;
}

.launcher-btn {
  background-color: #4a90d9;
  border-radius: 40rpx;
  padding: 28rpx 80rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
  margin-bottom: 20rpx;
}

.launcher-btn-secondary {
  background-color: #e8913a;
  box-shadow: 0 4rpx 16rpx rgba(232, 145, 58, 0.3);
}

/* R3.54 随机术语按钮 */
.launcher-btn-random {
  background-color: #9c27b0;
  box-shadow: 0 4rpx 16rpx rgba(156, 39, 176, 0.3);
}

.launcher-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

.launcher-hint {
  font-size: 24rpx;
  color: #e8913a;
  margin-top: 30rpx;
}
