.rc-container { padding: 24rpx 32rpx; min-height: 100vh; background: #fafaf8; }
.rc-header { margin-bottom: 32rpx; }
.rc-title { display: block; font-size: 40rpx; font-weight: 700; color: #1a1a1a; }
.rc-subtitle { display: block; font-size: 26rpx; color: #999; margin-top: 4rpx; }
.rc-stats { display: flex; gap: 16rpx; margin-bottom: 32rpx; }
.rc-stat { flex: 1; background: #fff; border-radius: 12rpx; padding: 16rpx 12rpx; text-align: center; border: 1rpx solid #eee; }
.rc-stat-value { display: block; font-size: 36rpx; font-weight: 700; color: #1a1a1a; }
.rc-stat-label { display: block; font-size: 22rpx; color: #999; margin-top: 4rpx; }
.rc-empty { text-align: center; padding: 80rpx 32rpx; }
.rc-empty-icon { font-size: 64rpx; color: #4caf50; display: block; margin-bottom: 16rpx; }
.rc-empty-title { font-size: 32rpx; font-weight: 600; color: #333; display: block; margin-bottom: 8rpx; }
.rc-empty-detail { font-size: 26rpx; color: #999; display: block; margin-bottom: 32rpx; }
.rc-groups { display: flex; flex-direction: column; gap: 16rpx; }
.rc-group { background: #fff; border-radius: 12rpx; padding: 24rpx; border: 1rpx solid #eee; }
.rc-group-course { font-size: 22rpx; color: #999; margin-bottom: 4rpx; }
.rc-group-deck { font-size: 30rpx; font-weight: 600; color: #1a1a1a; margin-bottom: 12rpx; }
.rc-group-meta { display: flex; gap: 24rpx; margin-bottom: 16rpx; }
.rc-group-count { font-size: 26rpx; color: #e67e22; font-weight: 600; }
.rc-group-time { font-size: 26rpx; color: #999; }
.rc-btn { display: inline-flex; align-items: center; justify-content: center; padding: 16rpx 32rpx; border-radius: 8rpx; font-size: 28rpx; font-weight: 600; }
.rc-btn-primary { background: #1a1a1a; color: #fff; width: 100%; }
.rc-btn-ghost { background: #f5f5f5; color: #666; margin-top: 8rpx; }

/* Recovery card */
.rc-recovery-card { background: #fff3e0; border-radius: 16rpx; padding: 24rpx; margin-bottom: 24rpx; border: 2rpx solid #ffe0b2; }
.rc-recovery-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; }
.rc-recovery-icon { font-size: 36rpx; }
.rc-recovery-title { font-size: 30rpx; font-weight: 700; color: #e65100; }
.rc-recovery-body { margin-bottom: 16rpx; }
.rc-recovery-course { display: block; font-size: 24rpx; color: #bf360c; margin-bottom: 4rpx; }
.rc-recovery-deck { display: block; font-size: 28rpx; font-weight: 600; color: #1a1a1a; margin-bottom: 8rpx; }
.rc-recovery-progress { display: block; font-size: 26rpx; color: #666; }
.rc-recovery-actions { display: flex; gap: 12rpx; align-items: center; }
.rc-btn-recovery { flex: 1; }
.rc-btn-secondary { background: #e65100; color: #fff; flex: 1; padding: 16rpx 24rpx; border-radius: 8rpx; font-size: 28rpx; font-weight: 600; text-align: center; }
.rc-btn-small { padding: 12rpx 24rpx; font-size: 24rpx; }