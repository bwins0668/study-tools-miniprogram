<!--pages/course/course.wxml · Unified course shell-->
<view class="cs-page">

  <!-- Safety: unknown / unresolved courseId -->
  <block wx:if="{{notFound}}">
    <view class="cs-empty">
      <text class="cs-empty__title">课程暂不可用</text>
      <text class="cs-empty__sub">该课程尚未开放或入口尚未确认</text>
      <view class="cs-btn cs-btn--outline" bindtap="goBackHome">返回课程</view>
    </view>
  </block>

  <!-- Certification: IT Passport / SG -->
  <block wx:elif="{{course.courseKind === 'certification'}}">
    <view class="cs-head">
      <text class="cs-head__title">{{course.displayName}}</text>
      <text class="cs-head__kind">资格考试</text>
    </view>

    <view class="cs-last" wx:if="{{hasLastAttempt}}">
      <text class="cs-last__label">上次练习</text>
      <text class="cs-last__meta">{{lastMetaText}}</text>
    </view>

    <view class="cs-actions">
      <view class="cs-btn cs-btn--primary" bindtap="goPractice">{{hasLastAttempt ? '再练一次' : '开始刷题'}}</view>
      <view class="cs-btn cs-btn--outline" bindtap="goExamMenu">真题与模拟练习</view>
    </view>

    <view class="cs-section">
      <text class="cs-section__title">学习辅助</text>
      <view class="cs-row" bindtap="goMistakes">
        <text class="cs-row__text">全部错题复习</text>
        <text class="cs-row__arrow">→</text>
      </view>
      <text class="cs-note">课程内容正在整理</text>
    </view>
  </block>

  <!-- Learning: Python / Java / Algorithm -->
  <block wx:elif="{{course.courseKind === 'learning'}}">
    <view class="cs-head">
      <text class="cs-head__title">{{course.displayName}}</text>
      <text class="cs-head__kind">课程学习</text>
    </view>

    <view class="cs-empty cs-empty--planned">
      <text class="cs-empty__title">课程内容正在整理</text>
      <text class="cs-empty__sub">课程目录、教材导航与章节练习将在内容校验完成后开放。</text>
      <view class="cs-btn cs-btn--outline" bindtap="goBackHome">返回课程</view>
    </view>
  </block>

  <!-- Fallback -->
  <block wx:else>
    <view class="cs-empty">
      <text class="cs-empty__title">课程暂不可用</text>
      <view class="cs-btn cs-btn--outline" bindtap="goBackHome">返回课程</view>
    </view>
  </block>
</view>
