@import "../../styles/tokens.wxss";

.cs-page {
  min-height: 100vh; box-sizing: border-box;
  padding: 32rpx var(--qp-space-5) calc(128rpx + env(safe-area-inset-bottom));
  background-color: var(--qp-color-canvas); color: var(--qp-color-ink);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.cs-head { margin-bottom: 24rpx; }
.cs-head__title {
  display: block; font-size: 38rpx; font-weight: var(--qp-font-weight-semibold);
  letter-spacing: -0.5rpx; color: var(--qp-color-ink);
}
.cs-head__kind {
  display: block; margin-top: 4rpx; font-size: var(--qp-font-size-caption);
  color: var(--qp-color-text-tertiary);
}

.cs-last {
  padding: 20rpx 24rpx; margin-bottom: 20rpx;
  background-color: var(--qp-color-surface); border-radius: var(--qp-radius-lg);
  border: var(--qp-border-width) solid var(--qp-color-line);
}
.cs-last__label { font-size: var(--qp-font-size-caption); color: var(--qp-color-text-tertiary); }
.cs-last__meta { display: block; margin-top: 2rpx; font-size: var(--qp-font-size-body); color: var(--qp-color-ink); }

.cs-actions { display: flex; gap: 16rpx; margin-bottom: 32rpx; }

.cs-btn {
  flex: 1; text-align: center; padding: 18rpx 0; border-radius: var(--qp-radius-md);
  font-size: 28rpx; font-weight: var(--qp-font-weight-semibold); line-height: 1.4;
}
.cs-btn--primary { background-color: var(--qp-color-primary); color: #fff; }
.cs-btn--outline { background-color: transparent; border: var(--qp-border-width) solid var(--qp-color-line-strong); color: var(--qp-color-ink); }

.cs-section { margin-bottom: 24rpx; }
.cs-section__title {
  display: block; margin-bottom: 12rpx;
  font-size: var(--qp-font-size-label); font-weight: var(--qp-font-weight-regular);
  letter-spacing: 2rpx; color: var(--qp-color-text-tertiary);
}

.cs-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 0; border-top: var(--qp-border-width) solid var(--qp-color-line);
}
.cs-row__text { font-size: var(--qp-font-size-body); color: var(--qp-color-ink); }
.cs-row__arrow { font-size: 24rpx; color: var(--qp-color-text-tertiary); }

.cs-note {
  display: block; margin-top: 16rpx; font-size: var(--qp-font-size-caption);
  color: var(--qp-color-text-tertiary);
}

.cs-empty { padding: 48rpx 0; text-align: center; }
.cs-empty__title { font-size: 28rpx; font-weight: var(--qp-font-weight-semibold); color: var(--qp-color-ink); }
.cs-empty__sub { display: block; margin-top: 8rpx; font-size: 24rpx; color: var(--qp-color-text-secondary); }
.cs-empty .cs-btn { display: inline-block; margin-top: 24rpx; padding: 14rpx 48rpx; width: auto; }

/* Dark theme */
.dark-theme .cs-page { background-color: var(--bg-color); color: var(--text-primary); }
.dark-theme .cs-head__title, .dark-theme .cs-last__meta, .dark-theme .cs-row__text,
.dark-theme .cs-empty__title { color: var(--text-primary); }
.dark-theme .cs-last, .dark-theme .cs-row { background-color: var(--card-bg); border-color: var(--border-color); }
.dark-theme .cs-btn--outline { color: var(--text-primary); border-color: var(--border-color); }
