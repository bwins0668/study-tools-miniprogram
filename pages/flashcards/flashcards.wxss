.page{min-height:100vh;background:#f4f6f8;padding-bottom:constant(safe-area-inset-bottom);padding-bottom:env(safe-area-inset-bottom)}.container{padding:0 28rpx}.page-header{padding-top:32rpx;padding-bottom:18rpx}.page-title{display:block;font-size:42rpx;font-weight:760;line-height:1.18;color:#111827}.page-subtitle{display:block;margin-top:6rpx;font-size:26rpx;color:#4b5563}.section{margin-top:24rpx}.section-title-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:12rpx;padding:0 8rpx}.section-title{font-size:30rpx;font-weight:680;color:#111827}.continue-card{display:flex;align-items:center;justify-content:space-between;gap:18rpx;padding:24rpx;background:#f9fafb;border:1rpx solid #d9dee6;border-radius:18rpx}.continue-body{display:flex;flex-direction:column;gap:6rpx}.continue-course{font-size:30rpx;font-weight:680;color:#111827}.continue-sub{font-size:26rpx;color:#4b5563}.continue-meta{font-size:26rpx;color:#111827}.continue-time{font-size:22rpx;color:#8a94a3}.continue-btn{min-height:72rpx;padding:0 24rpx;border-radius:999rpx;background:#111827;color:#ffffff;border:1rpx solid #111827;display:flex;align-items:center;justify-content:center;font-size:26rpx;font-weight:620}.empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10rpx;padding:32rpx 24rpx}.empty-dot{width:10rpx;height:10rpx;border-radius:50%;background:#b8c0cc}.empty-text{font-size:26rpx;color:#8a94a3;text-align:center}.course-grid{display:flex;flex-direction:column;gap:18rpx}.course-card{padding:22rpx 24rpx;background:#ffffff;border:1rpx solid #d9dee6;border-radius:18rpx;box-shadow:0 1rpx 2rpx rgba(15,23,42,0.04)}.course-header{display:flex;align-items:center;gap:18rpx}.course-icon-wrap{width:56rpx;height:56rpx;border-radius:16rpx;background:rgba(17,24,39,0.02);border:2rpx solid #111827;overflow:hidden;display:flex;align-items:center;justify-content:center}.course-icon-symbol{width:20rpx;height:2rpx;background:#111827;border-radius:2rpx}.course-icon-anki .course-icon-symbol{background:#4a5563;border-color:rgba(74,85,99,0.12)}.course-title-wrap{display:flex;flex-direction:column;gap:4rpx}.course-title{font-size:30rpx;font-weight:680;color:#111827}.course-desc{font-size:24rpx;color:#8a94a3}.course-stats{display:flex;gap:24rpx;margin-top:16rpx}.course-stat{display:flex;flex-direction:column;gap:4rpx}.course-stat-value{font-size:28rpx;font-weight:680;color:#111827}.course-stat-label{font-size:22rpx;color:#8a94a3}.course-footer{display:flex;align-items:center;justify-content:space-between;margin-top:14rpx}.course-tags{display:flex;flex-wrap:wrap;gap:10rpx}.course-tag{min-height:36rpx;padding:0 16rpx;border-radius:999rpx;font-size:22rpx;color:#4b5563;background:rgba(17,24,39,0.04);border:1rpx solid rgba(17,24,39,0.08)}.course-arrow{color:#8a94a3;font-size:34rpx}
