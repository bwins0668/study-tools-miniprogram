.page{min-height:100vh;background:#f4f6f8;padding-bottom:constant(safe-area-inset-bottom);padding-bottom:env(safe-area-inset-bottom)}
.container{padding:0 28rpx}
.page-header{padding-top:32rpx;padding-bottom:12rpx}
.page-title{display:block;font-size:38rpx;font-weight:760;line-height:1.18;color:#111827}
.page-subtitle{display:block;margin-top:4rpx;font-size:24rpx;color:#9ca3af}
.section{margin-top:20rpx}
.section-title-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:10rpx;padding:0 8rpx}
.section-title{font-size:28rpx;font-weight:680;color:#111827}
.continue-card{display:flex;align-items:center;justify-content:space-between;gap:16rpx;padding:20rpx;background:#f9fafb;border:1rpx solid #d9dee6;border-radius:14rpx}
.continue-body{display:flex;flex-direction:column;gap:4rpx}
.continue-course{font-size:28rpx;font-weight:680;color:#111827}
.continue-sub{font-size:24rpx;color:#4b5563}
.continue-meta{font-size:24rpx;color:#111827}
.continue-time{font-size:22rpx;color:#8a94a3}
.continue-btn{min-height:64rpx;padding:0 20rpx;border-radius:999rpx;background:#111827;color:#ffffff;border:1rpx solid #111827;display:flex;align-items:center;justify-content:center;font-size:24rpx;font-weight:620}
.continue-hint{padding:20rpx;background:#f9fafb;border:1rpx solid #d9dee6;border-radius:14rpx;text-align:center}
.continue-hint-text{font-size:26rpx;color:#8a94a3}
.course-grid{display:flex;flex-direction:column;gap:16rpx}
.course-card{padding:20rpx 22rpx;background:#ffffff;border:1rpx solid #d9dee6;border-radius:16rpx;box-shadow:0 1rpx 2rpx rgba(15,23,42,0.04)}
.course-header{display:flex;align-items:center;gap:16rpx}
.course-icon-wrap{width:52rpx;height:52rpx;border-radius:14rpx;background:rgba(17,24,39,0.02);border:2rpx solid #111827;overflow:hidden;display:flex;align-items:center;justify-content:center}
.course-icon-symbol{width:18rpx;height:2rpx;background:#111827;border-radius:2rpx}
.course-icon-anki{border-color:#6366f1}
.course-icon-anki .course-icon-symbol{background:#6366f1}
.course-title-wrap{display:flex;flex-direction:column;gap:2rpx}
.course-title{font-size:28rpx;font-weight:680;color:#111827}
.course-desc{font-size:22rpx;color:#6b7280}
.course-stats{display:flex;gap:24rpx;margin-top:14rpx;padding-top:14rpx;border-top:1rpx solid #e5e7eb}
.course-stat{display:flex;flex-direction:column;align-items:center;gap:2rpx}
.course-stat-value{font-size:28rpx;font-weight:700;color:#111827}
.course-stat-label{font-size:20rpx;color:#8a94a3}
.course-footer{display:flex;align-items:center;justify-content:space-between;margin-top:12rpx}
.course-tags{display:flex;gap:8rpx;flex-wrap:wrap}
.course-tag{font-size:20rpx;padding:4rpx 10rpx;background:#f3f4f6;color:#6b7280;border-radius:6rpx}
.course-arrow{font-size:32rpx;color:#9ca3af}
