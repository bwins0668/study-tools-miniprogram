/* pages/profile/profile.wxss */

.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 30rpx 30rpx;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #eef4fc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin-bottom: 20rpx;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 8rpx;
}

.profile-version {
  font-size: 24rpx;
  color: #999999;
}

/* R3.57 复制版本号按钮 */
.version-row {
  display: flex;
  align-items: center;
  justify-content: center;
}

.copy-version-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx 10rpx;
  margin-left: 10rpx;
  background-color: #f0f0f0;
  border-radius: 6rpx;
}

.copy-version-icon {
  font-size: 24rpx;
}

/* 学习状态 */
.status-card {
  text-align: center;
}

.status-text {
  font-size: 28rpx;
  color: #4a90d9;
  font-weight: 500;
  line-height: 1.6;
}

/* 区块标题 */
.stats-section {
  padding: 10rpx 0;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #666666;
  padding: 20rpx 30rpx 10rpx;
}

/* 信息卡片 */
.info-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin: 8rpx 30rpx;
  padding: 24rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
}

.info-value {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.info-highlight {
  color: #e8913a;
  font-size: 32rpx;
  font-weight: 700;
}

.streak-value {
  color: #4caf50;
  font-weight: 700;
}

.info-disabled {
  color: #bbbbbb;
}

/* 统计网格 */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 8rpx 20rpx;
}

.stat-box {
  width: calc(50% - 20rpx);
  margin: 10rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
}

.stat-correct {
  color: #4caf50;
}

.stat-wrong {
  color: #f44336;
}

.stat-accuracy {
  color: #4a90d9;
}

/* 本地数据管理按钮 */
.backup-btn-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 10rpx 30rpx 0;
}

.backup-btn {
  border-radius: 40rpx;
  padding: 24rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.backup-btn-primary {
  background-color: #4a90d9;
}

.backup-btn-primary .backup-btn-text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
}

.backup-btn-secondary {
  background-color: #ffffff;
  border: 2rpx solid #4a90d9;
}

.backup-btn-secondary .backup-btn-text {
  color: #4a90d9;
  font-size: 28rpx;
  font-weight: 500;
}

.backup-btn-danger {
  background-color: #ffffff;
  border: 2rpx solid #f44336;
}

.backup-btn-danger .backup-btn-text {
  color: #f44336;
  font-size: 28rpx;
  font-weight: 500;
}

.backup-hint {
  display: block;
  font-size: 22rpx;
  color: #bbbbbb;
  text-align: center;
  margin-top: 16rpx;
  padding-bottom: 10rpx;
}

/* 备份数据摘要 */
.backup-summary-card {
  padding: 20rpx 32rpx;
}

.backup-summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}

.backup-summary-row + .backup-summary-row {
  border-top: 1rpx solid #f5f5f5;
}

.backup-summary-label {
  font-size: 26rpx;
  color: #666666;
}

.backup-summary-value {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.backup-local-notice {
  display: block;
  font-size: 22rpx;
  color: #bbbbbb;
  text-align: center;
  padding: 16rpx 30rpx 10rpx;
  line-height: 1.6;
}

/* 本地版说明 */
.local-notice-text {
  display: block;
  font-size: 26rpx;
  color: #888888;
  line-height: 1.7;
}

/* 清空按钮 */
.clear-section {
  padding: 40rpx 30rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.clear-btn {
  background-color: #ffffff;
  border: 2rpx solid #f44336;
  border-radius: 40rpx;
  padding: 24rpx 60rpx;
}

.clear-btn-text {
  font-size: 28rpx;
  color: #f44336;
  font-weight: 500;
}

.clear-hint {
  font-size: 22rpx;
  color: #bbbbbb;
  margin-top: 16rpx;
}

/* 练习时间线 */
.empty-card {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 32rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999999;
  text-align: center;
  line-height: 1.6;
}

.timeline-list {
  margin: 8rpx 20rpx;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 10rpx;
  position: relative;
  border-left: 3rpx solid #e8e8e8;
  margin-left: 26rpx;
}

.timeline-item:last-child {
  border-left-color: transparent;
}

.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  position: absolute;
  left: -10rpx;
  top: 26rpx;
  flex-shrink: 0;
}

.timeline-dot-correct {
  background-color: #4caf50;
}

.timeline-dot-wrong {
  background-color: #f44336;
}

.timeline-content {
  margin-left: 20rpx;
  flex: 1;
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.04);
}

.timeline-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.timeline-label {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.timeline-status {
  font-size: 24rpx;
  font-weight: 500;
}

.status-correct {
  color: #4caf50;
}

.status-wrong {
  color: #f44336;
}

.timeline-time {
  display: block;
  font-size: 22rpx;
  color: #999999;
  margin-top: 6rpx;
}

/* 复习建议 (Round 3.21) */
.review-hint-list {
  margin: 8rpx 20rpx;
}

.review-hint-item {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 16rpx;
  margin: 10rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.review-hint-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.review-hint-text {
  font-size: 26rpx;
  color: #555555;
  line-height: 1.6;
  flex: 1;
}

.review-hint-wrong {
  border-left: 6rpx solid #f44336;
}

.review-hint-wrong .review-hint-text {
  color: #d32f2f;
}

.review-hint-favorite {
  border-left: 6rpx solid #4a90d9;
}

.review-hint-favorite .review-hint-text {
  color: #1976d2;
}

.review-hint-empty {
  border-left: 6rpx solid #e0e0e0;
}

.review-hint-empty .review-hint-text {
  color: #999999;
}

/* 科目对比洞察 (Round 3.21) */
.subject-compare-card {
  margin: 12rpx 30rpx;
  background-color: #f8f9fe;
  border: 1rpx solid #e8ebf5;
}

.subject-compare-row {
  display: flex;
  align-items: flex-start;
}

.subject-compare-icon {
  font-size: 32rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.subject-compare-text {
  font-size: 26rpx;
  color: #555555;
  line-height: 1.6;
  flex: 1;
}

.subject-compare-empty {
  background-color: #fafafa;
  border-color: #eeeeee;
}

.subject-compare-empty .subject-compare-text {
  color: #999999;
}

/* 新用户欢迎引导 (Round 3.21) */
.welcome-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 32rpx;
  text-align: center;
}

.welcome-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.welcome-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.welcome-desc {
  font-size: 26rpx;
  color: #888888;
  line-height: 1.7;
}

/* R3.68 版本更新说明 */
.update-notice {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.6;
  margin-top: 16rpx;
  display: block;
}

/* R3.73 使用帮助按钮 */
.help-btn {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 8rpx;
}

.help-btn-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.help-btn-text {
  font-size: 28rpx;
  color: #1890ff;
}

/* R3.74 联系反馈按钮 */
.feedback-btn {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #f8f9fa;
  border-radius: 8rpx;
}

.feedback-btn-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.feedback-btn-text {
  font-size: 28rpx;
  color: #52c41a;
}
