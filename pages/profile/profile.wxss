/* pages/profile/profile.wxss - 学习中心 */

.container {
  min-height: 100vh;
  background: var(--bg-color);
  padding-bottom: 72rpx;
}

/* === 头部 === */
.r6-profile-head {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 28rpx 28rpx 0;
  padding: 34rpx 30rpx;
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
  border-radius: 26rpx;
  box-shadow: var(--shadow-sm);
}

.r6-profile-head::before,
.r6-profile-head::after {
  display: none;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 28rpx;
  background: var(--bg-surface);
  border: 1rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin-bottom: 20rpx;
}

.avatar-symbol {
  width: 58rpx;
  height: 58rpx;
  border: 3rpx solid var(--text-primary);
  border-radius: 18rpx;
  position: relative;
}

.avatar-symbol::before,
.avatar-symbol::after,
.copy-version-symbol::before,
.copy-version-symbol::after,
.welcome-symbol::before,
.welcome-symbol::after,
.review-hint-symbol::before,
.review-hint-symbol::after,
.subject-compare-symbol::before,
.subject-compare-symbol::after,
.help-btn-symbol::before,
.help-btn-symbol::after,
.feedback-btn-symbol::before,
.feedback-btn-symbol::after {
  content: '';
  position: absolute;
  background: currentColor;
}

.avatar-symbol::before {
  left: 20rpx;
  top: 13rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

.avatar-symbol::after {
  left: 14rpx;
  right: 14rpx;
  bottom: 13rpx;
  height: 14rpx;
  border-radius: 999rpx 999rpx 6rpx 6rpx;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.profile-version {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 版本号复制按钮 */
.version-row {
  display: flex;
  align-items: center;
  justify-content: center;
}

.copy-version-btn {
  width: 52rpx;
  height: 52rpx;
  padding: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-surface);
  border: 1rpx solid var(--border-color);
  border-radius: 14rpx;
}

.copy-version-btn:active,
.r6-profile-card:active,
.backup-btn:active,
.clear-btn:active,
.help-btn:active,
.feedback-btn:active {
  transform: translateY(2rpx) scale(0.985);
  background: var(--press-bg);
}

.copy-version-symbol {
  width: 26rpx;
  height: 26rpx;
  border: 2rpx solid var(--text-secondary);
  border-radius: 7rpx;
  position: relative;
}

.copy-version-symbol::before {
  left: 6rpx;
  right: 6rpx;
  top: 7rpx;
  height: 2rpx;
  box-shadow: 0 7rpx 0 var(--text-secondary);
}

.copy-version-symbol::after {
  display: none;
}

/* 学习状态 */
.status-card {
  text-align: center;
}

.status-text {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  line-height: 1.6;
}

/* 区块标题 */
.stats-section {
  padding: 10rpx 0;
}

.section-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-hint);
  padding: 20rpx 30rpx 10rpx;
}

.section-divider {
  height: 1rpx;
  margin: 20rpx 28rpx 4rpx;
  background: var(--divider-color);
}

/* 信息卡片 */
.r6-profile-card,
.stat-box,
.timeline-content,
.review-hint-item,
.subject-compare-card {
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
  border-radius: 20rpx;
  box-shadow: var(--shadow-sm);
}

.r6-profile-card {
  margin: 8rpx 30rpx;
  padding: 24rpx 32rpx;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.info-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.info-value {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.info-highlight,
.stat-correct,
.stat-wrong,
.stat-accuracy,
.streak-value,
.status-text,
.subject-compare-text,
.help-btn-text,
.feedback-btn-text {
  color: var(--text-primary);
}

.info-highlight {
  font-size: 32rpx;
  font-weight: 700;
}

.info-disabled {
  color: var(--text-hint);
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin: 8rpx 30rpx;
}

.stat-box {
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  overflow: hidden;
}

.stat-box::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  border-radius: 18rpx 18rpx 0 0;
  background: var(--border-strong);
}

.stat-value {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-hint);
  font-weight: 500;
}

/* 本地数据管理按钮 */
.backup-btn-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 10rpx 30rpx 0;
}

.backup-btn {
  min-height: 88rpx;
  border-radius: 999rpx;
  padding: 24rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid var(--border-color);
  background: var(--card-bg);
  box-shadow: var(--shadow-sm);
}

.backup-btn-primary {
  background: var(--text-primary);
  border-color: var(--text-primary);
  box-shadow: 0 14rpx 32rpx rgba(17, 24, 39, 0.16);
}

.backup-btn-primary .backup-btn-text {
  color: var(--text-inverse);
  font-size: 28rpx;
  font-weight: 500;
}

.backup-btn-secondary {
  border-color: var(--border-color);
}

.backup-btn-secondary .backup-btn-text {
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 500;
}

.backup-btn-danger,
.clear-btn {
  background: var(--color-error-light);
  border: 1rpx solid rgba(138, 95, 100, 0.3);
}

.backup-btn-secondary .backup-btn-text,
.backup-btn-danger .backup-btn-text,
.clear-btn-text {
  color: var(--text-primary);
}

.backup-btn-danger .backup-btn-text,
.clear-btn-text {
  color: var(--color-error);
}

.backup-btn-danger .backup-btn-text {
  font-size: 28rpx;
  font-weight: 500;
}

.backup-hint {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: center;
  margin-top: 16rpx;
  padding-bottom: 10rpx;
  line-height: 1.7;
}

/* 备份数据摘要 */
.backup-summary-card {
  padding: 20rpx 32rpx;
}

.backup-summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}

.backup-summary-row + .backup-summary-row {
  border-top: 1rpx solid var(--divider-color);
}

.backup-summary-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.backup-summary-value {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.backup-local-notice {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: center;
  padding: 16rpx 30rpx 10rpx;
  line-height: 1.7;
}

/* 本地版说明 */
.local-notice-text,
.update-notice,
.backup-local-notice,
.backup-hint,
.clear-hint {
  color: var(--text-secondary);
  line-height: 1.7;
}

.local-notice-text {
  display: block;
  font-size: 26rpx;
}

/* 清空按钮 */
.clear-section {
  padding: 40rpx 30rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.clear-btn {
  border-radius: 40rpx;
  padding: 24rpx 60rpx;
}

.clear-btn-text {
  font-size: 28rpx;
  font-weight: 500;
}

.clear-hint {
  font-size: 22rpx;
  margin-top: 16rpx;
}

/* 练习时间线 */
.empty-card {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 32rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-hint);
  text-align: center;
  line-height: 1.6;
}

.timeline-list {
  margin: 8rpx 20rpx;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 10rpx;
  position: relative;
  border-left: 3rpx solid var(--divider-color);
  margin-left: 26rpx;
}

.timeline-item:last-child {
  border-left-color: transparent;
}

.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  position: absolute;
  left: -10rpx;
  top: 26rpx;
  flex-shrink: 0;
}

.timeline-dot-correct,
.timeline-dot-wrong {
  background: var(--border-strong);
}

.timeline-content {
  margin-left: 20rpx;
  flex: 1;
  padding: 16rpx 20rpx;
}

.timeline-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.timeline-label {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.timeline-status {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-secondary);
}

.status-correct,
.status-wrong {
  color: var(--text-secondary);
}

.timeline-time {
  display: block;
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 6rpx;
}

/* 复习建议 */
.review-hint-list {
  margin: 8rpx 20rpx;
}

.review-hint-item {
  display: flex;
  align-items: center;
  margin: 10rpx;
  padding: 24rpx 28rpx;
  border-left: 5rpx solid var(--border-strong);
}

.review-hint-wrong,
.review-hint-favorite,
.review-hint-empty {
  border-left-color: var(--border-strong);
}

.review-hint-wrong .review-hint-text,
.review-hint-favorite .review-hint-text,
.review-hint-empty .review-hint-text {
  color: var(--text-secondary);
}

.review-hint-text {
  font-size: 26rpx;
  line-height: 1.6;
  flex: 1;
}

.review-hint-empty {
  border-left: 6rpx solid var(--border-color);
}

.review-hint-empty .review-hint-text {
  color: var(--text-hint);
}

/* Symbol 组件 */
.review-hint-symbol,
.subject-compare-symbol,
.help-btn-symbol,
.feedback-btn-symbol,
.welcome-symbol {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid var(--text-secondary);
  border-radius: 14rpx;
  margin-right: 16rpx;
  position: relative;
  flex-shrink: 0;
}

.welcome-symbol {
  width: 70rpx;
  height: 70rpx;
  margin: 0 0 18rpx;
  border-radius: 22rpx;
}

.review-hint-symbol::before,
.subject-compare-symbol::before,
.help-btn-symbol::before,
.feedback-btn-symbol::before,
.welcome-symbol::before {
  left: 11rpx;
  right: 11rpx;
  top: 20rpx;
  height: 2rpx;
}

.review-hint-symbol::after,
.subject-compare-symbol::after,
.help-btn-symbol::after,
.feedback-btn-symbol::after,
.welcome-symbol::after {
  top: 11rpx;
  bottom: 11rpx;
  left: 20rpx;
  width: 2rpx;
}

.review-hint-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

/* 科目对比洞察 */
.subject-compare-card {
  margin: 12rpx 30rpx;
}

.subject-compare-row {
  display: flex;
  align-items: flex-start;
}

.subject-compare-icon {
  font-size: 32rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.subject-compare-text {
  font-size: 26rpx;
  line-height: 1.6;
  flex: 1;
}

.subject-compare-empty {
  background-color: var(--card-bg);
  border-color: var(--border-color);
}

.subject-compare-empty .subject-compare-text {
  color: var(--text-hint);
}

/* 新用户欢迎引导 */
.welcome-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 32rpx;
  text-align: center;
}

.welcome-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.welcome-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.welcome-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

/* 版本更新说明 */
.update-notice {
  font-size: 24rpx;
  margin-top: 16rpx;
  display: block;
}

/* 使用帮助按钮 */
.help-btn {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: var(--bg-surface);
  border: 1rpx solid var(--divider-color);
  border-radius: 16rpx;
}

.help-btn-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.help-btn-text {
  font-size: 28rpx;
}

/* 联系反馈按钮 */
.feedback-btn {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: var(--bg-surface);
  border: 1rpx solid var(--divider-color);
  border-radius: 16rpx;
}

.feedback-btn-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.feedback-btn-text {
  font-size: 28rpx;
}

/* ===== R6.1 profile markers ===== */
.r6-profile-stat-strip { /* R6.1 binding */ }
.r6-profile-row-list { /* R6.1 binding */ }
.r6-profile-row { /* R6.1 binding */ }
