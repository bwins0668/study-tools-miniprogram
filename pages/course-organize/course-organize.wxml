<!--pages/course-organize/course-organize.wxml · R2.8 Course Question Organizer-->
<view class="co-page {{__themeDark ? 'dark-theme' : ''}}">

  <!-- Invalid / unknown courseId -->
  <block wx:if="{{status === 'invalid'}}">
    <view class="co-empty">
      <text class="co-empty__title">该课程暂不支持题目整理</text>
      <text class="co-empty__sub">题目整理功能目前仅对资格考试开放</text>
      <view class="co-btn co-btn--outline" bindtap="goBackToCourse">返回课程</view>
    </view>
  </block>

  <!-- Valid course: tab bar + content -->
  <block wx:else>
    <view class="co-head">
      <text class="co-head__title">{{courseName}}</text>
      <text class="co-head__kind">题目整理</text>
    </view>

    <!-- Tab bar: wrong | favorite -->
    <view class="co-tabs">
      <view class="co-tab {{tab === 'wrong' ? 'co-tab--active' : ''}}"
            data-tab="wrong" bindtap="switchTab">
        <text class="co-tab__label">错题</text>
        <text class="co-tab__count">{{wrong.count}}</text>
      </view>
      <view class="co-tab {{tab === 'favorite' ? 'co-tab--active' : ''}}"
            data-tab="favorite" bindtap="switchTab">
        <text class="co-tab__label">收藏</text>
        <text class="co-tab__count">{{favorite.count}}</text>
      </view>
    </view>

    <!-- ===== Wrong tab ===== -->
    <block wx:if="{{tab === 'wrong'}}">
      <block wx:if="{{wrong.status === 'available'}}">
        <view class="co-list">
          <view class="co-item" wx:for="{{wrong.items}}" wx:key="questionId">
            <view class="co-item__body">
              <text class="co-item__title">{{item.questionZh || item.questionJa || '题目 ' + (index + 1)}}</text>
              <text class="co-item__meta">答错于 {{item.wrongAt ? '记录' : '较早时间'}}</text>
            </view>
            <text class="co-item__arrow">→</text>
          </view>
        </view>
        <view class="co-section">
          <text class="co-section__note">以上为本课程错题。按最近答错时间排序。</text>
        </view>
      </block>

      <block wx:elif="{{wrong.status === 'empty'}}">
        <view class="co-empty">
          <text class="co-empty__title">暂无本课程错题</text>
          <text class="co-empty__sub">继续练习后，错题会自动出现在这里</text>
        </view>
      </block>

      <block wx:else>
        <view class="co-empty">
          <text class="co-empty__title">错题状态异常</text>
          <text class="co-empty__sub">请返回课程后重试</text>
        </view>
      </block>

      <!-- Cross-course mistakes bridge (always present) -->
      <view class="co-cross" bindtap="goCrossCourseMistakes">
        <view class="co-cross__body">
          <text class="co-cross__text">查看全部错题</text>
          <text class="co-cross__note">跨课程错题汇总（不限于当前课程）</text>
        </view>
        <text class="co-cross__arrow">→</text>
      </view>
    </block>

    <!-- ===== Favorite tab ===== -->
    <block wx:if="{{tab === 'favorite'}}">
      <block wx:if="{{favorite.status === 'available'}}">
        <view class="co-list">
          <view class="co-item" wx:for="{{favorite.items}}" wx:key="questionId">
            <view class="co-item__body">
              <text class="co-item__title">题目 {{item.questionId}}</text>
              <text class="co-item__meta">收藏于 {{item.createdAt ? '记录' : '较早时间'}}</text>
            </view>
            <text class="co-item__arrow">→</text>
          </view>
        </view>
        <view class="co-section">
          <text class="co-section__note">以上为本课程收藏题目。按收藏时间排序。</text>
        </view>
      </block>

      <block wx:elif="{{favorite.status === 'empty'}}">
        <view class="co-empty">
          <text class="co-empty__title">还没有收藏题目</text>
          <text class="co-empty__sub">答题时点击 ☆ 即可收藏当前题目</text>
        </view>
      </block>

      <block wx:else>
        <view class="co-empty">
          <text class="co-empty__title">收藏状态异常</text>
          <text class="co-empty__sub">请返回课程后重试</text>
        </view>
      </block>
    </block>
  </block>

</view>
