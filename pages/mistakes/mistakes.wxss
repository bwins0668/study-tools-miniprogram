/* pages/mistakes/mistakes.wxss - 错题 tab 轻入口 */

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
  padding: 60rpx 40rpx;
}

.launcher-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.launcher-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.launcher-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.launcher-desc {
  font-size: 26rpx;
  color: var(--text-hint);
  text-align: center;
  margin-bottom: 30rpx;
}

/* 错题总数 */
.stats-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.stats-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #f44336;
  margin-right: 12rpx;
}

.stats-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 分类错题统计 */
.category-stats {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #fef5f5;
  border-radius: 16rpx;
  padding: 20rpx 36rpx;
}

.category-label {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-bottom: 6rpx;
}

.category-count {
  font-size: 32rpx;
  font-weight: 700;
  color: #e8913a;
}

/* 最近错误时间 */
.last-wrong {
  margin-bottom: 30rpx;
}

.last-wrong-text {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 查看详情按钮 */
.launcher-btn {
  background-color: #4a90d9;
  border-radius: 40rpx;
  padding: 28rpx 80rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
  margin-bottom: 24rpx;
}

.launcher-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 去学习按钮 */
.study-btn {
  background-color: #ffffff;
  border: 2rpx solid #4a90d9;
  border-radius: 40rpx;
  padding: 24rpx 60rpx;
}

.study-btn-text {
  font-size: 28rpx;
  color: #4a90d9;
  font-weight: 500;
}

/* 增强空状态 */
.enhanced-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-main {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: var(--text-hint);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 36rpx;
  max-width: 400rpx;
}
