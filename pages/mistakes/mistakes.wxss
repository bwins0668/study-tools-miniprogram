/* pages/mistakes/mistakes.wxss - 错题 tab 轻入口 */

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
  padding: 60rpx 40rpx;
}

.launcher-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.launcher-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.launcher-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 16rpx;
}

.launcher-desc {
  font-size: 26rpx;
  color: #999999;
  text-align: center;
  margin-bottom: 30rpx;
}

.stats-row {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.stats-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #f44336;
  margin-right: 12rpx;
}

.stats-label {
  font-size: 28rpx;
  color: #666666;
}

.launcher-btn {
  background-color: #4a90d9;
  border-radius: 40rpx;
  padding: 28rpx 80rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
  margin-bottom: 24rpx;
}

.launcher-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

.study-btn {
  background-color: #ffffff;
  border: 2rpx solid #4a90d9;
  border-radius: 40rpx;
  padding: 24rpx 60rpx;
}

.study-btn-text {
  font-size: 28rpx;
  color: #4a90d9;
  font-weight: 500;
}

.empty-state {
  margin-top: 30rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #bbbbbb;
}
