/* pages/mistakes/mistakes.wxss - 错题复盘中心 */

.container {
  min-height: 100vh;
  background-color: var(--bg-color);
  padding-bottom: 40rpx;
}

/* === Hero 区域 === */
.mistakes-hero {
  padding: 40rpx 30rpx 28rpx;
  background: linear-gradient(145deg, #3a1a1a 0%, #4d1e1e 40%, #5f2a2a 70%, transparent 100%);
  position: relative;
}

.mistakes-hero::after {
  content: '';
  position: absolute;
  bottom: -20rpx;
  left: 0;
  right: 0;
  height: 40rpx;
  background: linear-gradient(0deg, var(--bg-color) 0%, transparent 100%);
  z-index: 1;
}

.mistakes-hero-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.mistakes-hero-text {
  flex: 1;
}

.mistakes-hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 1rpx;
  margin-bottom: 6rpx;
}

.mistakes-hero-subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.55);
  font-weight: 500;
}

.mistakes-hero-count {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: rgba(239,68,68,0.15);
  border: 1rpx solid rgba(239,68,68,0.25);
  border-radius: 16rpx;
  padding: 10rpx 24rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.mistakes-hero-count-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #ef4444;
}

.mistakes-hero-count-label {
  font-size: 18rpx;
  color: rgba(255,255,255,0.5);
  font-weight: 500;
}

/* 分类标签行 */
.mistakes-category-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.mistakes-cat-chip {
  padding: 6rpx 16rpx;
  border-radius: 14rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.mistakes-cat-itpass {
  background-color: rgba(74,144,217,0.12);
  border: 1rpx solid rgba(74,144,217,0.2);
}

.mistakes-cat-itpass .mistakes-cat-chip-text {
  color: #58a6ff;
}

.mistakes-cat-sg {
  background-color: rgba(156,39,176,0.12);
  border: 1rpx solid rgba(156,39,176,0.2);
}

.mistakes-cat-sg .mistakes-cat-chip-text {
  color: #ce93d8;
}

.mistakes-last-time {
  font-size: 20rpx;
  color: rgba(255,255,255,0.35);
  margin-left: auto;
}

/* === 操作区 === */
.mistakes-actions {
  padding: 20rpx 30rpx 0;
  position: relative;
  z-index: 2;
}

.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 14rpx;
}

.action-tile {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 12rpx 24rpx;
  border-radius: 18rpx;
  background-color: var(--card-bg);
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.05);
  transition: transform 0.15s, box-shadow 0.15s;
  position: relative;
  overflow: hidden;
}

.action-tile:active {
  transform: scale(0.97);
  box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.08);
}

.action-tile::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
}

.action-tile-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.action-tile-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.action-tile-stat {
  font-size: 20rpx;
  color: var(--text-hint);
  font-weight: 500;
}

.action-tile-red::before { background: linear-gradient(90deg, #ef4444, #f87171); }
.action-tile-purple::before { background: linear-gradient(90deg, #9c27b0, #ce93d8); }
.action-tile-blue::before { background: linear-gradient(90deg, #4a90d9, #36d1dc); }

/* === 空状态 === */
.mistakes-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.mistakes-empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.mistakes-empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.mistakes-empty-desc {
  font-size: 26rpx;
  color: var(--text-hint);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 36rpx;
  max-width: 400rpx;
}

.mistakes-empty-btn {
  background-color: #4a90d9;
  border-radius: 40rpx;
  padding: 24rpx 60rpx;
  box-shadow: 0 4rpx 16rpx rgba(74,144,217,0.3);
}

.mistakes-empty-btn-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
}

/* 兼容旧 smoke test 类名 */
.launcher-btn-secondary { background-color: #e8913a; box-shadow: 0 4rpx 16rpx rgba(232,145,58,0.3); }
.study-btn { background-color: #ffffff; border: 2rpx solid #4a90d9; border-radius: 40rpx; padding: 24rpx 60rpx; }
.study-btn-text { font-size: 28rpx; color: #4a90d9; font-weight: 500; }
.enhanced-empty { display:flex; flex-direction:column; align-items:center; margin-top:40rpx; }
.empty-icon { font-size:80rpx; margin-bottom:24rpx; }
.empty-main { font-size:32rpx; font-weight:600; color:var(--text-secondary); margin-bottom:16rpx; }
.empty-sub { font-size:26rpx; color:var(--text-hint); text-align:center; line-height:1.6; margin-bottom:36rpx; max-width:400rpx; }
.stats-row { display:flex; align-items:center; margin-bottom:24rpx; }
.stats-value { font-size:48rpx; font-weight:700; color:#f44336; margin-right:12rpx; }
.stats-label { font-size:28rpx; color:var(--text-secondary); }
.category-stats { display:flex; gap:20rpx; margin-bottom:20rpx; }
.category-item { display:flex; flex-direction:column; align-items:center; background-color:#fef5f5; border-radius:16rpx; padding:20rpx 36rpx; }
.category-label { font-size:24rpx; color:var(--text-hint); margin-bottom:6rpx; }
.category-count { font-size:32rpx; font-weight:700; color:#e8913a; }
.last-wrong { margin-bottom:30rpx; }
.last-wrong-text { font-size:24rpx; color:var(--text-hint); }
.launcher-btn { background-color:#4a90d9; border-radius:40rpx; padding:28rpx 80rpx; box-shadow:0 4rpx 16rpx rgba(74,144,217,0.3); margin-bottom:24rpx; }
.launcher-btn-text { font-size:30rpx; font-weight:600; color:#ffffff; }

/* 浅色模式适配 */
@media (prefers-color-scheme: light) {
  .mistakes-hero {
    background: linear-gradient(145deg, rgba(239,68,68,0.06) 0%, rgba(255,152,0,0.04) 100%);
  }
  .mistakes-hero-title { color: var(--text-primary); }
  .mistakes-hero-subtitle { color: var(--text-secondary); }
  .mistakes-hero-count {
    background-color: rgba(239,68,68,0.08);
    border-color: rgba(239,68,68,0.15);
  }
  .mistakes-hero-count-num { color: #ef4444; }
  .mistakes-hero-count-label { color: var(--text-hint); }
  .mistakes-cat-itpass { background-color: rgba(74,144,217,0.08); border-color: rgba(74,144,217,0.12); }
  .mistakes-cat-itpass .mistakes-cat-chip-text { color: #4a90d9; }
  .mistakes-cat-sg { background-color: rgba(156,39,176,0.08); border-color: rgba(156,39,176,0.12); }
  .mistakes-cat-sg .mistakes-cat-chip-text { color: #9c27b0; }
  .mistakes-last-time { color: var(--text-hint); }
}
