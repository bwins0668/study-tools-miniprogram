/* pages/home/home.wxss */

.header {
  text-align: center;
  padding: 24rpx 30rpx 16rpx;
}

.title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* R3.52 学习时间智能提醒 - 首屏降级隐藏 */
.reminder-banner { display: none; }

/* R3.58 每日学习格言 - 首屏降级隐藏 */
.quote-banner { display: none; }

/* R3.61 练习提醒 - 首屏降级隐藏 */
.practice-reminder-banner { display: none; }

/* R3.79 最近更新提示 - 首屏降级隐藏 */
.update-banner { display: none; }

/* R3.75 快捷操作提示 - 首屏降级隐藏 */
.quick-tips { display: none; }

/* R3.69 分区分隔线 - 首屏降级隐藏 */
.section-divider { display: none; }

/* R3.42 学习 streak */
.streak-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 30rpx;
  background: linear-gradient(135deg, #fff7e6, #ffe6cc);
  border-radius: 20rpx;
  margin: 0 30rpx 16rpx;
}

.streak-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.streak-text {
  font-size: 28rpx;
  color: #e8913a;
  font-weight: 600;
}

/* R3.55 分享按钮 */
.streak-share-btn {
  background-color: transparent !important;
  border: none !important;
  padding: 0 !important;
  margin: 0 0 0 16rpx !important;
  line-height: 1 !important;
  min-height: auto !important;
  display: inline-flex;
  align-items: center;
}

.streak-share-icon {
  font-size: 32rpx;
}

/* 学习概览 */
.overview-section {
  background: linear-gradient(145deg, var(--card-bg), rgba(74, 144, 217, 0.03));
  border-radius: 20rpx;
  margin: 20rpx 30rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08), 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.overview-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.overview-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #4a90d9;
  margin-bottom: 8rpx;
}

.overview-label {
  font-size: 22rpx;
  color: var(--text-hint);
}

.overview-row-extra {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--divider-color);
  justify-content: space-around;
}

.overview-accuracy {
  color: #4caf50;
}

.overview-time {
  font-size: 32rpx;
  color: var(--text-secondary);
}

/* 今日建议 */
.suggestion-card {
  display: flex;
  align-items: flex-start;
  background-color: #f0f7ff;
  border-radius: 16rpx;
  border-left: 8rpx solid #4a90d9;
  margin: 0 30rpx 10rpx;
  padding: 24rpx 28rpx;
}

.suggestion-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.suggestion-text {
  font-size: 26rpx;
  color: #4a6d8c;
  line-height: 1.6;
  flex: 1;
}

.suggestion-content {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.next-action-hint {
  font-size: 24rpx;
  color: #4a90d9;
  font-weight: 600;
  margin-top: 6rpx;
}

/* R3.51 建议操作按钮 */
.suggestion-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background-color: #4a90d9;
  border-radius: 20rpx;
  padding: 10rpx 24rpx;
  margin-top: 12rpx;
  align-self: flex-start;
}

.suggestion-action-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 600;
}

/* R3.52 学习提醒横幅 */
.reminder-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 30rpx;
  background: linear-gradient(135deg, #e8f0fe, #dbeafe);
  border-radius: 12rpx;
  margin: 0 30rpx 20rpx;
}

.reminder-text {
  font-size: 28rpx;
  color: #356a9f;
  font-weight: 500;
  text-align: center;
}

/* R3.58 每日学习格言 */
.quote-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 30rpx;
  background: linear-gradient(135deg, #fef9c3, #fef08a);
  border-radius: 12rpx;
  margin: 0 30rpx 20rpx;
}

.quote-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.quote-text {
  font-size: 26rpx;
  color: #713f12;
  font-weight: 500;
  text-align: center;
  line-height: 1.5;
}

/* R3.61 练习提醒 */
.practice-reminder-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 30rpx;
  background: linear-gradient(135deg, #fee2e2, #fecaca);
  border-radius: 12rpx;
  margin: 0 30rpx 20rpx;
}

.practice-reminder-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.practice-reminder-text {
  font-size: 26rpx;
  color: #92400e;
  font-weight: 500;
  text-align: center;
  line-height: 1.5;
}

/* R3.63 练习提醒关闭按钮 */
.reminder-dismiss-btn {
  position: absolute;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  color: #92400e;
  padding: 8rpx;
}

/* 功能入口 */
.section-label {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  padding: 30rpx 30rpx 10rpx;
}

.card-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  padding: 0 24rpx 32rpx;
}

.card-entry {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(145deg, var(--card-bg), rgba(74, 144, 217, 0.03));
  border-radius: 18rpx;
  padding: 20rpx 12rpx 18rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08), 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.card-entry:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.card-icon {
  font-size: 40rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  flex-shrink: 0;
  background: rgba(74, 144, 217, 0.08);
  border-radius: 14rpx;
}

.card-entry {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: var(--card-bg);
  border-radius: 16rpx;
  padding: 28rpx 16rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  text-align: center;
}

.card-icon {
  font-size: 48rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  flex-shrink: 0;
}

.card-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
  width: 100%;
}

.card-title-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 2rpx;
  width: 100%;
}

.card-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 2rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.card-title-wrap .card-title {
  margin-bottom: 0;
  flex: 1;
  min-width: 0;
}

.card-desc {
  font-size: 18rpx;
  color: var(--text-hint);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.card-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 4rpx;
  gap: 6rpx;
  flex-wrap: wrap;
}

.card-stat-text {
  font-size: 16rpx;
  color: #4a90d9;
}

.card-stat-new {
  color: var(--text-hint);
}

.card-stat-status {
  font-size: 14rpx;
  color: #ffffff;
  background-color: #4a90d9;
  padding: 1rpx 6rpx;
  border-radius: 10rpx;
}

.card-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  font-size: 16rpx;
  font-weight: 600;
  color: #ffffff;
  background-color: #e74c3c;
  min-width: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
  text-align: center;
  border-radius: 14rpx;
  padding: 0 6rpx;
}

.card-entry {
  position: relative;
}

.card-arrow {
  display: none;
  flex-shrink: 0;
}

.card-arrow-disabled {
  color: var(--border-color);
}

/* 弱项徽标 */
.card-title-wrap {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.card-weak-badge {
  font-size: 20rpx;
  font-weight: 600;
  color: #e65100;
  background-color: #fff3e0;
  border: 1rpx solid #ffcc80;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
  white-space: nowrap;
}

/* 最近练习时间 */
.card-last-time {
  font-size: 20rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
}

/* 我的统计入口 */
.card-entry-profile {
  border: 2rpx solid #4a90d9;
  background-color: #fafbff;
}

/* 继续学习 */
.continue-section {
  padding: 0 30rpx;
  margin-top: 10rpx;
}

.continue-card {
  display: flex;
  align-items: center;
  background-color: var(--card-bg);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.continue-icon {
  font-size: 40rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.continue-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.continue-exam {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.continue-hint {
  font-size: 22rpx;
  color: var(--text-hint);
}

.continue-meta-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.continue-time {
  font-size: 20rpx;
  color: var(--text-hint);
}

.continue-suggestion-bar {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  padding: 12rpx 24rpx;
  background-color: #f0f7ff;
  border-radius: 10rpx;
  border-left: 6rpx solid #4a90d9;
}

.continue-suggestion-text {
  font-size: 24rpx;
  color: #4a6d8c;
  line-height: 1.5;
}

.continue-btn {
  font-size: 26rpx;
  color: #ffffff;
  background-color: #4a90d9;
  padding: 14rpx 28rpx;
  border-radius: 30rpx;
  flex-shrink: 0;
}

.continue-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: var(--card-bg);
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.continue-empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.continue-empty-hint {
  font-size: 22rpx;
  color: var(--text-hint);
  text-align: center;
}

.quick-start-btn {
  font-size: 28rpx;
  color: #ffffff;
  background-color: #4a90d9;
  padding: 20rpx 48rpx;
  border-radius: 40rpx;
  margin-top: 24rpx;
  text-align: center;
}

/* R3.44 今日练习进度 */
.goal-section {
  background-color: var(--card-bg);
  border-radius: 16rpx;
  margin: 20rpx 30rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.goal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.goal-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.goal-text {
  font-size: 26rpx;
  color: #4a90d9;
  font-weight: 500;
}

.goal-bar-wrap {
  height: 16rpx;
  background-color: var(--divider-color);
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.goal-bar {
  height: 100%;
  background: linear-gradient(90deg, #4a90d9, #81c784);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.goal-reminder {
  font-size: 24rpx;
  color: #ff9800;
  text-align: center;
  margin-top: 8rpx;
}

/* R3.53 今日练习完成庆祝 */
.goal-celebrate {
  font-size: 32rpx;
  margin-left: 12rpx;
  animation: celebrate-bounce 0.6s ease-in-out infinite alternate;
}

.goal-bar-complete {
  background: linear-gradient(90deg, #4caf50, #81c784) !important;
}

@keyframes celebrate-bounce {
  0% {
    transform: scale(1);
  }
  100% {
    transform: scale(1.2);
  }
}

/* R3.47 学习成就系统 */
.achievement-section {
  margin: 24rpx 24rpx 0;
  padding: 24rpx;
  background: var(--card-bg);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.achievement-list {
  margin-top: 16rpx;
  white-space: nowrap;
}

.achievement-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  height: 140rpx;
  margin-right: 16rpx;
  background: linear-gradient(135deg, #fff3e0, #ffe0b2);
  border-radius: 16rpx;
  padding: 12rpx;
}

.achievement-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.achievement-name {
  font-size: 20rpx;
  color: #e65100;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 120rpx;
}

/* R3.67 页脚版本号 */
.footer {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 30rpx 60rpx;
}

.footer-text {
  font-size: 24rpx;
  color: var(--text-hint);
}
.section-divider {
  height: 2rpx;
  background-color: var(--divider-color);
  margin: 20rpx 30rpx;
}

/* R3.72 返回顶部按钮 */
.back-to-top {
  position: fixed;
  right: 30rpx;
  bottom: 100rpx;
  width: 80rpx;
  height: 80rpx;
  background-color: #1890ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.4);
  z-index: 100;
}

.back-to-top-icon {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: bold;
}

/* R3.75 快捷操作提示 */
.quick-tips {
  margin: 20rpx 30rpx;
  padding: 20rpx;
  background-color: #fff7e6;
  border-radius: 8rpx;
  border-left: 4rpx solid #fa8c16;
}

.quick-tips-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #fa8c16;
  display: block;
  margin-bottom: 8rpx;
}

.quick-tips-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* R3.76 下拉刷新提示 */
.footer-hint {
  font-size: 20rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}

/* R3.77 页面浏览次数 */
.footer-view-count {
  font-size: 20rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
  display: block;
}

/* R3.79 最近更新提示 */
.update-banner {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #e6f7ff;
  border-bottom: 1rpx solid #91d5ff;
}

.update-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.update-text {
  flex: 1;
  font-size: 26rpx;
  color: #1890ff;
}

.update-dismiss-btn {
  font-size: 32rpx;
  color: #1890ff;
  padding: 8rpx;
  cursor: pointer;
}


/* 首页紧凑状态条 */
.today-status {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background-color: var(--card-bg);
  border-radius: 16rpx;
  margin: 0 30rpx 16rpx;
  padding: 20rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}
.today-status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}
.today-status-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #4a90d9;
}
.today-status-label {
  font-size: 20rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
}
.today-status-accuracy {
  color: #4caf50;
}
.today-status-divider {
  width: 1rpx;
  height: 40rpx;
  background-color: var(--divider-color);
}

/* 紧凑进度条 */
.goal-bar-compact {
  display: flex;
  align-items: center;
  margin: 0 30rpx 16rpx;
  gap: 16rpx;
}
.goal-bar-track {
  flex: 1;
  height: 8rpx;
  background-color: var(--border-color);
  border-radius: 4rpx;
  overflow: hidden;
}
.goal-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #4a90d9, #58a6ff);
  border-radius: 4rpx;
  transition: width 0.3s;
}
.goal-bar-complete {
  background: linear-gradient(90deg, #4caf50, #66bb6a);
}
.goal-bar-text {
  font-size: 22rpx;
  color: var(--text-hint);
  white-space: nowrap;
}

/* 紧凑继续学习 */
.continue-compact {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: var(--card-bg);
  border-radius: 16rpx;
  margin: 0 30rpx 16rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}
.continue-compact-text {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}
.continue-compact-arrow {
  font-size: 32rpx;
  color: var(--text-hint);
}

/* 紧凑建议 */
.suggestion-compact {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: var(--card-bg);
  border-radius: 16rpx;
  border-left: 6rpx solid #4a90d9;
  margin: 0 30rpx 16rpx;
  padding: 20rpx 24rpx;
}
.suggestion-compact-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  flex: 1;
  min-width: 0;
}
.suggestion-compact-action {
  font-size: 24rpx;
  color: #4a90d9;
  font-weight: 600;
  white-space: nowrap;
  margin-left: 16rpx;
}

/* ===== 深色模式覆盖（Round 3.95） ===== */
@media (prefers-color-scheme: dark) {
  .streak-banner {
    background: linear-gradient(135deg, #2a1a0a, #3a2520) !important;
  }
  .streak-text {
    color: #e8a040 !important;
  }
  .suggestion-card {
    background-color: #0d1b2a !important;
    border-left-color: #58a6ff !important;
  }
  .suggestion-text {
    color: #8bb4d8 !important;
  }
  .next-action-hint {
    color: #58a6ff !important;
  }
  .reminder-banner {
    background: linear-gradient(135deg, #0d1b2a, #1a2a3e) !important;
  }
  .reminder-text {
    color: #8bb4d8 !important;
