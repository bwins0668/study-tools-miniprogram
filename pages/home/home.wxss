/* pages/home/home.wxss */

.header {
  text-align: center;
  padding: 50rpx 30rpx 30rpx;
}

.title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #888888;
}

/* R3.42 学习 streak */
.streak-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 30rpx;
  background: linear-gradient(135deg, #fff7e6, #ffe6cc);
  border-radius: 12rpx;
  margin: 0 30rpx 20rpx;
}

.streak-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.streak-text {
  font-size: 28rpx;
  color: #e8913a;
  font-weight: 600;
}

/* R3.55 分享按钮 */
.streak-share-btn {
  background-color: transparent !important;
  border: none !important;
  padding: 0 !important;
  margin: 0 0 0 16rpx !important;
  line-height: 1 !important;
  min-height: auto !important;
  display: inline-flex;
  align-items: center;
}

.streak-share-icon {
  font-size: 32rpx;
}

/* 学习概览 */
.overview-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin: 20rpx 30rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.overview-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.overview-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #4a90d9;
  margin-bottom: 8rpx;
}

.overview-label {
  font-size: 22rpx;
  color: #999999;
}

.overview-row-extra {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  justify-content: space-around;
}

.overview-accuracy {
  color: #4caf50;
}

.overview-time {
  font-size: 32rpx;
  color: #666666;
}

/* 今日建议 */
.suggestion-card {
  display: flex;
  align-items: flex-start;
  background-color: #f0f7ff;
  border-radius: 16rpx;
  border-left: 8rpx solid #4a90d9;
  margin: 0 30rpx 10rpx;
  padding: 24rpx 28rpx;
}

.suggestion-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.suggestion-text {
  font-size: 26rpx;
  color: #4a6d8c;
  line-height: 1.6;
  flex: 1;
}

.suggestion-content {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.next-action-hint {
  font-size: 24rpx;
  color: #4a90d9;
  font-weight: 600;
  margin-top: 6rpx;
}

/* R3.51 建议操作按钮 */
.suggestion-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background-color: #4a90d9;
  border-radius: 20rpx;
  padding: 10rpx 24rpx;
  margin-top: 12rpx;
  align-self: flex-start;
}

.suggestion-action-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 600;
}

/* R3.52 学习提醒横幅 */
.reminder-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 30rpx;
  background: linear-gradient(135deg, #e8f0fe, #dbeafe);
  border-radius: 12rpx;
  margin: 0 30rpx 20rpx;
}

.reminder-text {
  font-size: 28rpx;
  color: #356a9f;
  font-weight: 500;
  text-align: center;
}

/* R3.58 每日学习格言 */
.quote-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 30rpx;
  background: linear-gradient(135deg, #fef9c3, #fef08a);
  border-radius: 12rpx;
  margin: 0 30rpx 20rpx;
}

.quote-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.quote-text {
  font-size: 26rpx;
  color: #713f12;
  font-weight: 500;
  text-align: center;
  line-height: 1.5;
}

/* R3.61 练习提醒 */
.practice-reminder-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 30rpx;
  background: linear-gradient(135deg, #fee2e2, #fecaca);
  border-radius: 12rpx;
  margin: 0 30rpx 20rpx;
}

.practice-reminder-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.practice-reminder-text {
  font-size: 26rpx;
  color: #92400e;
  font-weight: 500;
  text-align: center;
  line-height: 1.5;
}

/* R3.63 练习提醒关闭按钮 */
.reminder-dismiss-btn {
  position: absolute;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  color: #92400e;
  padding: 8rpx;
}

/* 功能入口 */
.section-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  padding: 30rpx 30rpx 10rpx;
}

.card-list {
  padding: 0 0 40rpx;
}

.card-entry {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 36rpx 32rpx;
  margin: 16rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-icon {
  font-size: 48rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.card-title-wrap {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
  width: 100%;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-title-wrap .card-title {
  margin-bottom: 0;
  flex: 1;
  min-width: 0;
}

.card-desc {
  font-size: 24rpx;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-stats {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
  gap: 16rpx;
}

.card-stat-text {
  font-size: 22rpx;
  color: #4a90d9;
}

.card-stat-new {
  color: #bbbbbb;
}

.card-stat-status {
  font-size: 20rpx;
  color: #ffffff;
  background-color: #4a90d9;
  padding: 2rpx 12rpx;
  border-radius: 16rpx;
}

.card-badge {
  font-size: 22rpx;
  font-weight: 600;
  color: #ffffff;
  background-color: #e74c3c;
  min-width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 20rpx;
  padding: 0 12rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.card-arrow {
  font-size: 36rpx;
  color: #cccccc;
  flex-shrink: 0;
}

.card-arrow-disabled {
  color: #dddddd;
}

/* 弱项徽标 */
.card-title-wrap {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.card-weak-badge {
  font-size: 20rpx;
  font-weight: 600;
  color: #e65100;
  background-color: #fff3e0;
  border: 1rpx solid #ffcc80;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
  white-space: nowrap;
}

/* 最近练习时间 */
.card-last-time {
  font-size: 20rpx;
  color: #999999;
  margin-top: 4rpx;
}

/* 我的统计入口 */
.card-entry-profile {
  border: 2rpx solid #4a90d9;
  background-color: #fafbff;
}

/* 继续学习 */
.continue-section {
  padding: 0 30rpx;
  margin-top: 10rpx;
}

.continue-card {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.continue-icon {
  font-size: 40rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.continue-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.continue-exam {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.continue-hint {
  font-size: 22rpx;
  color: #999999;
}

.continue-meta-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.continue-time {
  font-size: 20rpx;
  color: #bbbbbb;
}

.continue-suggestion-bar {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  padding: 12rpx 24rpx;
  background-color: #f0f7ff;
  border-radius: 10rpx;
  border-left: 6rpx solid #4a90d9;
}

.continue-suggestion-text {
  font-size: 24rpx;
  color: #4a6d8c;
  line-height: 1.5;
}

.continue-btn {
  font-size: 26rpx;
  color: #ffffff;
  background-color: #4a90d9;
  padding: 14rpx 28rpx;
  border-radius: 30rpx;
  flex-shrink: 0;
}

.continue-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.continue-empty-text {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.continue-empty-hint {
  font-size: 22rpx;
  color: #bbbbbb;
  text-align: center;
}

.quick-start-btn {
  font-size: 28rpx;
  color: #ffffff;
  background-color: #4a90d9;
  padding: 20rpx 48rpx;
  border-radius: 40rpx;
  margin-top: 24rpx;
  text-align: center;
}

/* R3.44 今日练习进度 */
.goal-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin: 20rpx 30rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.goal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.goal-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.goal-text {
  font-size: 26rpx;
  color: #4a90d9;
  font-weight: 500;
}

.goal-bar-wrap {
  height: 16rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.goal-bar {
  height: 100%;
  background: linear-gradient(90deg, #4a90d9, #81c784);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.goal-reminder {
  font-size: 24rpx;
  color: #ff9800;
  text-align: center;
  margin-top: 8rpx;
}

/* R3.53 今日练习完成庆祝 */
.goal-celebrate {
  font-size: 32rpx;
  margin-left: 12rpx;
  animation: celebrate-bounce 0.6s ease-in-out infinite alternate;
}

.goal-bar-complete {
  background: linear-gradient(90deg, #4caf50, #81c784) !important;
}

@keyframes celebrate-bounce {
  0% {
    transform: scale(1);
  }
  100% {
    transform: scale(1.2);
  }
}

/* R3.47 学习成就系统 */
.achievement-section {
  margin: 24rpx 24rpx 0;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.achievement-list {
  margin-top: 16rpx;
  white-space: nowrap;
}

.achievement-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  height: 140rpx;
  margin-right: 16rpx;
  background: linear-gradient(135deg, #fff3e0, #ffe0b2);
  border-radius: 16rpx;
  padding: 12rpx;
}

.achievement-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.achievement-name {
  font-size: 20rpx;
  color: #e65100;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 120rpx;
}

/* R3.67 页脚版本号 */
.footer {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 30rpx 60rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #999999;
}
.section-divider {\n  height: 2rpx;\n  background-color: #f0f0f0;\n  margin: 20rpx 30rpx;\n}

/* R3.72 返回顶部按钮 */
.back-to-top {
  position: fixed;
  right: 30rpx;
  bottom: 100rpx;
  width: 80rpx;
  height: 80rpx;
  background-color: #1890ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.4);
  z-index: 100;
}

.back-to-top-icon {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: bold;
}
