@import "../../styles/tokens.wxss";

/* pages/home/home.wxss · Course Center landing page (QP style) */

page { background-color: var(--qp-color-canvas); }

.cc-home {
  min-height: 100vh; box-sizing: border-box;
  padding: 0 var(--qp-space-5) calc(100rpx + env(safe-area-inset-bottom));
  background-color: var(--qp-color-canvas); color: var(--qp-color-ink);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: var(--qp-font-size-body); line-height: var(--qp-line-height-normal);
}

.cc-mast {
  /* R6.5.4: flex-start aligns kicker top with date top on same baseline */
  display: flex; align-items: flex-start; justify-content: space-between;
  padding: 4rpx 0 0; margin-bottom: 22rpx;
}
.cc-mast__kicker {
  display: block; margin-bottom: 8rpx;
  font-family: var(--qp-font-family-data); font-size: 20rpx; font-weight: var(--qp-font-weight-semibold);
  letter-spacing: 0; color: var(--qp-color-editorial);
}
.cc-mast__title {
  display: block; font-size: var(--qp-font-size-masthead); line-height: 1;
  font-weight: var(--qp-font-weight-semibold); letter-spacing: 0; color: var(--qp-color-ink);
}
.cc-mast__meta {
  padding-bottom: 6rpx; font-family: var(--qp-font-family-data);
  font-size: 24rpx; color: var(--qp-color-text-secondary);
}
.cc-mast__meta__num {
  color: var(--qp-color-primary);
  font-weight: var(--qp-font-weight-semibold);
  font-size: 30rpx;
}
.cc-rule {
  display: flex; align-items: center; margin-bottom: 28rpx;
}
.cc-rule__accent { width: 60rpx; height: 4rpx; background: var(--qp-color-primary); }
.cc-rule__line { flex: 1; height: 2rpx; background: var(--qp-color-ink); opacity: 0.72; }

/* ===== A. Hero ===== */
.cc-hero {
  padding: 32rpx 28rpx; margin-bottom: 24rpx;
  background-color: var(--qp-color-surface);
  border: var(--qp-border-width) solid var(--qp-color-line);
  border-top: 5rpx solid var(--qp-color-editorial);
  border-radius: var(--qp-radius-lg);
}
.cc-hero__kicker {
  display: block; font-size: 20rpx; font-weight: var(--qp-font-weight-semibold);
  letter-spacing: 2rpx; color: var(--qp-color-primary); text-transform: uppercase; margin-bottom: 8rpx;
}
.cc-hero__title {
  display: block; font-size: 34rpx; line-height: var(--qp-line-height-tight);
  font-weight: var(--qp-font-weight-semibold); color: var(--qp-color-ink);
}
.cc-hero__sub {
  display: block; margin-top: 6rpx; font-size: 24rpx; color: var(--qp-color-text-secondary);
}
.cc-hero__actions {
  display: flex; gap: 16rpx; margin-top: 24rpx;
}
.cc-hero__streak {
  display: block; margin-top: 16rpx; font-size: var(--qp-font-size-caption); color: var(--qp-color-text-tertiary);
}

/* Buttons */
.cc-btn {
  flex: 1; text-align: center; padding: 18rpx 0; border-radius: var(--qp-radius-md);
  font-size: 28rpx; font-weight: var(--qp-font-weight-semibold); line-height: 1.4;
}
.cc-btn--primary { background-color: var(--qp-color-primary); color: var(--qp-color-surface); }
.cc-btn--outline { background-color: var(--qp-color-fill-warm); border: var(--qp-border-width) solid transparent; color: var(--qp-color-ink); }

/* ===== B/C. Sections ===== */
.cc-section { margin-bottom: 32rpx; }
.cc-section__title {
  display: block; margin-bottom: 12rpx;
  font-size: var(--qp-font-size-label); font-weight: var(--qp-font-weight-regular);
  letter-spacing: 2rpx; color: var(--qp-color-text-tertiary);
}

/* Course cards (single-column large) */
.r6-course-strip { display: flex; flex-direction: column; gap: 16rpx; }
.r6-course-strip__item {
  display: flex;
  flex-direction: column;
  padding: 20rpx 24rpx;
  background: var(--qp-color-surface);
  border-radius: var(--qp-radius-md);
  border: var(--qp-border-width) solid var(--qp-color-line);
  gap: 4rpx;
}
.r6-course-strip__abbr {
  font-family: var(--qp-font-family-data);
  font-size: 20rpx;
  font-weight: var(--qp-font-weight-semibold);
  color: var(--qp-color-primary);
}
.r6-course-strip__name {
  font-size: 26rpx;
  font-weight: var(--qp-font-weight-semibold);
  color: var(--qp-color-ink);
}
.r6-course-strip__item--pressed {
  opacity: 0.7;
}
.r6-course-strip__item--planned {
  opacity: 0.5;
}
.cc-course-card {
  padding: 28rpx; background-color: var(--qp-color-surface);
  border: var(--qp-border-width) solid var(--qp-color-line); border-radius: var(--qp-radius-lg);
}
.cc-course-card--planned { opacity: 0.7; }
.cc-course-card__name {
  display: block; font-size: 28rpx; font-weight: var(--qp-font-weight-semibold); color: var(--qp-color-ink);
}
.r6-course-strip__desc {
  display: block; margin-top: 4rpx; font-size: 22rpx; color: var(--qp-color-text-secondary);
}
.cc-course-card__badge {
  display: inline-block; margin-top: 12rpx; padding: 4rpx 16rpx;
  border-radius: 999rpx; background-color: var(--qp-color-surface-muted);
}
.cc-course-card__badge-text { font-size: 20rpx; color: var(--qp-color-text-tertiary); }

/* Exam cards (compact two-column feel) */
.cc-exam-list { display: flex; flex-direction: column; gap: 12rpx; }
.cc-exam-card {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx; background-color: var(--qp-color-surface);
  border: var(--qp-border-width) solid var(--qp-color-line); border-radius: var(--qp-radius-lg);
}
.cc-course-card:active,
.cc-exam-card:active,
.cc-btn:active,
.cc-record-link:active,
.home-card-pressed {
  transform: scale(0.98);
  opacity: 0.92;
}
.cc-exam-card--muted { opacity: 0.55; }
.cc-exam-card__body { flex: 1; min-width: 0; }
.cc-exam-card__name {
  display: block; font-size: 28rpx; font-weight: var(--qp-font-weight-semibold); color: var(--qp-color-ink);
}
.cc-exam-card__desc {
  display: block; margin-top: 2rpx; font-size: 22rpx; color: var(--qp-color-text-secondary);
}
.cc-exam-card__action {
  flex: none; margin-left: 16rpx; padding: 10rpx 24rpx;
  border-radius: var(--qp-radius-md); background-color: var(--qp-color-primary); color: var(--qp-color-surface);
  font-size: 24rpx; font-weight: var(--qp-font-weight-semibold); white-space: nowrap;
}
.cc-exam-card__status {
  flex: none; margin-left: 16rpx; font-size: 22rpx; color: var(--qp-color-text-tertiary); white-space: nowrap;
}

/* ===== D. Record ===== */
.cc-record-link {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 0; border-top: var(--qp-border-width) solid var(--qp-color-line);
}
.cc-record-link__text { font-size: var(--qp-font-size-body); color: var(--qp-color-text-secondary); }
.cc-record-link__arrow { font-size: 24rpx; color: var(--qp-color-text-tertiary); }

/* Back to top */
.cc-backtop {
  position: fixed; right: var(--qp-space-4);
  bottom: calc(var(--qp-space-6) + env(safe-area-inset-bottom));
  width: 72rpx; height: 72rpx; display: flex; align-items: center; justify-content: center;
  background-color: var(--qp-color-surface);
  border: var(--qp-border-width) solid var(--qp-color-line-strong); border-radius: var(--qp-radius-lg);
  color: var(--qp-color-text-secondary);
}
.cc-backtop__icon { font-size: var(--qp-font-size-section-title); line-height: 1; }

/* ===== Dark theme ===== */
.cc-home.dark-theme { background-color: var(--bg-color); color: var(--text-primary); }
.dark-theme .cc-hero__title,
.dark-theme .cc-course-card__name,
.dark-theme .cc-exam-card__name { color: var(--text-primary); }
.dark-theme .cc-hero__sub,
.dark-theme .r6-course-strip__desc,
.dark-theme .cc-exam-card__desc { color: var(--text-secondary); }
.dark-theme .cc-hero,
.dark-theme .cc-course-card,
.dark-theme .cc-exam-card { background-color: var(--card-bg); border-color: var(--border-color); }
.dark-theme .cc-btn--outline { color: var(--text-primary); border-color: var(--border-color); }
.dark-theme .cc-backtop { background-color: var(--card-bg); border-color: var(--border-color); color: var(--text-secondary); }
.dark-theme .cc-record-link { border-top-color: var(--border-color); }

/* ===== R6.1 section label ===== */
.r6-section-label {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 6rpx;
}
.r6-section-label__num {
  font-family: var(--qp-font-family-data);
  font-size: 48rpx;
  font-weight: var(--qp-font-weight-semibold);
  color: var(--qp-color-text-phantom);
  line-height: .8;
}
.r6-section-label__meta {
  font-family: var(--qp-font-family-data);
  font-size: var(--qp-font-size-label);
  color: var(--qp-color-text-ghost);
}
.r6-section-label .cc-section__title {
  font-size: var(--qp-font-size-section-title);
  font-weight: var(--qp-font-weight-semibold);
}
.r6-section-label::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: var(--qp-color-line);
}
/* ===== R6.1 exam row ===== */
.r6-exam-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 13rpx 14rpx;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
  border-left: 3rpx solid var(--qp-color-primary);
}
.cc-exam-card--muted.r6-exam-row {
  border-left-color: var(--qp-color-line);
  opacity: 1;
}
.r6-exam-row__action {
  flex-shrink: 0;
  color: var(--qp-color-primary);
  font-weight: var(--qp-font-weight-semibold);
  font-size: var(--qp-font-size-caption);
}

/* ===== R6.3 masthead date ===== */
.cc-mast__right {
  /* R6.5.4C: column flex with center alignment — date on top, streak centered below */
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 4rpx;
}
.cc-mast__date {
  display: block;
  font-family: var(--qp-font-family-data);
  font-size: 18rpx;
  color: var(--qp-color-editorial);
  font-weight: var(--qp-font-weight-semibold);
  letter-spacing: .1em;
  margin-bottom: 12rpx;
}
.cc-mast__streak {
  display: block;
  font-family: var(--qp-font-family-data);
  font-size: 24rpx;
  color: var(--qp-color-text-secondary);
}
.cc-mast__streak__num {
  color: var(--qp-color-primary);
  font-weight: var(--qp-font-weight-semibold);
  font-size: 30rpx;
}

/* ===== R6.5: DC-accurate hero variants ===== */
.cc-hero__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.cc-hero__time {
  font-family: var(--qp-font-family-data);
  font-size: 22rpx;
  color: var(--qp-color-text-ghost);
}
.cc-btn__arrow {
  font-family: var(--qp-font-family-data);
  font-size: 30rpx;
}

/* Start state hero */
.cc-hero--start {
  border-top-color: var(--qp-color-editorial);
}
.cc-hero__exam-pick {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}
.cc-hero__exam-opt {
  flex: 1;
  border: 2rpx solid rgba(33,31,28,0.14);
  border-radius: var(--qp-radius-md);
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  font-weight: var(--qp-font-weight-semibold);
  color: var(--qp-color-text-secondary);
  text-align: center;
}
.cc-hero__exam-opt--primary {
  border-color: var(--qp-color-primary);
  color: var(--qp-color-ink);
}

/* ===== R6.5: DC-accurate exam rows ===== */
.cc-exam-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 26rpx 28rpx;
  border-radius: var(--qp-radius-md);
  margin-bottom: 8rpx;
  border-left: 3rpx solid transparent;
  background: var(--qp-color-surface);
  border: var(--qp-border-width) solid var(--qp-color-line);
}
.cc-exam-row--primary {
  background: var(--qp-color-primary-soft);
  border-left: 3rpx solid var(--qp-color-primary);
}
.cc-exam-row--muted {
  opacity: 0.55;
  border-left: 3rpx solid var(--qp-color-line);
}
.cc-exam-row--pressed {
  opacity: 0.85;
  transform: scale(0.985);
}
.cc-exam-row__body {
  flex: 1;
  min-width: 0;
}
.cc-exam-row__name {
  display: block;
  font-size: 31rpx;
  font-weight: var(--qp-font-weight-semibold);
  color: var(--qp-color-ink);
}
.cc-exam-row__desc {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--qp-color-text-secondary);
}
.cc-exam-row__action {
  flex: none;
  margin-left: 16rpx;
  padding: 10rpx 24rpx;
  border-radius: var(--qp-radius-md);
  background: var(--qp-color-primary);
  color: var(--qp-color-surface);
  font-size: 24rpx;
  font-weight: var(--qp-font-weight-semibold);
}
.cc-exam-row__chev {
  flex: none;
  font-size: 32rpx;
  color: var(--qp-color-text-ghost);
  margin-left: 8rpx;
}
.cc-exam-row__badge {
  flex: none;
  margin-left: 16rpx;
  font-size: 22rpx;
  color: var(--qp-color-text-tertiary);
}

/* R6.5: course strip badge */
.r6-course-strip__badge {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 8rpx 0;
  font-size: 22rpx;
  color: var(--qp-color-text-ghost);
}

