/* pages/home/home.wxss */

.header {
  text-align: center;
  padding: 50rpx 30rpx 30rpx;
}

.title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #888888;
}

/* 学习概览 */
.overview-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin: 20rpx 30rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.overview-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.overview-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #4a90d9;
  margin-bottom: 8rpx;
}

.overview-label {
  font-size: 22rpx;
  color: #999999;
}

.overview-row-extra {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  justify-content: space-around;
}

.overview-accuracy {
  color: #4caf50;
}

.overview-time {
  font-size: 32rpx;
  color: #666666;
}

/* 今日建议 */
.suggestion-card {
  display: flex;
  align-items: flex-start;
  background-color: #f0f7ff;
  border-radius: 16rpx;
  border-left: 8rpx solid #4a90d9;
  margin: 0 30rpx 10rpx;
  padding: 24rpx 28rpx;
}

.suggestion-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.suggestion-text {
  font-size: 26rpx;
  color: #4a6d8c;
  line-height: 1.6;
  flex: 1;
}

/* 功能入口 */
.section-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  padding: 30rpx 30rpx 10rpx;
}

.card-list {
  padding: 0 0 40rpx;
}

.card-entry {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 36rpx 32rpx;
  margin: 16rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-icon {
  font-size: 48rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-desc {
  font-size: 24rpx;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-badge {
  font-size: 22rpx;
  font-weight: 600;
  color: #ffffff;
  background-color: #e74c3c;
  min-width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 20rpx;
  padding: 0 12rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.card-arrow {
  font-size: 36rpx;
  color: #cccccc;
  flex-shrink: 0;
}

.card-arrow-disabled {
  color: #dddddd;
}

/* 我的统计入口 */
.card-entry-profile {
  border: 2rpx solid #4a90d9;
  background-color: #fafbff;
}

/* 继续学习 */
.continue-section {
  padding: 0 30rpx;
  margin-top: 10rpx;
}

.continue-card {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.continue-icon {
  font-size: 40rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.continue-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.continue-exam {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.continue-hint {
  font-size: 22rpx;
  color: #999999;
}

.continue-btn {
  font-size: 26rpx;
  color: #ffffff;
  background-color: #4a90d9;
  padding: 14rpx 28rpx;
  border-radius: 30rpx;
  flex-shrink: 0;
}

.continue-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.continue-empty-text {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.continue-empty-hint {
  font-size: 22rpx;
  color: #bbbbbb;
  text-align: center;
}
