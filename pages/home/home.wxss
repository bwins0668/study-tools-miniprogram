@import "../../styles/tokens.wxss";

/* pages/home/home.wxss · Quiet Paper 学习驾驶舱（UI Freeze v1 · 高保真对齐冻结原型）
   浅色：全部用 styles/tokens.wxss 的 --qp-* 令牌（与设计稿同色：canvas #FAF9F6 / primary #37418A / danger #BE5750）。
   深色：仅在 .dark-theme 作用域回退 app.wxss 既有旧令牌（--bg-color/--text-primary/--card-bg/--border-color…），
         不为 --qp-* 引入深色变体，不改 app.wxss / theme.json。
   8pt 节奏；标题克制（≤600，无 700/800）；所有数字 .qp-num 用 data 字体。 */

page {
  background-color: var(--qp-color-canvas);
}

.qp-home {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 0 var(--qp-space-5) calc(128rpx + env(safe-area-inset-bottom));
  background-color: var(--qp-color-canvas);
  color: var(--qp-color-ink);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Hiragino Kaku Gothic ProN", "Microsoft YaHei", sans-serif;
  font-size: var(--qp-font-size-body);
  line-height: var(--qp-line-height-normal);
}

/* 数字统一等宽字体 */
.qp-num {
  font-family: var(--qp-font-family-data);
  font-variant-numeric: tabular-nums;
}
.qp-ink-strong {
  color: var(--qp-color-primary);
  font-weight: var(--qp-font-weight-semibold);
}

/* ===== A · 顶部学习面板 ===== */
.qp-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.qp-head__title {
  font-size: 38rpx;
  font-weight: var(--qp-font-weight-semibold);
  color: var(--qp-color-ink);
  letter-spacing: -0.5rpx;
  line-height: 1.2;
}
.qp-head__meta {
  display: flex;
  align-items: baseline;
  font-size: var(--qp-font-size-caption);
  color: var(--qp-color-text-secondary);
}
.qp-head__dot {
  margin: 0 var(--qp-space-2);
  color: var(--qp-color-text-tertiary);
}
.qp-head__date {
  font-size: 22rpx;
  line-height: 1.2;
  color: var(--qp-color-text-secondary);
}
.qp-head__streak {
  color: var(--qp-color-text-secondary);
}

/* ===== B · 主行动区（继续上次 / 开始今日） ===== */
.qp-focus {
  box-sizing: border-box;
  padding: 28rpx;
  background-color: var(--qp-color-surface);
  border: var(--qp-border-width) solid var(--qp-color-line);
  border-radius: var(--qp-radius-lg);
  margin-bottom: 32rpx;
}
.qp-focus__kicker {
  display: block;
  font-size: 20rpx;
  font-weight: var(--qp-font-weight-semibold);
  letter-spacing: 2rpx;
  color: var(--qp-color-primary);
  text-transform: uppercase;
  margin-bottom: var(--qp-space-2);
}
.qp-focus__title {
  display: block;
  font-size: 34rpx;
  line-height: var(--qp-line-height-tight);
  font-weight: var(--qp-font-weight-semibold);
  color: var(--qp-color-ink);
}
.qp-focus__sub {
  display: block;
  margin-top: var(--qp-space-1);
  font-size: 24rpx;
  color: var(--qp-color-text-secondary);
}
.qp-focus__note {
  display: block;
  margin-top: var(--qp-space-2);
  font-size: var(--qp-font-size-caption);
  color: var(--qp-color-text-tertiary);
}
.qp-focus__desc {
  display: block;
  margin-top: var(--qp-space-1);
  font-size: 21rpx;
  color: var(--qp-color-text-tertiary);
}

/* 中性结构线：无真实单卷进度时不显示数字/百分比 */
.qp-structure-line {
  position: relative;
  height: 2rpx;
  margin: 16rpx 0 18rpx;
  background-color: var(--qp-color-line);
  border-radius: 999rpx;
  overflow: hidden;
}
.qp-structure-line__mark {
  width: 56rpx;
  height: 100%;
  background-color: var(--qp-color-primary);
  border-radius: 999rpx;
}

/* 卡内主按钮尺寸收缩：通过 CSS 自定义属性覆盖组件令牌 */
.qp-focus ui-button {
  display: block;
  width: 100%;
  --qp-control-height: 76rpx;
  --qp-font-size-body: 28rpx;
  --qp-radius-md: 12rpx;
}

/* ===== C · 三栏数据（无背景，大等宽数字 + 竖细线） ===== */
.qp-metrics {
  display: flex;
  align-items: stretch;
  margin-bottom: var(--qp-space-5);
  padding: 0 var(--qp-space-1);
}
.qp-metric {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.qp-metric__value {
  font-size: 52rpx;
  line-height: var(--qp-line-height-tight);
  font-weight: var(--qp-font-weight-semibold);
  color: var(--qp-color-ink);
}
.qp-metric__unit {
  font-size: 28rpx;
  font-weight: var(--qp-font-weight-regular);
  color: var(--qp-color-text-secondary);
  margin-left: 2rpx;
}
.qp-metric__label {
  margin-top: var(--qp-space-1);
  font-size: var(--qp-font-size-caption);
  color: var(--qp-color-text-tertiary);
}
.qp-metric__sep {
  width: var(--qp-border-width);
  align-self: center;
  height: 56rpx;
  background-color: var(--qp-color-line);
}

/* ===== 小标签（待复习 / 需要加强 / 开始练习 / 更多工具） ===== */
.qp-eyebrow {
  display: block;
  margin-bottom: 12rpx;
  font-size: var(--qp-font-size-label);
  font-weight: var(--qp-font-weight-regular);
  letter-spacing: 2rpx;
  color: var(--qp-color-text-tertiary);
}
.qp-eyebrow-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: var(--qp-space-1);
}
.qp-eyebrow-row .qp-eyebrow {
  margin-bottom: 0;
}

/* ===== D/F/G · 训练入口行（圆点 + 标题 + 值 + 箭头，细分割线） ===== */
.qp-list {
  margin-bottom: 32rpx;
}
.qp-row {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  padding: var(--qp-space-2) 0;
  border-bottom: var(--qp-border-width) solid var(--qp-color-line);
}
.qp-list .qp-row:last-child {
  border-bottom: none;
}
.qp-row--pressed {
  background-color: var(--qp-color-surface-muted);
}
/* 主入口行：左侧墨蓝竖条强调 */
.qp-row--lead {
  position: relative;
  padding-left: var(--qp-space-3);
}
.qp-row--lead::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 3rpx;
  height: 32rpx;
  border-radius: 2rpx;
  background-color: var(--qp-color-primary);
}
.qp-row__dot {
  flex: none;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-right: var(--qp-space-3);
}
.qp-row__dot--danger { background-color: var(--qp-color-danger); }
.qp-row__dot--primary { background-color: var(--qp-color-primary); }
.qp-row__body {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}
.qp-row__title {
  flex: 1;
  font-size: 28rpx;
  font-weight: var(--qp-font-weight-semibold);
  color: var(--qp-color-ink);
}
.qp-row--lead .qp-row__title,
.qp-row__body .qp-row__title {
  flex: none;
}
.qp-row__title--regular {
  font-weight: var(--qp-font-weight-regular);
}
.qp-row__desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--qp-color-text-secondary);
}
.qp-row__desc--muted {
  color: var(--qp-color-text-tertiary);
}
.qp-row__value {
  flex: none;
  margin-left: var(--qp-space-2);
  font-size: var(--qp-font-size-body);
  font-weight: var(--qp-font-weight-semibold);
  color: var(--qp-color-ink);
}
.qp-row__chev {
  flex: none;
  margin-left: var(--qp-space-3);
  font-size: 28rpx;
  opacity: 0.45;
  color: var(--qp-color-text-tertiary);
  line-height: 1;
}

/* 更多工具行更紧凑 */
.qp-list--tools .qp-row {
  min-height: 72rpx;
}

/* 返回顶部：低频悬浮，安静描边 */
.qp-backtop {
  position: fixed;
  right: var(--qp-space-4);
  bottom: calc(var(--qp-space-6) + env(safe-area-inset-bottom));
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--qp-color-surface);
  border: var(--qp-border-width) solid var(--qp-color-line-strong);
  border-radius: var(--qp-radius-lg);
  color: var(--qp-color-text-secondary);
}
.qp-backtop__icon {
  font-size: var(--qp-font-size-section-title);
  line-height: 1;
}

/* =============================================================
   深色模式兼容（非回归）：仅回退到 app.wxss 既有深色旧令牌；
   不为 --qp-* 引入深色变体，不改 app.wxss / theme.json。 */
.qp-home.dark-theme {
  background-color: var(--bg-color);
  color: var(--text-primary);
}
.dark-theme .qp-head__title,
.dark-theme .qp-focus__title,
.dark-theme .qp-metric__value,
.dark-theme .qp-row__title,
.dark-theme .qp-row__value {
  color: var(--text-primary);
}
.dark-theme .qp-head__date,
.dark-theme .qp-head__streak,
.dark-theme .qp-focus__sub,
.dark-theme .qp-row__desc {
  color: var(--text-secondary);
}
.dark-theme .qp-focus {
  background-color: var(--card-bg);
  border-color: var(--border-color);
}
.dark-theme .qp-structure-line {
  background-color: var(--border-color);
}
.dark-theme .qp-metric__sep,
.dark-theme .qp-row {
  background-color: transparent;
}
.dark-theme .qp-metric__sep {
  background-color: var(--border-color);
}
.dark-theme .qp-row {
  border-bottom-color: var(--border-color);
}
.dark-theme .qp-backtop {
  background-color: var(--card-bg);
  border-color: var(--border-color);
  color: var(--text-secondary);
}
