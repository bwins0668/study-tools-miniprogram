/* pages/home/home.wxss - first-round monochrome redesign */

.home-page {
  padding-top: 18rpx;
  background: var(--bg-color);
}

/* ===== Hero 仪表盘区 ===== */
.hero {
  position: relative;
  overflow: hidden;
  margin: 0 24rpx 16rpx;
  padding: 28rpx 28rpx 22rpx;
  border-radius: 28rpx;
  background: var(--text-primary);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 24rpx 56rpx rgba(17, 24, 39, 0.18);
}

.hero::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background-image: radial-gradient(rgba(255,255,255,0.055) 1px, transparent 1px);
  background-size: 22rpx 22rpx;
  opacity: 0.72;
  pointer-events: none;
}

.hero-grid {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  width: 142rpx;
  height: 142rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 22rpx;
  opacity: 0.52;
}

.hero-grid::before,
.hero-grid::after {
  content: '';
  position: absolute;
  background: rgba(255, 255, 255, 0.08);
}

.hero-grid::before {
  left: 46rpx;
  top: 0;
  bottom: 0;
  width: 1rpx;
  box-shadow: 48rpx 0 0 rgba(255, 255, 255, 0.08);
}

.hero-grid::after {
  left: 0;
  right: 0;
  top: 46rpx;
  height: 1rpx;
  box-shadow: 0 48rpx 0 rgba(255, 255, 255, 0.08);
}

.hero-top,
.hero-focus,
.hero-stats,
.goal-section,
.goal-reminder {
  position: relative;
  z-index: 1;
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.hero-brand {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.hero-kicker {
  font-size: 18rpx;
  font-weight: 680;
  color: rgba(255, 255, 255, 0.42);
  letter-spacing: 2rpx;
  line-height: 1.2;
}

.hero-title {
  margin-top: 8rpx;
  font-size: 44rpx;
  font-weight: 760;
  line-height: 1.12;
  color: var(--text-inverse);
}

.hero-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.62);
  line-height: 1.42;
}

.streak-banner {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  max-width: 292rpx;
  min-height: 54rpx;
  padding: 0 8rpx 0 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.07);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.hero-streak {
  margin: 0;
}

.streak-icon,
.hero-streak-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
}

.streak-text,
.hero-streak-text {
  min-width: 0;
  font-size: 21rpx;
  color: rgba(255, 255, 255, 0.78);
  font-weight: 620;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.streak-share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx !important;
  height: 44rpx !important;
  min-height: 44rpx !important;
  margin: 0 0 0 8rpx !important;
  padding: 0 !important;
  line-height: 1 !important;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.12) !important;
  transition: transform 0.12s ease, opacity 0.12s ease, background-color 0.12s ease;
}

.streak-share-btn:active {
  transform: scale(0.92);
  opacity: 0.84;
  background: rgba(255, 255, 255, 0.18) !important;
}

.streak-share-icon {
  position: relative;
  width: 20rpx;
  height: 20rpx;
}

.share-symbol::before,
.share-symbol::after {
  content: '';
  position: absolute;
  border: 2rpx solid rgba(255, 255, 255, 0.82);
}

.share-symbol::before {
  left: 2rpx;
  bottom: 1rpx;
  width: 14rpx;
  height: 9rpx;
  border-top: none;
  border-radius: 2rpx;
}

.share-symbol::after {
  top: 2rpx;
  left: 8rpx;
  width: 7rpx;
  height: 7rpx;
  border-left: none;
  border-bottom: none;
  transform: rotate(-45deg);
}

.mini-symbol {
  position: relative;
  width: 100%;
  height: 100%;
}

.mini-symbol-streak::before,
.mini-symbol-note::before,
.mini-symbol-continue::before {
  content: '';
  position: absolute;
  border: 2rpx solid currentColor;
}

.mini-symbol-streak {
  color: rgba(255, 255, 255, 0.75);
}

.mini-symbol-streak::before {
  left: 4rpx;
  top: 4rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

.hero-focus {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx;
  margin-bottom: 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.07);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.06);
}

.hero-focus-copy {
  min-width: 0;
  flex: 1;
}

.hero-focus-label {
  display: block;
  font-size: 18rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.42);
  letter-spacing: 1rpx;
  text-transform: uppercase;
}

.hero-focus-title {
  display: block;
  margin-top: 4rpx;
  font-size: 32rpx;
  font-weight: 740;
  line-height: 1.22;
  color: var(--text-inverse);
}

.hero-focus-desc {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.58);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hero-focus-action {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 164rpx;
  min-height: 70rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: var(--card-bg);
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.16);
  transition: transform 0.12s ease, opacity 0.12s ease, background-color 0.12s ease;
}

.hero-focus-action:active {
  transform: translateY(2rpx) scale(0.97);
  opacity: 0.9;
}

.hero-focus-action-text {
  font-size: 25rpx;
  font-weight: 720;
  color: var(--text-primary);
  white-space: nowrap;
}

.hero-stats {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  padding: 12rpx 0;
  margin-bottom: 14rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.hero-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.hero-stat-value {
  font-size: 34rpx;
  font-weight: 760;
  color: var(--text-inverse);
  line-height: 1.1;
}

.hero-stat-label {
  margin-top: 6rpx;
  font-size: 19rpx;
  color: rgba(255, 255, 255, 0.48);
  white-space: nowrap;
}

.hero-stat-accent {
  color: var(--text-hint);
}

.hero-stat-success {
  color: var(--text-hint);
}

.hero-stat-divider {
  width: 1rpx;
  height: 44rpx;
  align-self: center;
  background: rgba(255, 255, 255, 0.08);
}

.goal-section {
  margin: 0;
  padding: 0;
  background: transparent;
  border-radius: 0;
  box-shadow: none;
}

.hero-progress {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.hero-progress-bar {
  flex: 1;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  overflow: hidden;
}

.goal-bar {
  height: 100%;
  border-radius: 999rpx;
  background: var(--bg-surface);
  transition: width 0.3s ease;
}

.hero-progress-fill {
  height: 100%;
  border-radius: 999rpx;
}

.goal-bar-complete,
.hero-progress-fill-complete {
  background: var(--card-bg) !important;
}

.goal-text,
.hero-progress-text {
  flex-shrink: 0;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.58);
  white-space: nowrap;
}

.goal-reminder {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.68);
  text-align: center;
}

.goal-celebrate {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 34rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  color: rgba(17, 24, 39, 0.92);
  background: rgba(255, 255, 255, 0.9);
  animation: celebrate-bounce 0.24s ease-out 1;
}

@keyframes celebrate-bounce {
  0% { transform: scale(0.98); }
  100% { transform: scale(1); }
}

/* ===== 核心入口矩阵 ===== */
.card-list,
.entry-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  padding: 0 24rpx 18rpx;
}

.entry-card {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-start;
  min-height: 184rpx;
  padding: 20rpx 20rpx 18rpx;
  border-radius: 22rpx;
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  transition: transform 0.12s ease, box-shadow 0.12s ease, opacity 0.12s ease, background-color 0.12s ease, border-color 0.12s ease;
}

.entry-card:active {
  transform: translateY(1rpx) scale(0.98);
  background: var(--press-bg);
  border-color: var(--border-strong);
  box-shadow: 0 4rpx 14rpx rgba(15, 23, 42, 0.08);
  opacity: 0.94;
}

.entry-card.home-card-pressed {
  transform: translateY(1rpx) scale(0.98);
  background: var(--press-bg);
  border-color: var(--border-strong);
  box-shadow: 0 4rpx 14rpx rgba(15, 23, 42, 0.08);
  opacity: 0.94;
}

.home-button-pressed {
  transform: translateY(1rpx) scale(0.98);
  opacity: 0.92;
}

.entry-card.home-card-navigating {
  transform: translateY(1rpx) scale(0.985);
  border-color: var(--border-strong);
  box-shadow: 0 3rpx 10rpx rgba(15, 23, 42, 0.08);
  opacity: 0.78;
}

.entry-card::before {
  content: '';
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(81, 99, 118, 0.16);
  background: var(--color-itpass-light);
}

.entry-card-anki,
.entry-card-itpass,
.entry-card-sg,
.entry-card-glossary,
.entry-card-mistakes,
.entry-card-profile {
  background: var(--card-bg);
  border-color: var(--border-color);
}

.entry-card-primary {
  background: var(--card-bg-elevated);
  border-color: var(--border-strong);
  box-shadow: var(--shadow-md);
}

.entry-card-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 66rpx;
  height: 66rpx;
  margin-bottom: 16rpx;
  border-radius: 18rpx;
  color: var(--text-primary);
  background: var(--color-itpass-light);
  border: 1rpx solid rgba(81, 99, 118, 0.12);
  transition: transform 0.12s ease, background-color 0.12s ease, border-color 0.12s ease;
}

.entry-card:active .entry-card-icon-wrap {
  transform: scale(0.94);
  background: var(--color-itpass-light);
  border-color: rgba(81, 99, 118, 0.2);
}

.entry-icon-anki,
.entry-icon-itpass,
.entry-icon-sg,
.entry-icon-glossary,
.entry-icon-mistakes,
.entry-icon-profile {
  background: var(--color-itpass-light);
}

.entry-symbol {
  position: relative;
  width: 42rpx;
  height: 42rpx;
  color: currentColor;
}

.symbol-line,
.symbol-dot,
.symbol-frame,
.symbol-shield,
.symbol-cross,
.symbol-bar {
  position: absolute;
  background: currentColor;
}

.symbol-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
}

.symbol-frame {
  left: 7rpx;
  top: 6rpx;
  width: 28rpx;
  height: 30rpx;
  border: 3rpx solid currentColor;
  border-radius: 7rpx;
  background: transparent;
}

.symbol-anki .symbol-line-a {
  left: 8rpx;
  top: 12rpx;
  width: 26rpx;
  height: 3rpx;
  border-radius: 999rpx;
  transform: rotate(24deg);
}

.symbol-anki .symbol-line-b {
  left: 8rpx;
  bottom: 12rpx;
  width: 26rpx;
  height: 3rpx;
  border-radius: 999rpx;
  transform: rotate(-24deg);
}

.symbol-anki .symbol-dot-a {
  left: 3rpx;
  top: 17rpx;
}

.symbol-anki .symbol-dot-b {
  right: 3rpx;
  top: 17rpx;
}

.symbol-itpass .symbol-line-a,
.symbol-itpass .symbol-line-b,
.symbol-itpass .symbol-line-c,
.symbol-glossary .symbol-line-a,
.symbol-glossary .symbol-line-b {
  left: 14rpx;
  width: 16rpx;
  height: 2rpx;
  border-radius: 999rpx;
}

.symbol-itpass .symbol-line-a,
.symbol-glossary .symbol-line-a {
  top: 15rpx;
}

.symbol-itpass .symbol-line-b,
.symbol-glossary .symbol-line-b {
  top: 22rpx;
}

.symbol-itpass .symbol-line-c {
  top: 29rpx;
}

.symbol-shield {
  left: 8rpx;
  top: 5rpx;
  width: 26rpx;
  height: 30rpx;
  border: 3rpx solid currentColor;
  border-radius: 14rpx 14rpx 10rpx 10rpx;
  background: transparent;
}

.symbol-sg .symbol-dot-a {
  left: 17rpx;
  top: 17rpx;
}

.symbol-cross-a,
.symbol-cross-b {
  left: 10rpx;
  top: 20rpx;
  width: 22rpx;
  height: 3rpx;
  border-radius: 999rpx;
}

.symbol-cross-a {
  transform: rotate(45deg);
}

.symbol-cross-b {
  transform: rotate(-45deg);
}

.symbol-bar {
  bottom: 7rpx;
  width: 7rpx;
  border-radius: 999rpx 999rpx 0 0;
}

.symbol-bar-a {
  left: 8rpx;
  height: 18rpx;
}

.symbol-bar-b {
  left: 18rpx;
  height: 27rpx;
}

.symbol-bar-c {
  left: 28rpx;
  height: 12rpx;
}

.entry-card-title {
  display: block;
  width: 100%;
  font-size: 27rpx;
  font-weight: 720;
  color: var(--text-primary);
  line-height: 1.26;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-title {
  font-size: 27rpx;
  font-weight: 720;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.entry-card-desc {
  display: block;
  width: 100%;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-hint);
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-title-wrap,
.entry-card-title-wrap {
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  flex-direction: column;
  width: 100%;
  min-height: 54rpx;
  gap: 6rpx;
}

.card-weak-badge,
.entry-tag-weak {
  display: inline-flex;
  align-items: center;
  min-height: 32rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 650;
  color: var(--color-warning);
  background: var(--color-warning-light);
  border: 1rpx solid rgba(139, 123, 93, 0.2);
  white-space: nowrap;
}

.card-stats,
.entry-card-stats {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  width: 100%;
  min-height: 46rpx;
  margin-top: 8rpx;
  gap: 8rpx;
  flex-wrap: wrap;
}

.card-stat-text {
  font-size: 21rpx;
  color: var(--text-secondary);
  font-weight: 560;
  line-height: 1.35;
}

.card-stat-new {
  color: var(--text-primary);
  font-weight: 660;
  background: var(--color-itpass-light);
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(81, 99, 118, 0.12);
}

.card-stat-status {
  display: inline-flex;
  align-items: center;
  min-height: 30rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 650;
  color: var(--text-secondary);
  background: var(--color-itpass-light);
  border: 1rpx solid rgba(81, 99, 118, 0.12);
}

.card-last-time {
  display: block;
  margin-top: 4rpx;
  font-size: 19rpx;
  color: var(--text-hint);
  line-height: 1.35;
}

.card-badge,
.entry-card-badge {
  position: absolute;
  top: 14rpx;
  right: 14rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 18rpx;
  font-weight: 720;
  color: var(--text-inverse);
  background: linear-gradient(135deg, #ef4444, #dc2626); /* smoke anchor */
  box-shadow: 0 4rpx 12rpx rgba(17, 24, 39, 0.12);
}

.card-entry,
.card-entry-profile {
  position: relative;
}

/* ===== 今日建议 ===== */
.suggestion-card {
  display: flex;
  align-items: flex-start;
  margin: 0 24rpx 16rpx;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
  border-left: 4rpx solid var(--border-strong);
  box-shadow: var(--shadow-sm);
  transition: transform 0.12s ease, opacity 0.12s ease, background-color 0.12s ease, border-color 0.12s ease;
}

.suggestion-card:active {
  transform: translateY(2rpx) scale(0.98);
  opacity: 0.92;
  background: var(--press-bg);
  border-color: var(--border-strong);
}

.suggestion-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
  color: var(--text-secondary);
}

.mini-symbol-note::before {
  left: 7rpx;
  top: 4rpx;
  width: 24rpx;
  height: 30rpx;
  border-radius: 7rpx;
}

.mini-symbol-note::after {
  content: '';
  position: absolute;
  left: 14rpx;
  top: 16rpx;
  width: 14rpx;
  height: 2rpx;
  border-radius: 999rpx;
  background: currentColor;
  box-shadow: 0 8rpx 0 currentColor;
}

.suggestion-content {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.suggestion-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.55;
}

.next-action-hint {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-primary);
  font-weight: 650;
}

.suggestion-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  align-self: flex-start;
  min-height: 48rpx;
  margin-top: 12rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: var(--text-primary);
  border: 1rpx solid var(--text-primary);
  transition: transform 0.12s ease, opacity 0.12s ease;
}

.suggestion-action:active {
  transform: scale(0.95);
  opacity: 0.88;
}

.suggestion-action-text {
  font-size: 22rpx;
  color: var(--text-inverse);
  font-weight: 660;
}

/* ===== 继续学习 / 快速开始 ===== */
.continue-section {
  margin: 0 24rpx 16rpx;
  padding: 0;
}

.section-title {
  display: block;
  margin-bottom: 12rpx;
  font-size: 25rpx;
  font-weight: 720;
  color: var(--text-primary);
  line-height: 1.3;
}

.continue-card {
  display: flex;
  align-items: center;
  min-height: 112rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
  transition: transform 0.12s ease, opacity 0.12s ease, background-color 0.12s ease, border-color 0.12s ease;
}

.continue-card:active {
  transform: translateY(2rpx) scale(0.98);
  opacity: 0.92;
  background: var(--press-bg);
  border-color: var(--border-strong);
}

.continue-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  color: var(--text-primary);
  border-radius: 16rpx;
  border: 1rpx solid rgba(81, 99, 118, 0.12);
  background: var(--color-itpass-light);
}

.mini-symbol-continue::before {
  left: 12rpx;
  top: 10rpx;
  width: 20rpx;
  height: 24rpx;
  border-left: none;
  border-bottom: none;
  transform: rotate(45deg);
  border-radius: 2rpx;
}

.continue-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.continue-exam {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.continue-meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 4rpx;
  min-width: 0;
}

.continue-hint,
.continue-time {
  font-size: 20rpx;
  color: var(--text-hint);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.continue-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 54rpx;
  margin-left: 14rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
  font-size: 23rpx;
  font-weight: 680;
  color: var(--text-inverse);
  background: var(--text-primary);
  transition: transform 0.12s ease, opacity 0.12s ease;
}

.continue-btn:active {
  transform: scale(0.95);
  opacity: 0.88;
}

.continue-suggestion-bar {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
  padding: 12rpx 16rpx;
  border-radius: 16rpx;
  background: var(--color-itpass-light);
  border: 1rpx solid rgba(81, 99, 118, 0.1);
}

.continue-suggestion-text {
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.continue-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 34rpx 28rpx;
  border-radius: 24rpx;
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
}

.empty-mark,
.achievement-mark {
  width: 46rpx;
  height: 46rpx;
  border-radius: 16rpx;
  border: 2rpx solid var(--text-secondary);
  position: relative;
}

.empty-mark::before,
.achievement-mark::before {
  content: '';
  position: absolute;
  left: 13rpx;
  top: 13rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  border: 2rpx solid var(--text-secondary);
}

.continue-empty-text {
  margin-top: 14rpx;
  font-size: 29rpx;
  font-weight: 720;
  color: var(--text-primary);
}

.continue-empty-hint {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.62;
}

.quick-start-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 82rpx;
  margin-top: 24rpx;
  padding: 0 34rpx;
  border-radius: 999rpx;
  background: var(--text-primary);
  color: var(--text-inverse);
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
  box-shadow: 0 14rpx 32rpx rgba(17, 24, 39, 0.14);
  transition: transform 0.12s ease, opacity 0.12s ease;
}

.quick-start-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.empty-guide-chips {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 20rpx;
  flex-wrap: wrap;
}

.empty-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 50rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  background: var(--color-itpass-light);
  border: 1rpx solid rgba(81, 99, 118, 0.12);
  transition: transform 0.12s ease, opacity 0.12s ease, background-color 0.12s ease;
}

.empty-chip:active {
  transform: scale(0.95);
  opacity: 0.85;
  background: var(--press-bg);
}

/* ===== 学习成就 ===== */
.achievement-section {
  margin: 0 24rpx 16rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
}

.achievement-list {
  margin-top: 10rpx;
  white-space: nowrap;
}

.achievement-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 132rpx;
  margin-right: 12rpx;
  padding: 12rpx;
  border-radius: 18rpx;
  background: rgba(81, 99, 118, 0.05);
  border: 1rpx solid rgba(81, 99, 118, 0.1);
}

.achievement-mark {
  width: 42rpx;
  height: 42rpx;
  border-radius: 14rpx;
}

.achievement-name {
  max-width: 110rpx;
  margin-top: 10rpx;
  font-size: 18rpx;
  color: var(--text-secondary);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.section-divider {
  height: 0;
  margin: 0;
}

.quick-tips {
  display: block;
  margin: 0 24rpx 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  background: var(--card-bg);
  border: 1rpx solid var(--border-color);
  border-left: 5rpx solid rgba(250, 140, 22, 0.38);
  box-shadow: var(--shadow-sm);
}

.quick-tips-title {
  display: block;
  margin-bottom: 6rpx;
  font-size: 23rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.quick-tips-text {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  word-break: break-word;
}

/* Hidden legacy banners */
.reminder-banner,
.quote-banner,
.practice-reminder-banner,
.update-banner {
  display: none;
}

.reminder-text,
.quote-text,
.practice-reminder-text,
.update-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 24rpx 64rpx;
}

.footer-text,
.footer-hint,
.footer-view-count {
  font-size: 20rpx;
  color: var(--text-hint);
  line-height: 1.55;
}

.back-to-top {
  position: fixed;
  right: 30rpx;
  bottom: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  color: var(--text-inverse);
  background: var(--text-primary);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 12rpx 30rpx rgba(17, 24, 39, 0.2);
  z-index: 100;
  transition: transform 0.12s ease, opacity 0.12s ease, background-color 0.12s ease;
}

.back-to-top:active {
  transform: scale(0.92);
  opacity: 0.86;
}

.back-to-top-icon {
  font-size: 32rpx;
  color: var(--text-inverse);
  font-weight: 700;
}

@media (prefers-color-scheme: dark) {
  .home-page {
    background: var(--bg-color);
  }

  .hero {
    background: var(--bg-color);
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 24rpx 56rpx rgba(0, 0, 0, 0.42);
  }

  .hero-focus-label {
    color: rgba(255, 255, 255, 0.50);
  }

  .hero-focus-title {
    color: rgba(255, 255, 255, 0.92);
  }

  .hero-focus-desc {
    color: rgba(255, 255, 255, 0.60);
  }

  .hero-focus-action,
  .quick-start-btn,
  .suggestion-action,
  .continue-btn,
  .back-to-top {
    background: var(--bg-surface);
    color: var(--text-primary);
  }

  .hero-focus-action-text,
  .suggestion-action-text,
  .back-to-top-icon {
    color: var(--text-primary);
  }

  .entry-card-primary {
    background: var(--card-bg-elevated);
  }
}

/* ---- Dark theme JS fallback ---- */
.dark-theme .hero {
  background: var(--card-bg-elevated);
  border-color: var(--border-color);
  box-shadow: 0 24rpx 56rpx rgba(0, 0, 0, 0.42);
}

.dark-theme .hero-kicker {
  color: var(--text-hint);
}

.dark-theme .hero-title {
  color: var(--text-primary);
}

.dark-theme .hero-subtitle {
  color: var(--text-secondary);
}

.dark-theme .hero-focus-label {
  color: var(--text-hint);
}

.dark-theme .hero-focus-title {
  color: var(--text-primary);
}

.dark-theme .hero-focus-desc {
  color: var(--text-secondary);
}

.dark-theme .hero-stats {
  border-top-color: var(--border-color);
  border-bottom-color: var(--border-color);
}

.dark-theme .hero-stat-divider {
  background: var(--border-color);
}

.dark-theme .hero-stat-value {
  color: var(--text-primary);
}

.dark-theme .hero-stat-label {
  color: var(--text-secondary);
}

.dark-theme .hero-focus-action,
.dark-theme .quick-start-btn,
.dark-theme .suggestion-action,
.dark-theme .continue-btn,
.dark-theme .back-to-top {
  background: var(--text-primary);
  color: var(--text-inverse);
  border: 1rpx solid var(--border-strong);
}

.dark-theme .hero-focus-action-text,
.dark-theme .suggestion-action-text,
.dark-theme .back-to-top-icon {
  color: var(--text-inverse);
}

.dark-theme .entry-card-primary {
  background: var(--card-bg-elevated);
}

