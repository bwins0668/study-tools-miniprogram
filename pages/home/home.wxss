/* pages/home/home.wxss */
/* Round 3.133: 首页仪表盘重构 */

/* ===== Hero 仪表盘区 ===== */
.hero {
  margin: 0 24rpx 10rpx;
  padding: 24rpx 28rpx 20rpx;
  background: linear-gradient(135deg, #0f1f35 0%, #1a3050 30%, #1e3a5a 60%, #152a45 100%);
  border-radius: 22rpx;
  box-shadow: 0 8rpx 32rpx rgba(15, 31, 53, 0.4);
  position: relative;
  overflow: hidden;
}

/* 微妙纹理叠加 */
.hero::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: radial-gradient(rgba(255,255,255,0.02) 1px, transparent 1px);
  background-size: 20rpx 20rpx;
  pointer-events: none;
  border-radius: 22rpx;
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.hero-brand {
  display: flex;
  flex-direction: column;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 1rpx;
}

.hero-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.55);
  margin-top: 2rpx;
}

/* R3.42 streak — 内嵌 hero 但保留 streak-banner 类名 */
.streak-banner {
  display: flex;
  align-items: center;
  background: rgba(255, 152, 0, 0.2);
  border: 1rpx solid rgba(255, 152, 0, 0.3);
  border-radius: 24rpx;
  padding: 6rpx 16rpx;
}

.hero-streak {
  margin: 0;
  padding: 6rpx 16rpx;
}

.streak-icon {
  font-size: 24rpx;
  margin-right: 4rpx;
}

.hero-streak-icon {
  font-size: 24rpx;
  margin-right: 4rpx;
}

.streak-text {
  font-size: 22rpx;
  color: #ffab40;
  font-weight: 700;
}

.hero-streak-text {
  font-size: 22rpx;
  color: #ffab40;
  font-weight: 700;
}

/* R3.55 分享按钮 */
.streak-share-btn {
  background-color: transparent !important;
  border: none !important;
  padding: 0 !important;
  margin: 0 0 0 8rpx !important;
  line-height: 1 !important;
  min-height: auto !important;
  display: inline-flex;
  align-items: center;
}

.streak-share-icon {
  font-size: 24rpx;
}

/* Hero 数据概览 */
.hero-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 14rpx;
  padding: 12rpx 8rpx;
  margin-bottom: 10rpx;
}

.hero-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.hero-stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.2;
}

.hero-stat-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 4rpx;
}

.hero-stat-accent {
  color: #ff6b6b;
}

.hero-stat-success {
  color: #69db7c;
}

.hero-stat-divider {
  width: 1rpx;
  height: 36rpx;
  background: rgba(255, 255, 255, 0.1);
}

/* R3.44 goal-section — 保留类名，内嵌 hero */
.goal-section {
  margin: 0;
  padding: 0;
  background: transparent;
  border-radius: 0;
  box-shadow: none;
}

.hero-progress {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.hero-progress-bar {
  flex: 1;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 4rpx;
  overflow: hidden;
}

.goal-bar {
  height: 100%;
  background: linear-gradient(90deg, #4a90d9, #58a6ff);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.hero-progress-fill {
  height: 100%;
  border-radius: 4rpx;
}

.goal-bar-complete {
  background: linear-gradient(90deg, #69db7c, #51cf66) !important;
}

.hero-progress-fill-complete {
  background: linear-gradient(90deg, #69db7c, #51cf66);
}

.goal-text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
  white-space: nowrap;
  flex-shrink: 0;
}

.hero-progress-text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
  white-space: nowrap;
  flex-shrink: 0;
}

.goal-reminder {
  font-size: 22rpx;
  color: #ff9800;
  text-align: center;
  margin-top: 8rpx;
}

/* R3.53 庆祝动画 */
.goal-celebrate {
  font-size: 24rpx;
  margin-left: 8rpx;
  animation: celebrate-bounce 0.6s ease-in-out infinite alternate;
}

@keyframes celebrate-bounce {
  0% { transform: scale(1); }
  100% { transform: scale(1.2); }
}

/* ===== 核心入口矩阵（2×3） ===== */
.card-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
  padding: 0 24rpx 12rpx;
}

.entry-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
  padding: 0 24rpx 12rpx;
}

.entry-card {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 10rpx 12rpx;
  border-radius: 16rpx;
  background-color: var(--card-bg);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
  overflow: hidden;
}

.entry-card:active {
  transform: scale(0.97);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.1);
}

/* 卡片顶部主题色条 */
.entry-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 5rpx;
  border-radius: 16rpx 16rpx 0 0;
}

.entry-card-anki::before {
  background: linear-gradient(90deg, var(--color-anki, #8b5cf6), #a78bfa);
}

.entry-card-itpass::before {
  background: linear-gradient(90deg, var(--color-itpass, #4a90d9), #60a5fa);
}

.entry-card-sg::before {
  background: linear-gradient(90deg, var(--color-sg, #9c27b0), #ce93d8);
}

.entry-card-glossary::before {
  background: linear-gradient(90deg, var(--color-glossary, #0891b2), #22d3ee);
}

.entry-card-mistakes::before {
  background: linear-gradient(90deg, var(--color-mistakes, #ef4444), #f87171);
}

.entry-card-profile::before {
  background: linear-gradient(90deg, var(--color-profile, #7c3aed), #a78bfa);
}

/* 图标容器 */
.entry-card-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.entry-icon-anki {
  background: var(--color-anki-light, rgba(139,92,246,0.15));
}

.entry-icon-itpass {
  background: var(--color-itpass-light, rgba(74,144,217,0.15));
}

.entry-icon-sg {
  background: var(--color-sg-light, rgba(156,39,176,0.15));
}

.entry-icon-glossary {
  background: var(--color-glossary-light, rgba(8,145,178,0.15));
}

.entry-icon-mistakes {
  background: var(--color-mistakes-light, rgba(239,68,68,0.15));
}

.entry-icon-profile {
  background: var(--color-profile-light, rgba(124,58,237,0.15));
}

.entry-card-icon {
  font-size: 30rpx;
}

.entry-card-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
  line-height: 1.3;
}

.entry-card-desc {
  font-size: 20rpx;
  color: var(--text-hint);
  text-align: center;
  margin-top: 2rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

/* R3.18 card-title-wrap 保留 */
.card-title-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 2rpx;
  gap: 4rpx;
}

.entry-card-title-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 2rpx;
  gap: 4rpx;
}

/* R3.18 card-weak-badge 保留 */
.card-weak-badge {
  font-size: 16rpx;
  font-weight: 600;
  color: #e65100;
  background: linear-gradient(135deg, #fff3e0, #ffe0b2);
  border: 1rpx solid #ffcc80;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}

.entry-tag-weak {
  font-size: 16rpx;
  font-weight: 600;
  color: #e65100;
  background: linear-gradient(135deg, #fff3e0, #ffe0b2);
  border: 1rpx solid #ffcc80;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}

/* R3.7 card-stats 保留 */
.card-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 2rpx;
  gap: 3rpx;
  flex-wrap: wrap;
}

.entry-card-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 2rpx;
  gap: 3rpx;
  flex-wrap: wrap;
}

.card-stat-text {
  font-size: 20rpx;
  color: var(--color-itpass, #4a90d9);
  font-weight: 500;
}

.card-stat-new {
  color: var(--text-hint);
}

.card-stat-status {
  font-size: 18rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #4a90d9, #6366f1);
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

/* R3.18 card-last-time 保留 */
.card-last-time {
  font-size: 18rpx;
  color: var(--text-hint);
  margin-top: 2rpx;
}

/* R3.5 card-badge 保留 */
.card-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  min-width: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
  text-align: center;
  font-size: 18rpx;
  font-weight: 700;
  color: #ffffff;
  background: linear-gradient(135deg, #ef4444, #dc2626);
  border-radius: 14rpx;
  padding: 0 6rpx;
  box-shadow: 0 2rpx 8rpx rgba(239, 68, 68, 0.3);
}

.entry-card-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  min-width: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
  text-align: center;
  font-size: 18rpx;
  font-weight: 700;
  color: #ffffff;
  background: linear-gradient(135deg, #ef4444, #dc2626);
  border-radius: 14rpx;
  padding: 0 6rpx;
  box-shadow: 0 2rpx 8rpx rgba(239, 68, 68, 0.3);
}

/* 入口卡片通用 */
.card-entry {
  position: relative;
}

/* card-title 保留（兼容） */
.card-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
  text-align: center;
}

/* 我的统计入口特殊样式 */
.card-entry-profile {
  border: 1rpx solid rgba(108, 92, 231, 0.3);
}

/* ===== 今日建议 ===== */
.suggestion-card {
  display: flex;
  align-items: flex-start;
  margin: 0 24rpx 8rpx;
  padding: 16rpx 20rpx;
  background-color: var(--card-bg);
  border-radius: 14rpx;
  border-left: 6rpx solid #4a90d9;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  position: relative;
  overflow: hidden;
}

.suggestion-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, #4a90d9, #a78bfa);
}

.suggestion-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.suggestion-content {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.suggestion-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* R3.34 next-action-hint */
.next-action-hint {
  font-size: 22rpx;
  color: #4a90d9;
  font-weight: 600;
  margin-top: 6rpx;
}

/* R3.51 建议操作按钮 */
.suggestion-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #4a90d9, #6366f1);
  border-radius: 22rpx;
  padding: 8rpx 20rpx;
  margin-top: 8rpx;
  align-self: flex-start;
  box-shadow: 0 3rpx 12rpx rgba(74, 144, 217, 0.25);
}

.suggestion-action-text {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 600;
}

/* ===== 继续学习 / 快速开始 ===== */
.continue-section {
  margin: 0 24rpx 8rpx;
  padding: 0;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.continue-card {
  display: flex;
  align-items: center;
  background: linear-gradient(170deg, var(--card-bg) 0%, rgba(255,255,255,0.98) 100%);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 3rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.15s ease;
  position: relative;
  overflow: hidden;
}

.continue-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, #4a90d9, #60a5fa);
}

.continue-card:active {
  transform: scale(0.98);
}

.continue-icon-wrap {
  width: 52rpx;
  height: 52rpx;
  background: rgba(74, 144, 217, 0.1);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.continue-icon {
  font-size: 28rpx;
}

.continue-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.continue-exam {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.continue-meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 4rpx;
}

.continue-hint {
  font-size: 20rpx;
  color: var(--text-hint);
}

.continue-time {
  font-size: 18rpx;
  color: var(--text-hint);
}

.continue-btn {
  font-size: 24rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #4a90d9, #6366f1);
  padding: 10rpx 24rpx;
  border-radius: 22rpx;
  flex-shrink: 0;
  font-weight: 600;
  box-shadow: 0 3rpx 12rpx rgba(74, 144, 217, 0.3);
}

.continue-suggestion-bar {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
  padding: 10rpx 16rpx;
  background-color: rgba(74, 144, 217, 0.06);
  border-radius: 10rpx;
}

.continue-suggestion-text {
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* 无学习记录 */
.continue-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: var(--card-bg);
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.continue-empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.continue-empty-hint {
  font-size: 22rpx;
  color: var(--text-hint);
  text-align: center;
}

/* R3.7 快速开始按钮 */
.quick-start-btn {
  font-size: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #4a90d9, #6366f1);
  padding: 20rpx 48rpx;
  border-radius: 44rpx;
  margin-top: 24rpx;
  text-align: center;
  box-shadow: 0 6rpx 24rpx rgba(74, 144, 217, 0.35);
}

/* ===== R3.47 学习成就 ===== */
.achievement-section {
  margin: 8rpx 24rpx 0;
  padding: 20rpx;
  background: var(--card-bg);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.achievement-list {
  margin-top: 8rpx;
  white-space: nowrap;
}

.achievement-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  margin-right: 12rpx;
  background: linear-gradient(135deg, #fff3e0, #ffe0b2);
  border-radius: 14rpx;
  padding: 10rpx;
}

.achievement-icon {
  font-size: 40rpx;
  margin-bottom: 6rpx;
}

.achievement-name {
  font-size: 18rpx;
  color: #e65100;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100rpx;
}

/* ===== R3.69 分区分隔线（视觉隐藏） ===== */
.section-divider {
  height: 0;
  margin: 0;
}

/* ===== R3.75 快捷操作提示（视觉隐藏） ===== */
.quick-tips {
  display: none;
}

.quick-tips-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #fa8c16;
  display: block;
  margin-bottom: 8rpx;
}

.quick-tips-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* ===== R3.52 学习提醒横幅（视觉隐藏） ===== */
.reminder-banner {
  display: none;
}

.reminder-text {
  font-size: 28rpx;
  color: #356a9f;
  font-weight: 500;
  text-align: center;
}

/* ===== R3.58 每日学习格言（视觉隐藏） ===== */
.quote-banner {
  display: none;
}

.quote-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.quote-text {
  font-size: 26rpx;
  color: #713f12;
  font-weight: 500;
  text-align: center;
  line-height: 1.5;
}

/* ===== R3.61 练习提醒（视觉隐藏） ===== */
.practice-reminder-banner {
  display: none;
}

.practice-reminder-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.practice-reminder-text {
  font-size: 26rpx;
  color: #92400e;
  font-weight: 500;
  text-align: center;
  line-height: 1.5;
}

.reminder-dismiss-btn {
  font-size: 28rpx;
  color: #92400e;
  padding: 8rpx;
}

/* ===== R3.79 最近更新提示 ===== */
.update-banner {
  display: none;
}

.update-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.update-text {
  flex: 1;
  font-size: 26rpx;
  color: #1890ff;
}

.update-dismiss-btn {
  font-size: 32rpx;
  color: #1890ff;
  padding: 8rpx;
}

/* ===== 页脚 ===== */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 24rpx 60rpx;
}

.footer-text {
  font-size: 20rpx;
  color: var(--text-hint);
}

/* R3.76 下拉刷新提示 */
.footer-hint {
  font-size: 20rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
}

/* R3.77 页面浏览次数 */
.footer-view-count {
  font-size: 20rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
}

/* ===== 返回顶部按钮 ===== */
.back-to-top {
  position: fixed;
  right: 30rpx;
  bottom: 100rpx;
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #4a90d9, #6366f1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 24rpx rgba(74, 144, 217, 0.4);
  z-index: 100;
}

.back-to-top-icon {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: bold;
}

/* ===== 深色模式覆盖 ===== */
@media (prefers-color-scheme: dark) {
  .hero {
    background: linear-gradient(135deg, #0d1b2a 0%, #1a2a3e 50%, #0f1f35 100%);
    box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.5);
  }

  .streak-banner {
    background: rgba(255, 152, 0, 0.15) !important;
    border-color: rgba(255, 152, 0, 0.25) !important;
  }

  .streak-text {
    color: #e8a040 !important;
  }

  .hero-stat-accent {
    color: #ff8787;
  }

  .hero-stat-success {
    color: #69db7c;
  }

