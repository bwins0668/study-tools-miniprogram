<!--pages/home/home.wxml · Course Center landing page-->
<view data-r6-active-tab="course" class="cc-home {{__themeDark ? 'dark-theme' : ''}}" style="padding-top: {{navSafeTop}}px;">
  <view class="cc-mast">
    <view>
      <text class="cc-mast__kicker">コース · 学習</text>
      <text class="cc-mast__title">课程</text>
    </view>
    <text class="cc-mast__meta" wx:if="{{streakCount > 0}}">连续 {{streakCount}} 天</text>
  </view>
  <view class="cc-rule">
    <view class="cc-rule__accent"></view>
    <view class="cc-rule__line"></view>
  </view>

  <!-- A. 学习状态 -->
  <view class="cc-hero">
    <block wx:if="{{hasLastAttempt}}">
      <text class="cc-hero__kicker">上次练习</text>
      <text class="cc-hero__title">{{lastExamLabel}}</text>
      <text class="cc-hero__sub" wx:if="{{lastMetaText}}">{{lastMetaText}}</text>
      <view class="cc-hero__actions">
        <view class="cc-btn cc-btn--primary" bindtap="continueLearning">再练一次</view>
        <view class="cc-btn cc-btn--outline" bindtap="goReview">今日复习</view>
      </view>
      <text class="cc-hero__streak" wx:if="{{streakCount > 0}}">连续学习 {{streakCount}} 天</text>
    </block>
    <block wx:else>
      <text class="cc-hero__kicker">开始学习</text>
      <text class="cc-hero__title">从一门课程或考试开始</text>
      <view class="cc-hero__actions">
        <view class="cc-btn cc-btn--primary" bindtap="goPractice">开始刷题</view>
        <view class="cc-btn cc-btn--outline" bindtap="goToCourseArea">浏览课程</view>
      </view>
    </block>
  </view>

  <!-- B. 课程学习 -->
  <view class="cc-section cc-section--courses">
    <view class="r6-section-label"><text class="r6-section-label__num">02</text><text class="cc-section__title">课程学习</text><text class="r6-section-label__meta">即将开放</text></view>
    <view class="r6-course-strip">
      <block wx:for="{{languageCourses}}" wx:key="id">
        <view class="r6-course-strip__item {{item.availability === 'planned' ? 'r6-course-strip__item--planned' : ''}}"
          bindtap="goToCourse" data-course-id="{{item.id}}"
          hover-class="r6-course-strip__item--pressed">
          <text class="r6-course-strip__abbr">{{item.displayName[0]}}{{item.displayName[1] || ''}}</text>
          <text class="r6-course-strip__name">{{item.displayName}}</text>
        </view>
      </block>
      <view class="r6-course-strip__badge">敬请期待</view>
    </view>
  </view>

  <!-- C. 资格考试 -->
  <view class="cc-section">
    <view class="r6-section-label"><text class="r6-section-label__num">01</text><text class="cc-section__title">资格考试</text></view>
    <view class="cc-exam-list">
      <block wx:for="{{examCourses}}" wx:key="id">
        <view wx:if="{{item.availability === 'available'}}" class="cc-exam-card r6-exam-row" bindtap="goToCourse" data-course-id="{{item.id}}"
          hover-class="home-card-pressed" hover-start-time="20" hover-stay-time="120">
          <view class="cc-exam-card__body">
            <text class="cc-exam-card__name">{{item.displayName}}</text>
            <text class="cc-exam-card__desc">{{item.description}}</text>
          </view>
          <view class="cc-exam-card__action r6-exam-row__action" catchtap="goToPractice" data-course-id="{{item.id}}"
            hover-class="home-card-pressed" hover-start-time="20" hover-stay-time="120">开始刷题</view>
        </view>
        <view wx:else class="cc-exam-card r6-exam-row cc-exam-card--muted">
          <view class="cc-exam-card__body">
            <text class="cc-exam-card__name">{{item.displayName}}</text>
            <text class="cc-exam-card__desc">{{item.description}}</text>
          </view>
          <text class="cc-exam-card__status">准备中</text>
        </view>
      </block>
    </view>
  </view>

  <!-- D. 学习记录 -->
  <view class="cc-section">
    <view class="cc-record-link" bindtap="goProfile">
      <text class="cc-record-link__text">学习记录</text>
      <text class="cc-record-link__arrow">→</text>
    </view>
  </view>

  <!-- Back to top -->
  <view class="cc-backtop" wx:if="{{showBackToTop}}" bindtap="scrollToTop">
    <text class="cc-backtop__icon">↑</text>
  </view>
</view>
