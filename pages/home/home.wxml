<!--pages/home/home.wxml-->
<view class="container">
  <!-- 头部标题 -->
  <view class="header">
    <text class="title">Study Tools</text>
    <text class="subtitle">中日双语 IT 学习工具</text>
  </view>

  <!-- 学习概览 -->
  <view class="overview-section">
    <text class="section-title">学习概览</text>
    <view class="overview-row">
      <view class="overview-item">
        <text class="overview-value">{{todayTotal}}</text>
        <text class="overview-label">今日答题</text>
      </view>
      <view class="overview-item">
        <text class="overview-value">{{favoriteCount}}</text>
        <text class="overview-label">已收藏术语</text>
      </view>
      <view class="overview-item">
        <text class="overview-value">{{wrongQuestionCount}}</text>
        <text class="overview-label">错题数量</text>
      </view>
    </view>
    <view class="overview-row overview-row-extra">
      <view class="overview-item">
        <text class="overview-value overview-accuracy">{{accuracy}}%</text>
        <text class="overview-label">总正确率</text>
      </view>
      <view class="overview-item" wx:if="{{lastPracticeTimeText}}">
        <text class="overview-value overview-time">{{lastPracticeTimeText}}</text>
        <text class="overview-label">最近练习</text>
      </view>
    </view>
  </view>

  <!-- 今日建议 -->
  <view class="suggestion-card" wx:if="{{suggestion}}">
    <text class="suggestion-icon">💡</text>
    <text class="suggestion-text">{{suggestion}}</text>
  </view>

  <!-- 继续学习 / 快速开始 -->
  <view class="continue-section" wx:if="{{hasLastAttempt}}">
    <text class="section-title">{{sectionTitle}}</text>
    <view class="continue-card" bindtap="continueLearning">
      <view class="continue-icon">📚</view>
      <view class="continue-info">
        <text class="continue-exam">{{lastExamLabel}} · {{lastSourceLabel}}</text>
        <text class="continue-hint">继续上次的练习</text>
      </view>
      <view class="continue-btn">继续练习</view>
    </view>
  </view>

  <!-- 无学习记录 / 快速开始 -->
  <view class="continue-section" wx:if="{{!hasLastAttempt}}">
    <text class="section-title">{{sectionTitle}}</text>
    <view class="continue-empty">
      <text class="continue-empty-text">还没有学习记录</text>
      <text class="continue-empty-hint">从 IT Passport 课程练习开始，也可以选择其他题库</text>
      <view class="quick-start-btn" bindtap="quickStart">快速开始 · IT Passport 课程练习</view>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="section-label">快捷入口</view>

  <view class="card-list">
    <!-- 错题本（优先，有数据时显示徽标） -->
    <view class="card card-entry" bindtap="goToMistakes">
      <view class="card-icon">📋</view>
      <view class="card-info">
        <text class="card-title">错题本</text>
        <text class="card-desc">查看做错的题目和复习记录</text>
      </view>
      <view class="card-badge" wx:if="{{wrongQuestionCount > 0}}">{{wrongQuestionCount}}</view>
      <view class="card-arrow">›</view>
    </view>

    <!-- 收藏术语复习 -->
    <view class="card card-entry" bindtap="goToFavoriteReview">
      <view class="card-icon">⭐</view>
      <view class="card-info">
        <text class="card-title">收藏术语复习</text>
        <text class="card-desc">逐张复习已收藏的术语卡片</text>
      </view>
      <view class="card-badge" wx:if="{{favoriteCount > 0}}">{{favoriteCount}}</view>
      <view class="card-arrow">›</view>
    </view>

    <!-- Glossary 术语表 -->
    <view class="card card-entry" bindtap="goToGlossary">
      <view class="card-icon">📖</view>
      <view class="card-info">
        <text class="card-title">Glossary 术语表</text>
        <text class="card-desc">IT 术语中日英对照查询</text>
      </view>
      <view class="card-arrow">›</view>
    </view>

    <!-- IT Passport -->
    <view class="card card-entry" bindtap="goToItPassport">
      <view class="card-icon">📝</view>
      <view class="card-info">
        <text class="card-title-wrap">
          <text class="card-title">IT Passport · 基础考试方向</text>
          <text class="card-weak-badge" wx:if="{{itpassWeak}}">建议优先复习</text>
        </text>
        <text class="card-desc">IT パスポート試験</text>
        <view class="card-stats">
          <text class="card-stat-text" wx:if="{{itpassTotal > 0}}">已做 {{itpassTotal}} 题 · 正确率 {{itpassAccuracy}}%</text>
          <text class="card-stat-text card-stat-new" wx:else>未练习</text>
          <text class="card-stat-status">{{itpassStatusText}}</text>
        </view>
        <text class="card-last-time" wx:if="{{itpassLastTime}}">最近练习：{{itpassLastTime}}</text>
      </view>
      <view class="card-arrow">›</view>
    </view>

    <!-- SG 考试 -->
    <view class="card card-entry" bindtap="goToSG">
      <view class="card-icon">🎯</view>
      <view class="card-info">
        <text class="card-title-wrap">
          <text class="card-title">SG · 信息安全管理方向</text>
          <text class="card-weak-badge" wx:if="{{sgWeak}}">建议优先复习</text>
        </text>
        <text class="card-desc">システム監査技術者</text>
        <view class="card-stats">
          <text class="card-stat-text" wx:if="{{sgTotal > 0}}">已做 {{sgTotal}} 题 · 正确率 {{sgAccuracy}}%</text>
          <text class="card-stat-text card-stat-new" wx:else>未练习</text>
          <text class="card-stat-status">{{sgStatusText}}</text>
        </view>
        <text class="card-last-time" wx:if="{{sgLastTime}}">最近练习：{{sgLastTime}}</text>
      </view>
      <view class="card-arrow">›</view>
    </view>

    <!-- 我的统计（使用 switchTab） -->
    <view class="card card-entry card-entry-profile" bindtap="goToProfile">
      <view class="card-icon">👤</view>
      <view class="card-info">
        <text class="card-title">我的统计</text>
        <text class="card-desc">查看详细学习数据和备份管理</text>
      </view>
      <view class="card-arrow">›</view>
    </view>
  </view>
</view>
