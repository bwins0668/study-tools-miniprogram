<!--pages/home/home.wxml · Quiet Paper 首页视觉冻结层-->
<view class="qp-home {{__themeDark ? 'dark-theme' : ''}}" style="padding-top: {{navSafeTop}}px;">
  <view class="qp-head">
    <text class="qp-head__title">{{uiText.panelTitle}}</text>
    <view class="qp-head__meta">
      <text class="qp-head__date qp-num">{{headDateText}}</text>
      <block wx:if="{{streakCount > 0}}">
        <text class="qp-head__dot">·</text>
        <text class="qp-head__streak">连续 <text class="qp-num qp-ink-strong">{{streakCount}}</text> 天</text>
      </block>
    </view>
  </view>

  <view class="qp-focus">
    <block wx:if="{{hasLastAttempt}}">
      <text class="qp-focus__kicker">{{uiText.continueKicker}}</text>
      <text class="qp-focus__title">{{lastExamLabel}}</text>
      <text class="qp-focus__sub" wx:if="{{lastMetaText}}">{{lastMetaText}}</text>

      <view class="qp-structure-line" aria-hidden="true">
        <view class="qp-structure-line__mark"></view>
      </view>

      <ui-button variant="primary" text="{{uiText.continueButton}}" bind:qptap="continueLearning"></ui-button>
    </block>

    <block wx:else>
      <text class="qp-focus__kicker">{{uiText.startKicker}}</text>
      <text class="qp-focus__title">{{uiText.startTitle}}</text>
      <text class="qp-focus__sub">{{uiText.startSub}}</text>
      <text class="qp-focus__desc">{{uiText.startDesc}}</text>

      <view class="qp-structure-line" aria-hidden="true"></view>

      <ui-button variant="primary" text="{{uiText.startButton}}" bind:qptap="quickStart"></ui-button>
    </block>
  </view>

  <view class="qp-metrics" wx:if="{{todayTotal > 0 || totalAttempts > 0 || favoriteCount > 0}}">
    <view class="qp-metric" wx:if="{{todayTotal > 0}}">
      <text class="qp-metric__value qp-num">{{todayTotal}}</text>
      <text class="qp-metric__label">今日答题</text>
    </view>
    <view class="qp-metric__sep" wx:if="{{todayTotal > 0 && totalAttempts > 0}}"></view>
    <view class="qp-metric" wx:if="{{totalAttempts > 0}}">
      <text class="qp-metric__value qp-num">{{accuracy}}<text class="qp-metric__unit">%</text></text>
      <text class="qp-metric__label">正确率</text>
    </view>
    <view class="qp-metric__sep" wx:if="{{(todayTotal > 0 || totalAttempts > 0) && favoriteCount > 0}}"></view>
    <view class="qp-metric" wx:if="{{favoriteCount > 0}}">
      <text class="qp-metric__value qp-num">{{favoriteCount}}</text>
      <text class="qp-metric__label">已收藏</text>
    </view>
  </view>

  <block wx:if="{{wrongQuestionCount > 0 || favoriteCount > 0}}">
    <text class="qp-eyebrow">{{uiText.reviewSection}}</text>
    <view class="qp-list">
      <view class="qp-row ui-pressable" wx:if="{{wrongQuestionCount > 0}}" bindtap="goToMistakes" hover-class="qp-row--pressed" hover-stay-time="80">
        <view class="qp-row__dot qp-row__dot--danger"></view>
        <text class="qp-row__title">{{uiText.mistakeReview}}</text>
        <text class="qp-row__value qp-num">{{wrongQuestionCount}}</text>
        <text class="qp-row__chev">›</text>
      </view>
      <view class="qp-row ui-pressable" wx:if="{{favoriteCount > 0}}" bindtap="goToFavoriteReview" hover-class="qp-row--pressed" hover-stay-time="80">
        <view class="qp-row__dot qp-row__dot--primary"></view>
        <text class="qp-row__title">{{uiText.flashcardReview}}</text>
        <text class="qp-row__value qp-num">{{favoriteCount}}</text>
        <text class="qp-row__chev">›</text>
      </view>
    </view>
  </block>

  <!-- E · 需要加强 -->
  <block wx:if="{{itpassWeak || sgWeak}}">
    <text class="qp-eyebrow">{{uiText.weakSection}}</text>
    <view class="qp-list">
      <view class="qp-row ui-pressable" wx:if="{{itpassWeak}}" bindtap="goToItPassport" hover-class="qp-row--pressed" hover-stay-time="80">
        <view class="qp-row__dot qp-row__dot--danger"></view>
        <view class="qp-row__body">
          <text class="qp-row__title">{{uiText.itpassTitle}} · 需要加强</text>
          <text class="qp-row__desc">正确率 {{itpassAccuracy}}%</text>
          <view class="qp-structure-line" aria-hidden="true">
            <view class="qp-structure-line__mark" style="background-color: var(--qp-color-danger); width: {{itpassAccuracy}}%"></view>
          </view>
        </view>
        <text class="qp-row__chev">›</text>
      </view>
      <view class="qp-row ui-pressable" wx:if="{{sgWeak}}" bindtap="goToSG" hover-class="qp-row--pressed" hover-stay-time="80">
        <view class="qp-row__dot qp-row__dot--danger"></view>
        <view class="qp-row__body">
          <text class="qp-row__title">{{uiText.sgTitle}} · 需要加强</text>
          <text class="qp-row__desc">正确率 {{sgAccuracy}}%</text>
          <view class="qp-structure-line" aria-hidden="true">
            <view class="qp-structure-line__mark" style="background-color: var(--qp-color-danger); width: {{sgAccuracy}}%"></view>
          </view>
        </view>
        <text class="qp-row__chev">›</text>
      </view>
    </view>
  </block>

  <text class="qp-eyebrow">{{uiText.practiceSection}}</text>
  <view class="qp-list">
    <view class="qp-row qp-row--lead ui-pressable" bindtap="goToItPassport" hover-class="qp-row--pressed" hover-stay-time="80">
      <view class="qp-row__body">
        <text class="qp-row__title">{{uiText.itpassTitle}}</text>
        <text class="qp-row__desc" wx:if="{{itpassTotal > 0}}">已做 <text class="qp-num">{{itpassTotal}}</text> 题 · 正确率 <text class="qp-num">{{itpassAccuracy}}</text>%</text>
        <text class="qp-row__desc qp-row__desc--muted" wx:else>{{uiText.itpassEmpty}}</text>
      </view>
      <text class="qp-row__chev">›</text>
    </view>
    <view class="qp-row ui-pressable" bindtap="goToSG" hover-class="qp-row--pressed" hover-stay-time="80">
      <view class="qp-row__body">
        <text class="qp-row__title">{{uiText.sgTitle}}</text>
        <text class="qp-row__desc" wx:if="{{sgTotal > 0}}">已做 <text class="qp-num">{{sgTotal}}</text> 题 · 正确率 <text class="qp-num">{{sgAccuracy}}</text>%</text>
        <text class="qp-row__desc qp-row__desc--muted" wx:else>{{uiText.sgEmpty}}</text>
      </view>
      <text class="qp-row__chev">›</text>
    </view>
    <view class="qp-row ui-pressable" bindtap="goToJavaCourse" hover-class="qp-row--pressed" hover-stay-time="80">
      <view class="qp-row__body">
        <text class="qp-row__title">{{uiText.javaTitle}}</text>
        <text class="qp-row__desc" wx:if="{{javaCompleted > 0}}">已学 <text class="qp-num">{{javaCompleted}}</text> 小节</text>
        <text class="qp-row__desc qp-row__desc--muted" wx:else>{{uiText.javaEmpty}}</text>
      </view>
      <text class="qp-row__chev">›</text>
    </view>
  </view>

  <text class="qp-eyebrow">{{uiText.toolsSection}}</text>
  <view class="qp-list qp-list--tools">
    <view class="qp-row ui-pressable" bindtap="goToGlossary" hover-class="qp-row--pressed" hover-stay-time="80">
      <text class="qp-row__title qp-row__title--regular">{{uiText.glossary}}</text>
      <text class="qp-row__chev">›</text>
    </view>
    <view class="qp-row ui-pressable" bindtap="goToAnki" hover-class="qp-row--pressed" hover-stay-time="80">
      <text class="qp-row__title qp-row__title--regular">{{uiText.anki}}</text>
      <text class="qp-row__chev">›</text>
    </view>
    <view class="qp-row ui-pressable" bindtap="goToProfile" hover-class="qp-row--pressed" hover-stay-time="80">
      <text class="qp-row__title qp-row__title--regular">{{uiText.profile}}</text>
      <text class="qp-row__chev">›</text>
    </view>
  </view>

  <view class="qp-backtop ui-pressable" wx:if="{{showBackToTop}}" bindtap="scrollToTop">
    <text class="qp-backtop__icon">↑</text>
  </view>
</view>
