/* app.wxss - 全局样式与设计 Token */
/* Round 3.143: 建立第一版全局设计 token */

page {
  /* ===== 颜色系统 ===== */
  /* 基础色 */
  --bg-color: #f5f5f5;
  --card-bg: #ffffff;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --border-color: #eeeeee;
  --divider-color: #f0f0f0;

  /* 品牌色 */
  --primary-color: #4a90d9;
  --primary-light: #e8f4fd;
  --primary-dark: #3a7bc8;

  /* 功能色 */
  --color-success: #22c55e;
  --color-success-light: #dcfce7;
  --color-warning: #f59e0b;
  --color-warning-light: #fef3c7;
  --color-error: #ef4444;
  --color-error-light: #fef2f2;
  --color-info: #4a90d9;
  --color-info-light: #e8f4fd;

  /* 考试方向色 */
  --color-itpass: #4a90d9;
  --color-itpass-light: rgba(74,144,217,0.1);
  --color-sg: #9c27b0;
  --color-sg-light: rgba(156,39,176,0.1);
  --color-anki: #8b5cf6;
  --color-anki-light: rgba(139,92,246,0.1);
  --color-glossary: #0891b2;
  --color-glossary-light: rgba(8,145,178,0.1);
  --color-mistakes: #ef4444;
  --color-mistakes-light: rgba(239,68,68,0.1);
  --color-profile: #7c3aed;
  --color-profile-light: rgba(124,58,237,0.1);

  /* ===== 间距系统 ===== */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;
  --space-2xl: 64rpx;

  /* ===== 圆角系统 ===== */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-full: 50%;

  /* ===== 阴影系统 ===== */
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.06);
  --shadow-lg: 0 8rpx 32rpx rgba(0,0,0,0.1);
  --shadow-xl: 0 16rpx 48rpx rgba(0,0,0,0.15);

  /* ===== 字体层级 ===== */
  --font-xs: 20rpx;
  --font-sm: 22rpx;
  --font-base: 26rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-2xl: 40rpx;
  --font-3xl: 48rpx;

  /* ===== 动画 ===== */
  --transition-fast: 0.12s ease;
  --transition-normal: 0.2s ease;
  --transition-slow: 0.3s ease;

  /* ===== 页面基础 ===== */
  background-color: var(--bg-color, #f5f5f5);
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", Arial, sans-serif;
  font-size: 28rpx;
  color: var(--text-primary, #333333);
  line-height: 1.6;
  box-sizing: border-box;
}

/* ===== 暗色模式 ===== */
@media (prefers-color-scheme: dark) {
  page {
    --bg-color: #0d1117;
    --card-bg: #1e1e2e;
    --text-primary: #e0e0e0;
    --text-secondary: #a0a0a0;
    --text-hint: #666666;
    --border-color: #333333;
    --divider-color: #2a2a2a;
    --primary-color: #58a6ff;
    --primary-light: #1a2a3e;
    --primary-dark: #79b8ff;

    --color-success: #4ade80;
    --color-success-light: rgba(74,222,128,0.12);
    --color-warning: #fbbf24;
    --color-warning-light: rgba(251,191,36,0.12);
    --color-error: #f87171;
    --color-error-light: rgba(248,113,113,0.12);
    --color-info: #58a6ff;
    --color-info-light: rgba(88,166,255,0.12);

    --color-itpass: #58a6ff;
    --color-itpass-light: rgba(88,166,255,0.12);
    --color-sg: #ce93d8;
    --color-sg-light: rgba(206,147,216,0.12);
    --color-anki: #a78bfa;
    --color-anki-light: rgba(167,139,250,0.12);
    --color-glossary: #22d3ee;
    --color-glossary-light: rgba(34,211,238,0.12);
    --color-mistakes: #f87171;
    --color-mistakes-light: rgba(248,113,113,0.12);
    --color-profile: #a78bfa;
    --color-profile-light: rgba(167,139,250,0.12);

    --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.15);
    --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.2);
    --shadow-lg: 0 8rpx 32rpx rgba(0,0,0,0.25);
    --shadow-xl: 0 16rpx 48rpx rgba(0,0,0,0.3);
  }
}

/* ===== 通用组件 ===== */
.card {
  background-color: var(--card-bg, #ffffff);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  margin: var(--space-sm) 30rpx;
  box-shadow: var(--shadow-sm);
}

.container {
  padding: 20rpx 0;
  min-height: 100vh;
}

/* ===== 全局按钮系统 ===== */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #3b82f6 0%, #6366f1 52%, #8b5cf6 100%);
  border-radius: 44rpx;
  padding: 24rpx 48rpx;
  box-shadow: 0 8rpx 26rpx rgba(79, 70, 229, 0.32);
  transition: transform 0.12s ease, box-shadow 0.12s ease, filter 0.12s ease;
}

.btn-primary:active {
  transform: translateY(2rpx) scale(0.97);
  box-shadow: 0 3rpx 12rpx rgba(79, 70, 229, 0.24);
  filter: saturate(1.08);
}

.btn-primary-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 1rpx;
}

.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(74, 144, 217, 0.06), var(--card-bg) 72%);
  border: 2rpx solid var(--primary-color);
  border-radius: 44rpx;
  padding: 22rpx 48rpx;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.28);
  transition: transform 0.12s ease, opacity 0.12s ease;
}

.btn-secondary:active {
  transform: translateY(2rpx) scale(0.97);
  opacity: 0.88;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.18);
}

.btn-secondary-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.btn-danger {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f97316 0%, #ef4444 48%, #dc2626 100%);
  border-radius: 44rpx;
  padding: 24rpx 48rpx;
  box-shadow: 0 7rpx 24rpx rgba(239, 68, 68, 0.28);
  transition: transform 0.12s ease, box-shadow 0.12s ease;
}

.btn-danger:active {
  transform: translateY(2rpx) scale(0.97);
  box-shadow: 0 3rpx 12rpx rgba(239, 68, 68, 0.22);
}

.btn-danger-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

/* ===== 全局标签系统 ===== */
.tag {
  display: inline-flex;
  align-items: center;
  font-size: var(--font-sm);
  font-weight: 650;
  padding: 7rpx 16rpx;
  border-radius: 12rpx;
  letter-spacing: 0.5rpx;
  border: 1rpx solid transparent;
}

.tag-itpass {
  color: var(--color-itpass);
  background-color: var(--color-itpass-light);
  border-color: rgba(74, 144, 217, 0.18);
}

.tag-sg {
  color: var(--color-sg);
  background-color: var(--color-sg-light);
  border-color: rgba(156, 39, 176, 0.18);
}

.tag-anki {
  color: var(--color-anki);
  background-color: var(--color-anki-light);
  border-color: rgba(139, 92, 246, 0.18);
}

.tag-glossary {
  color: var(--color-glossary);
  background-color: var(--color-glossary-light);
  border-color: rgba(8, 145, 178, 0.18);
}

.tag-mistakes {
  color: var(--color-mistakes);
  background-color: var(--color-mistakes-light);
  border-color: rgba(239, 68, 68, 0.18);
}

.tag-profile {
  color: var(--color-profile);
  background-color: var(--color-profile-light);
  border-color: rgba(124, 58, 237, 0.18);
}

/* ===== 全局色条工具类 ===== */
.bar-top {
  position: relative;
  overflow: hidden;
}

.bar-top::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 5rpx;
  border-radius: inherit;
}

.bar-top-itpass::before {
  background: linear-gradient(90deg, var(--color-itpass), #60a5fa);
}

.bar-top-sg::before {
  background: linear-gradient(90deg, var(--color-sg), #ce93d8);
}

.bar-top-anki::before {
  background: linear-gradient(90deg, var(--color-anki), #a78bfa);
}

.bar-top-glossary::before {
  background: linear-gradient(90deg, var(--color-glossary), #22d3ee);
}

.bar-top-mistakes::before {
  background: linear-gradient(90deg, var(--color-mistakes), #f87171);
}

.bar-top-profile::before {
  background: linear-gradient(90deg, var(--color-profile), #a78bfa);
}

/* 左侧色条 */
.bar-left {
  position: relative;
  overflow: hidden;
  border-left: 6rpx solid var(--primary-color);
}

.bar-left-success {
  border-left-color: var(--color-success);
}

.bar-left-warning {
  border-left-color: var(--color-warning);
}

.bar-left-error {
  border-left-color: var(--color-error);
}

.bar-left-info {
  border-left-color: var(--color-info);
}
